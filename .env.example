# Vorlage. Kopiere diese Datei nach .env und trage echte Werte ein.
# .env ist per .gitignore vom Repo ausgenommen.

# Adresse des selbst gehosteten PocketBase-Servers.
PB_URL=http://127.0.0.1:8090

# Zugaenge fuer das lokale Seeding (scripts/seed.mjs)
PB_ADMIN_EMAIL=admin@example.local
PB_ADMIN_PW=change-me-admin
PB_MEMBER_EMAIL=mitglied@example.local
PB_MEMBER_PW=change-me-member

# Optional: aktive Vereinsseite (Default: goerlitz)
# SITE_ID=goerlitz
