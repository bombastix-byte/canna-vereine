# Astro-Server (oeffentliche Seiten + Mitgliederbereich) je Verein.
# Der Verein wird ueber das Build-Argument SITE_ID gewaehlt.
FROM node:24.11.0-alpine AS build
ARG SITE_ID=goerlitz
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
ENV SITE_ID=${SITE_ID}
# Eigene Domain -> Basis '/', voller Hybrid-Build (statische Seiten + SSR).
RUN npm run build

FROM node:24.11.0-alpine
WORKDIR /app
ENV NODE_ENV=production HOST=0.0.0.0 PORT=4321
COPY --from=build /app/dist ./dist
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/package.json ./package.json
EXPOSE 4321
CMD ["node", "./dist/server/entry.mjs"]
