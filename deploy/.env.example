# Domains je Verein (ohne https://). Kopie nach .env, echte Domains eintragen.
DOMAIN_GOERLITZ=goerlitz.example.de
DOMAIN_GOERLITZ2=csc-goerlitz.example.de
DOMAIN_LEIPZIG=leipzig.example.de

# E-Mail fuer Let's Encrypt (Zertifikats-Benachrichtigungen)
ACME_EMAIL=admin@example.de

# ---- E-Mail-Versand (optional; ohne diese Werte wird nicht gesendet) ----
# SMTP-Zugang des Vereinspostfachs. Antragsbestaetigung, Zugangsdaten bei
# Aufnahme und Ablehnungen gehen dann automatisch raus.
#SMTP_HOST=mail.example.de
#SMTP_PORT=587
#SMTP_USER=verein@example.de
#SMTP_PASS=geheim
#SMTP_FROM=Anbauvereinigung <verein@example.de>

# ---- Etikettendrucker (optional; sonst ZPL-Datei-Download) ----
#PRINTER_HOST=192.168.0.50
#PRINTER_PORT=9100

# ---- SEPA-Lastschrift (optional; fuer den Beitrags-Export) ----
# Glaeubiger = der Verein. Ohne diese Werte ist der SEPA-Export gesperrt.
#SEPA_GLAEUBIGER_NAME=Anbauvereinigung Goerlitz e. V.
#SEPA_GLAEUBIGER_IBAN=DE00000000000000000000
#SEPA_GLAEUBIGER_BIC=GENODEF1XXX
#SEPA_GLAEUBIGER_ID=DE98ZZZ09999999999
