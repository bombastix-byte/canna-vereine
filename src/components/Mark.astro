---
// Abstraktes, ruhiges Emblem (Spross/Wachstum). Bewusst neutral gehalten,
// keine konsumbezogene oder verherrlichende Darstellung. Nutzt currentColor.
interface Props {
  class?: string;
}
const { class: klasse } = Astro.props;
---

<svg
  class={klasse}
  viewBox="0 0 48 48"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Emblem"
>
  <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.5" />
  <path
    d="M24 34V18"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
  />
  <path
    d="M24 22C24 22 20.5 21 18.5 17.5C22.5 16.5 24 19.5 24 22Z"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linejoin="round"
  />
  <path
    d="M24 24.5C24 24.5 27.5 23.5 29.5 20C25.5 19 24 22 24 24.5Z"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linejoin="round"
  />
</svg>
