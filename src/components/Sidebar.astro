---
import { site, navigation, produkt } from '../config';
import { pfad } from '../lib/url';
import Mark from './Mark.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../lib/pb';
import { mitgliedPunkte as baueMitgliedPunkte, arbeitPunkteFuer, istAktiv as punktAktiv } from '../lib/mitglied-nav';
import { uebersetzer } from '../lib/i18n';
import SprachWahl from './SprachWahl.astro';
import { istVereinsarbeitPfad } from '../lib/vereinsarbeit';

// Seitenleiste (Layout "sidebar"). Oeffentliche Navigation fuer Besucher;
// fuer angemeldete Mitglieder zusaetzlich der komplette Mitgliederbereich
// (rollenbasiert). Auf statisch gebauten Seiten gibt es keinen Cookie -
// mitgliedAusToken(undefined) liefert dann sofort null, kein PB-Zugriff.
const hier = Astro.url.pathname;
const home = pfad('/');
const istAktiv = (href: string) =>
  href === '/' ? hier === home : hier.startsWith(pfad(href));

let mitglied: { rollen?: string[] } | null = null;
if (hier.startsWith('/mitglieder')) {
  try {
    mitglied = (await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value))?.mitglied ?? null;
  } catch {
    mitglied = null;
  }
}
const funktionen = Astro.locals.funktionen;
const sprache = Astro.locals.sprache ?? 'de';
const tNav = uebersetzer(sprache);
const MITGLIED_PUNKTE = baueMitgliedPunkte(funktionen, sprache);
const arbeitPunkte = mitglied ? arbeitPunkteFuer(mitglied.rollen, funktionen) : [];
const aufVereinsarbeit = istVereinsarbeitPfad(hier);

// Anonyme Eingangs-Ansicht: nicht angemeldet UND kein oeffentlicher Auftritt.
// Dann verraet die Startseite weder Vereinsname noch Ort; Impressum/Daten-
// schutz bleiben unter ihrer URL erreichbar, sind aber nicht sichtbar
// verlinkt (analog App: Impressum erst im Inneren).
const anonym = !mitglied && site.oeffentlich === false;
---

{anonym ? (
  <span class="sb-brand sb-brand--side">
    <Mark class="sb-mark" />
    <span class="sb-brand__text">
      <span class="sb-name">Mitgliederbereich</span>
    </span>
  </span>
) : mitglied ? (
  <a class="sb-brand sb-brand--side" href="/mitglieder/bereich">
    <Mark class="sb-mark" />
    <span class="sb-brand__text">
      <span class="sb-name">{produkt.name}</span>
      <span class="sb-stadt">{site.kuerzel ? `${site.kuerzel} · ` : ''}{site.kurzname}</span>
    </span>
  </a>
) : (
  <a class="sb-brand sb-brand--side" href={pfad('/')}>
    <Mark class="sb-mark" />
    <span class="sb-brand__text">
      <span class="sb-name">{site.kurzname}</span>
      <span class="sb-stadt">Anbauvereinigung in {site.stadt}</span>
    </span>
  </a>
)}

{mitglied ? (
  <>
    <nav class="sb-nav" aria-label="Mitgliederbereich">
      <p class="sb-gruppe">{tNav('nav.bereich')}</p>
      <ul>
        {MITGLIED_PUNKTE.map((p) => (
          <li>
            <a href={p.href} aria-current={punktAktiv(p, hier) ? 'page' : undefined}>{p.label}</a>
          </li>
        ))}
      </ul>
      {arbeitPunkte.length > 0 && (
        <>
          <p class="sb-gruppe">Vereinsarbeit</p>
          <ul>
            {arbeitPunkte.map((p) => (
              <li>
                <a href={p.href} aria-current={punktAktiv(p, hier) ? 'page' : undefined}>{p.label}</a>
              </li>
            ))}
          </ul>
        </>
      )}
    </nav>
    <div class="sb-info">
      <a href="/mitglieder/abmelden">{tNav('nav.abmelden')}</a>
      {site.oeffentlich !== false && <a href={pfad('/')}>Zur Website</a>}
      <a href={pfad('/impressum')}>Impressum</a>
      <a href={pfad('/datenschutz')}>Datenschutz</a>
      {aufVereinsarbeit ? (
        <p class="sb-sprachhinweis">Vereinsarbeit ist derzeit nur auf Deutsch verfügbar.</p>
      ) : (
        <SprachWahl aktuell={sprache} />
      )}
    </div>
  </>
) : anonym ? (
  <>
    {/* Anonyme Startseite: nur Anmeldung, keine Impressums-/Vereinshinweise.
        Impressum/Datenschutz bleiben ueber ihre URL erreichbar. */}
    <nav class="sb-nav" aria-label="Anmeldung">
      <ul>
        <li>
          <a href="/mitglieder" aria-current={hier.startsWith('/mitglieder') ? 'page' : undefined}>Anmelden</a>
        </li>
      </ul>
    </nav>
  </>
) : (
  <>
    <nav class="sb-nav" aria-label="Hauptnavigation">
      <ul>
        {navigation.map((p) => (
          <li>
            <a href={pfad(p.href)} aria-current={istAktiv(p.href) ? 'page' : undefined}>
              {p.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="sb-info">
      <a href={pfad('/mitglieder')}>Mitgliederbereich</a>
      <a href={pfad('/impressum')}>Impressum</a>
      <a href={pfad('/datenschutz')}>Datenschutz</a>
    </div>
  </>
)}
