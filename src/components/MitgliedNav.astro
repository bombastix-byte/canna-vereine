---
import { darfAusgeben, darfAnbau, darfBerichte, darfVerwalten } from '../lib/rollen';

// Interne Navigation des Mitgliederbereichs. Wird auf allen geschützten
// Seiten eingebunden. Hebt den aktuellen Punkt hervor. Zwei Gruppen:
// Mitglieder-Punkte und (nur bei passender Rolle) "Vereinsarbeit".
// Dazu Prop `rollen` übergeben - sonst fehlen die Personal-Punkte.
interface Props {
  rollen?: string[];
}
const { rollen } = Astro.props;

// Gebuendelte Punkte fuehren mehrere Seiten unter einem Eintrag (die
// Unterseiten wechselt man dort per UnterNav-Reitern); `auch` zaehlt fuer
// die Hervorhebung mit.
interface Punkt {
  label: string;
  href: string;
  auch?: string[];
}

const mitgliedPunkte: Punkt[] = [
  { label: 'Aktuelles', href: '/mitglieder/bereich' },
  { label: 'Angebot der Woche', href: '/mitglieder/wochenangebot' },
  { label: 'Vorbestellung', href: '/mitglieder/vorbestellung' },
  { label: 'Helferplan', href: '/mitglieder/helferplan' },
  { label: 'Abstimmungen', href: '/mitglieder/abstimmungen' },
  { label: 'Wissen', href: '/mitglieder/anleitungen', auch: ['/mitglieder/sortenberichte'] },
  { label: 'Ausweis', href: '/mitglieder/ausweis' },
  { label: 'App', href: '/mitglieder/app' },
  { label: 'Sicherheit', href: '/mitglieder/sicherheit' },
];

const arbeitPunkte: Punkt[] = [];
if (darfAusgeben(rollen)) {
  // Tresen buendelt Abgabe (Bluete/Haschisch/Rosin) und Samen/Stecklinge.
  arbeitPunkte.push({ label: 'Tresen', href: '/mitglieder/ausgabe' });
}
if (darfAnbau(rollen)) {
  arbeitPunkte.push({ label: 'Anbau heute', href: '/mitglieder/anbau' });
  arbeitPunkte.push({ label: 'Warenwirtschaft', href: '/mitglieder/wawi' });
}
if (darfBerichte(rollen)) {
  arbeitPunkte.push({ label: 'Jahresmeldung', href: '/mitglieder/jahresmeldung' });
}
if (darfVerwalten(rollen)) {
  arbeitPunkte.push({
    label: 'Verwaltung',
    href: '/mitglieder/verwaltung',
    auch: ['/mitglieder/antraege', '/mitglieder/beitraege', '/mitglieder/nachricht'],
  });
}

const aktiv = Astro.url.pathname.replace(/\/$/, '');
const istAktiv = (p: Punkt) =>
  [p.href, ...(p.auch ?? [])].some((h) => aktiv === h || aktiv.startsWith(h + '/'));
---

<nav class="mnav" aria-label="Mitgliederbereich">
  <div class="mnav-zeile">
    {
      mitgliedPunkte.map((p) => (
        <a href={p.href} aria-current={istAktiv(p) ? 'page' : undefined}>
          {p.label}
        </a>
      ))
    }
    <a class="mnav-aus" href="/mitglieder/abmelden">Abmelden</a>
  </div>
  {
    arbeitPunkte.length > 0 && (
      <div class="mnav-zeile mnav-arbeit">
        <span class="mnav-label">Vereinsarbeit</span>
        {arbeitPunkte.map((p) => (
          <a href={p.href} aria-current={istAktiv(p) ? 'page' : undefined}>
            {p.label}
          </a>
        ))}
      </div>
    )
  }
</nav>

<style>
  .mnav {
    margin: 0 0 1.6rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--line);
    font-size: 0.95rem;
    max-width: var(--mass);
  }
  .mnav-zeile {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.9rem;
    align-items: center;
  }
  .mnav-arbeit {
    margin-top: 0.55rem;
    padding-top: 0.55rem;
    border-top: 1px dashed var(--line);
  }
  .mnav-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .mnav a {
    text-decoration: none;
    color: var(--ink-soft);
    padding: 0.15rem 0;
    border-bottom: 2px solid transparent;
  }
  .mnav a:hover {
    color: var(--ink);
  }
  .mnav a[aria-current='page'] {
    color: var(--ink);
    border-bottom-color: currentColor;
    font-weight: 600;
  }
  .mnav-aus {
    margin-left: auto;
  }

  /* Handy: statt vieler umgebrochener Zeilen zwei seitlich wischbare
     Zeilen - die Navigation kostet so ~100px statt ~330px Bildschirmhoehe.
     Groessere Tippflaechen (~44px) fuer den Daumen. */
  @media (max-width: 700px) {
    .mnav-zeile {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .mnav-zeile::-webkit-scrollbar {
      display: none;
    }
    .mnav a {
      white-space: nowrap;
      padding: 0.6rem 0.1rem;
    }
    .mnav-label {
      white-space: nowrap;
    }
    .mnav-aus {
      padding-left: 0.9rem;
    }
  }
</style>

<script is:inline>
  // Handy: den aktiven Nav-Punkt in der wischbaren Zeile in Sicht ruecken
  // (nur horizontal, damit die Seite nicht springt).
  document.querySelectorAll('.mnav a[aria-current="page"]').forEach((a) => {
    const zeile = a.closest('.mnav-zeile');
    if (!zeile || zeile.scrollWidth <= zeile.clientWidth) return;
    zeile.scrollLeft = Math.max(0, a.offsetLeft - (zeile.clientWidth - a.offsetWidth) / 2);
  });
</script>
