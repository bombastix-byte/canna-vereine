---
import Basis from '../../layouts/Basis.astro';
import MitgliedNav from '../../components/MitgliedNav.astro';
import { mitgliedAusToken, AUTH_COOKIE, dateiUrl } from '../../lib/pb';
import { darfAnbau } from '../../lib/rollen';
import { STATUS_LABEL, moeglicheAktionen, schwundProzent, VERNICHTUNG_GRUENDE } from '../../lib/wawi';
import { VERARBEITUNG_TYPEN, PRODUKT_TYPEN, PRODUKT_LABEL, produktTyp, produktLabel, ausbeuteProzent } from '../../lib/verarbeitung';
import { berlinTag } from '../../lib/ausgabe';
import { type PlanSchritt, zyklustag, aktuellePhase } from '../../lib/anbauplan';

// Warenwirtschaft: Chargen vom Anbau bis zur Freigabe + Vernichtung.
// Nur Anbauverantwortliche/Vorstand.
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
const { pb, mitglied } = ergebnis;
if (!darfAnbau(mitglied.rollen)) return Astro.redirect('/mitglieder/bereich?fehler=keinzugriff', 303);

interface Sorte { id: string; name: string; thc_prozent?: number; cbd_prozent?: number }
interface Charge {
  id: string;
  collectionId: string;
  charge_nr?: string;
  sorte_name?: string;
  status?: string;
  herkunft?: string;
  pflanzenzahl?: number;
  anbau_start?: string;
  ernte_datum?: string;
  frischgewicht_g?: number;
  trockengewicht_g?: number;
  verfuegbar_g?: number;
  thc_prozent?: number;
  cbd_prozent?: number;
  standort?: string;
  coa?: string;
  testergebnis_url?: string;
  plan?: string;
  produkt_typ?: string;
}
interface Verarbeitung {
  id: string;
  quelle_nr?: string;
  sorte_name?: string;
  produkt_typ?: string;
  einsatz_g?: number;
  ertrag_g?: number;
  produkt_nr?: string;
  datum?: string;
  notiz?: string;
}
interface Vernichtung {
  id: string;
  charge_nr?: string;
  sorte_name?: string;
  menge_gramm?: number;
  anzahl_pflanzen?: number;
  pflanzen_nrn?: string;
  grund?: string;
  datum?: string;
  zeuge?: string;
}
interface Pflanze {
  id: string;
  charge_ref: string;
  nummer: string;
  status?: string;
}

async function ladeListe<T>(collection: string, opts: Record<string, unknown> = {}): Promise<T[]> {
  try {
    return (await pb.collection(collection).getFullList(opts)) as T[];
  } catch {
    return [];
  }
}

interface Transport {
  id: string;
  charge_nr?: string;
  sorte_name?: string;
  menge_gramm: number;
  von?: string;
  nach?: string;
  datum?: string;
  person_name?: string;
  belegnr?: string;
}

const sorten = await ladeListe<Sorte>('sorten', { sort: 'name' });
const alleChargen = await ladeListe<Charge>('chargen', { sort: 'sorte_name,charge_nr' });
const vernichtungen = await ladeListe<Vernichtung>('vernichtungen', { sort: '-created' });
const verarbeitungen = await ladeListe<Verarbeitung>('verarbeitungen', { sort: '-created' });
// Nur freigegebene Blueten-Chargen mit Restbestand koennen verarbeitet werden.
const verarbeitbar = alleChargen.filter(
  (c) => c.status === 'freigegeben' && produktTyp(c.produkt_typ) === 'bluete' && (c.verfuegbar_g ?? 0) > 0,
);
const transporte = await ladeListe<Transport>('transporte', { sort: '-created' });
const allePflanzen = await ladeListe<Pflanze>('pflanzen', { sort: 'nummer' });
const plaene = await ladeListe<{ id: string; name: string }>('anbau_plaene', { sort: 'name' });
const planSchritte = await ladeListe<PlanSchritt>('plan_schritte', { sort: 'tag_von' });
const heuteTag = berlinTag();
const zyklusInfo = (c: Charge) => {
  const tag = zyklustag(c.anbau_start, heuteTag);
  if (!tag) return null;
  const phase = c.plan ? aktuellePhase(planSchritte.filter((s) => s.plan === c.plan), tag) : null;
  return { tag, phase: phase?.titel ?? null };
};
const pflanzenVon = (chargeId: string) => allePflanzen.filter((p) => p.charge_ref === chargeId);
const PFLANZE_STATUS: Record<string, string> = { wachsend: '🌱', geerntet: '✂️', vernichtet: '✕' };

// Arbeitslogische Reihenfolge statt alphabetischem Status: erst was im Anbau
// ist, dann Trocknung, dann abgebbar. Erledigtes (aufgebraucht/gesperrt)
// wandert ins zusammengeklappte Archiv.
const statusReihe: Record<string, number> = { anbau: 0, geerntet: 1, freigegeben: 2 };
const laufend = alleChargen
  .filter((c) => c.status && c.status in statusReihe)
  .sort((a, b) => (statusReihe[a.status!] ?? 9) - (statusReihe[b.status!] ?? 9));
const archiv = alleChargen.filter((c) => !c.status || !(c.status in statusReihe));

// Zusammenklappbare Status-Gruppen statt einer endlosen Kartenliste (bei
// vielen Chargen sonst zehntausende Pixel Scrollweg, v. a. am Handy).
// Freigegebene starten zugeklappt - ihr Bestand steht oben in der Tabelle.
const gruppen = [
  { key: 'anbau', titel: 'Im Anbau', offen: true },
  { key: 'geerntet', titel: 'Geerntet — in Trocknung', offen: true },
  { key: 'freigegeben', titel: 'Freigegeben — am Tresen abgebbar', offen: false },
]
  .map((g) => ({ ...g, chargen: laufend.filter((c) => c.status === g.key) }))
  .filter((g) => g.chargen.length > 0);

// Bestand je Sorte UND Produkt aus freigegebenen Chargen (Haschisch/Rosin
// erscheinen als eigene Zeile, nicht mit der Bluete vermischt).
const bestand = new Map<string, number>();
for (const c of alleChargen) {
  if (c.status === 'freigegeben') {
    const typ = produktTyp(c.produkt_typ);
    const name = (c.sorte_name ?? '?') + (typ === 'bluete' ? '' : ` · ${PRODUKT_LABEL[typ]}`);
    bestand.set(name, (bestand.get(name) ?? 0) + (c.verfuegbar_g ?? 0));
  }
}
const bestandGesamt = [...bestand.values()].reduce((a, b) => a + b, 0);

const heute = berlinTag();
const fehler = Astro.url.searchParams.get('fehler');
const ok = Astro.url.searchParams.get('ok');
const fehlertext: Record<string, string> = {
  fehlend: 'Bitte die Pflichtfelder ausfüllen.',
  menge: 'Bitte eine gültige Menge/Gewicht angeben.',
  status: 'Diese Aktion ist im aktuellen Status nicht möglich.',
  sorte_existiert: 'Diese Sorte gibt es bereits.',
  fehlgeschlagen: 'Aktion fehlgeschlagen. Bitte erneut versuchen.',
  // Verarbeitung liefert die genaue Meldung im msg-Parameter mit.
  verarbeitung: Astro.url.searchParams.get('msg') || 'Verarbeitung nicht möglich.',
};
const oktext: Record<string, string> = {
  angelegt: 'Charge angelegt.',
  ernte: 'Ernte erfasst.',
  freigabe: 'Charge freigegeben – jetzt am Tresen abgebbar.',
  sperren: 'Charge gesperrt.',
  vernichtet: 'Vernichtung dokumentiert.',
  labor: 'Laborunterlagen gespeichert.',
  plan: 'Anbau-Plan zugewiesen — fällige Schritte stehen unter „Anbau heute".',
  sorte: 'Sorte angelegt — steht jetzt bei „Neue Charge anlegen" zur Auswahl.',
  verarbeitet: 'Verarbeitung gebucht — das Produkt ist als neue Charge freigegeben und am Tresen abgebbar.',
  bestand: 'Bestand angelegt — die Charge ist freigegeben und am Tresen abgebbar.',
};
const fmeldung = fehler ? fehlertext[fehler] ?? fehlertext.fehlgeschlagen : null;
const omeldung = ok ? oktext[ok] ?? 'Erledigt.' : null;

const datum = (iso?: string) =>
  iso ? new Date(iso).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '—';
const g = (n?: number | null) => (n == null ? '—' : `${n} g`);

// Der Klapper je Charge sagt direkt, was als Naechstes ansteht.
const naechsterSchritt: Record<string, string> = {
  anbau: '→ Nächster Schritt: Ernte erfassen',
  geerntet: '→ Nächster Schritt: Freigeben (nach der Trocknung)',
  freigegeben: 'Weitere Aktionen (vernichten, sperren)',
};

// Status -> einheitliche Abzeichen-Variante (gemeinsame Bausteine).
const statusVariante: Record<string, string> = {
  freigegeben: 'abzeichen--ok',
  anbau: 'abzeichen--warn',
  geerntet: '',
  gesperrt: 'abzeichen--gefahr',
  aufgebraucht: 'abzeichen--gefahr',
};
---

<Basis titel="Warenwirtschaft" beschreibung="Chargen vom Anbau bis zur Ausgabe, KCanG-dokumentiert.">
  <MitgliedNav rollen={mitglied.rollen} />
  <p class="eyebrow">Vereinsarbeit</p>
  <h1 style="margin-bottom:0.4rem;">Warenwirtschaft</h1>
  <p class="einleitung">
    Jedes Anbaulos als Charge vom Anbau über Ernte und Trocknung bis zur Freigabe.
    Freigegebene Chargen stehen am Tresen zur Abgabe; jede Abgabe bleibt bis zum
    Anbaulos rückverfolgbar. Vernichtungen werden dokumentiert.
  </p>

  {fmeldung && <p class="hinweis hinweis--fehler" role="alert">{fmeldung}</p>}
  {omeldung && <p class="hinweis" role="status">{omeldung}</p>}

  <h2>Bestand (freigegeben)</h2>
  {bestand.size === 0 ? (
    <p style="color:var(--ink-soft);">Kein freigegebener Bestand.</p>
  ) : (
    <table class="tabelle">
      <thead><tr><th>Sorte</th><th style="text-align:right;">Verfügbar</th></tr></thead>
      <tbody>
        {[...bestand.entries()].map(([name, g]) => (
          <tr><td>{name}</td><td style="text-align:right;">{g} g</td></tr>
        ))}
        <tr><td><strong>Gesamt</strong></td><td style="text-align:right;"><strong>{bestandGesamt} g</strong></td></tr>
      </tbody>
    </table>
  )}

  <h2>Chargen</h2>
  <p class="ablauf">Ablauf je Charge: <strong>Anbau</strong> → <strong>Ernte</strong> (Frischgewicht wiegen) → <strong>Freigabe</strong> (Trockengewicht + THC eintragen) → am Tresen abgebbar.</p>

  <details class="klappe">
    <summary>＋ Neue Charge anlegen</summary>
    <form class="kasten" method="post" action="/mitglieder/wawi/charge-neu">
    <div class="feld">
      <label for="sorte">Sorte</label>
      <select id="sorte" name="sorte" required>
        <option value="">— Sorte wählen —</option>
        {sorten.map((s) => <option value={s.id}>{s.name}</option>)}
      </select>
    </div>
    <div class="feld">
      <label for="herkunft">Herkunft (Samen/Stecklinge, Quelle)</label>
      <input id="herkunft" name="herkunft" type="text" placeholder="z. B. Stecklinge, Mutterpflanze intern" />
    </div>
    <div class="feld-reihe">
      <div class="feld">
        <label for="pflanzenzahl">Pflanzenzahl</label>
        <input id="pflanzenzahl" name="pflanzenzahl" type="number" min="0" step="1" />
      </div>
      <div class="feld">
        <label for="anbau_start">Anbaubeginn</label>
        <input id="anbau_start" name="anbau_start" type="date" value={heute} />
      </div>
      <div class="feld">
        <label for="standort">Standort</label>
        <input id="standort" name="standort" type="text" placeholder="z. B. Anbauraum 1" />
      </div>
    </div>
    <div class="feld">
      <label for="plan-neu">Anbau-Plan (Pflege- und Düngeschema)</label>
      <select id="plan-neu" name="plan">
        <option value="">— später zuweisen —</option>
        {plaene.map((p) => <option value={p.id}>{p.name}</option>)}
      </select>
    </div>
      <button class="knopf" type="submit">Charge anlegen</button>
    </form>
  </details>

  <details class="klappe">
    <summary>＋ Bestand nachtragen (bereits getrocknete Ware)</summary>
    <form class="kasten" method="post" action="/mitglieder/wawi/bestand-neu">
      <p style="color:var(--ink-soft);font-size:0.92rem;margin:0 0 0.8rem;">
        Für vorhandene, bereits getrocknete Ware ohne eigenen Anbauverlauf
        (z. B. bestehender Bestand). Die Charge wird <strong>sofort freigegeben</strong>
        und steht am Tresen zur Abgabe.
      </p>
      <div class="feld-reihe">
        <div class="feld">
          <label for="b-sorte">Sorte</label>
          <select id="b-sorte" name="sorte" required>
            <option value="">— Sorte wählen —</option>
            {sorten.map((s) => <option value={s.id}>{s.name}</option>)}
          </select>
        </div>
        <div class="feld">
          <label for="b-produkt">Produkt</label>
          <select id="b-produkt" name="produkt_typ">
            {PRODUKT_TYPEN.map((t) => <option value={t}>{PRODUKT_LABEL[t]}</option>)}
          </select>
        </div>
      </div>
      <div class="feld-reihe">
        <div class="feld">
          <label for="b-menge">Trockenmenge (g)</label>
          <input id="b-menge" name="trockengewicht_g" type="number" min="0.1" step="0.1" required placeholder="verfügbar" />
        </div>
        <div class="feld">
          <label for="b-thc">THC %</label>
          <input id="b-thc" name="thc_prozent" type="number" min="0" step="0.1" required />
        </div>
        <div class="feld">
          <label for="b-cbd">CBD %</label>
          <input id="b-cbd" name="cbd_prozent" type="number" min="0" step="0.1" />
        </div>
      </div>
      <div class="feld-reihe">
        <div class="feld">
          <label for="b-ernte">Erntedatum (für Jahresmeldung)</label>
          <input id="b-ernte" name="ernte_datum" type="date" value={heute} />
        </div>
        <div class="feld">
          <label for="b-herkunft">Herkunft / Notiz</label>
          <input id="b-herkunft" name="herkunft" type="text" placeholder="z. B. Altbestand, Übernahme" />
        </div>
      </div>
      <p style="color:var(--ink-soft);font-size:0.88rem;margin:0 0 0.8rem;">
        Ohne THC-Wert bleibt die Abgabe an unter 21-Jährige gesperrt. Sorte fehlt?
        Unten unter „Neue Sorte anlegen" anlegen.
      </p>
      <button class="knopf" type="submit">Bestand freigeben</button>
    </form>
  </details>

  <details class="klappe">
    <summary>＋ Neue Sorte anlegen</summary>
    <form class="kasten" method="post" action="/mitglieder/wawi/sorte-neu">
      <div class="feld">
        <label for="sorte-name">Sortenname</label>
        <input id="sorte-name" name="name" type="text" required placeholder="z. B. Wedding Cake" />
      </div>
      <div class="feld-reihe">
        <div class="feld">
          <label for="sorte-typ">Typ</label>
          <select id="sorte-typ" name="typ">
            <option>Hybrid</option>
            <option>Indica</option>
            <option>Sativa</option>
          </select>
        </div>
        <div class="feld">
          <label for="sorte-thc">THC % (Richtwert)</label>
          <input id="sorte-thc" name="thc_prozent" type="number" min="0" step="0.1" />
        </div>
        <div class="feld">
          <label for="sorte-cbd">CBD % (Richtwert)</label>
          <input id="sorte-cbd" name="cbd_prozent" type="number" min="0" step="0.1" />
        </div>
      </div>
      <div class="feld">
        <label for="sorte-notiz">Notiz (optional)</label>
        <input id="sorte-notiz" name="notiz" type="text" placeholder="z. B. Herkunft der Genetik" />
      </div>
      <p style="color:var(--ink-soft);font-size:0.88rem;margin:0 0 0.8rem;">
        Die maßgeblichen THC/CBD-Werte je Ernte trägst du bei der Freigabe der
        Charge ein — hier sind es nur Richtwerte der Sorte.
      </p>
      <button class="knopf" type="submit">Sorte anlegen</button>
    </form>
  </details>

  {laufend.length === 0 && (
    <p style="color:var(--ink-soft);">Keine laufende Charge. Oben über „Neue Charge anlegen“ starten.</p>
  )}
  {gruppen.map((gr) => (
    <details class="klappe charge-gruppe" open={gr.offen}>
      <summary>{gr.titel} ({gr.chargen.length})</summary>
      {gr.chargen.map((c) => (
      <div class="charge" id={`c-${c.id}`}>
        <div class="charge-kopf">
          <span><strong>{c.charge_nr}</strong> · {c.sorte_name}</span>
          <span class="charge-badges">
            {produktTyp(c.produkt_typ) !== 'bluete' && (
              <span class="abzeichen abzeichen--akzent">{produktLabel(c.produkt_typ)}</span>
            )}
            {c.status === 'anbau' && zyklusInfo(c) && (
              <span class="abzeichen abzeichen--akzent">Tag {zyklusInfo(c)!.tag}{zyklusInfo(c)!.phase ? ` · ${zyklusInfo(c)!.phase}` : ''}</span>
            )}
            <span class:list={['abzeichen', statusVariante[c.status ?? ''] || null]}>{STATUS_LABEL[c.status as keyof typeof STATUS_LABEL] ?? c.status}</span>
          </span>
        </div>
        <div class="charge-daten">
          <span>Herkunft: {c.herkunft || '—'}</span>
          <span>Pflanzen: {c.pflanzenzahl ?? '—'}</span>
          <span>Anbau seit: {datum(c.anbau_start)}</span>
          <span>Ernte: {datum(c.ernte_datum)}</span>
          <span>Frisch: {g(c.frischgewicht_g)}</span>
          <span>Trocken: {g(c.trockengewicht_g)}
            {schwundProzent(c.frischgewicht_g, c.trockengewicht_g) != null && ` (Schwund ${schwundProzent(c.frischgewicht_g, c.trockengewicht_g)} %)`}
          </span>
          <span>Verfügbar: <strong>{g(c.verfuegbar_g)}</strong></span>
          <span>THC/CBD: {c.thc_prozent ?? '—'} % / {c.cbd_prozent ?? '—'} %</span>
          <span>
            Labor:
            {c.coa ? <a href={dateiUrl(c as { collectionId: string; id: string }, c.coa)} target="_blank" rel="noopener"> Zertifikat</a> : ' —'}
            {c.testergebnis_url && <> · <a href={c.testergebnis_url} target="_blank" rel="noopener">Testergebnis</a></>}
          </span>
        </div>

        {c.status === 'anbau' && (
          <form class="plan-zeile" method="post" action="/mitglieder/wawi/plan">
            <input type="hidden" name="charge" value={c.id} />
            <label>Anbau-Plan:
              <select class="eingabe" name="plan">
                <option value="">— kein Plan —</option>
                {plaene.map((p) => (
                  <option value={p.id} selected={c.plan === p.id}>{p.name}</option>
                ))}
              </select>
            </label>
            <button class="knopf-sek" type="submit">Zuweisen</button>
            {c.plan && <a href="/mitglieder/anbau">→ Anbau heute</a>}
          </form>
        )}

        {c.status === 'freigegeben' && (
          <p class="gebinde-link">
            <a href={`/mitglieder/wawi/gebinde/${c.id}`}>→ Gebinde-Etiketten drucken (QR für den Tresen-Scan)</a>
          </p>
        )}

        {pflanzenVon(c.id).length > 0 && (
          <details class="pflanzen-det">
            <summary>
              Pflanzen: {pflanzenVon(c.id).filter((p) => p.status === 'wachsend').length} wachsend
              {' / '}{pflanzenVon(c.id).length} gesamt
            </summary>
            <p style="margin:0.5rem 0;"><a href={`/mitglieder/wawi/etiketten/${c.id}`}>→ QR-Etiketten für diese Pflanzen drucken</a></p>
            <ul class="pflanzenliste">
              {pflanzenVon(c.id).map((p) => (
                <li class:list={['pflanze', `pf-${p.status}`]}>
                  <span>{PFLANZE_STATUS[p.status ?? ''] ?? ''} {p.nummer} <em>({p.status})</em></span>
                  {p.status === 'wachsend' && c.status === 'anbau' && (
                    <form method="post" action="/mitglieder/wawi/pflanze-vernichten" class="pflanze-form">
                      <input type="hidden" name="pflanze" value={p.id} />
                      <input class="eingabe" name="grund" type="text" placeholder="Grund" required />
                      <button class="knopf-sek" type="submit">vernichten</button>
                    </form>
                  )}
                </li>
              ))}
            </ul>
          </details>
        )}

        {moeglicheAktionen(c.status).length > 0 && (
          <details class="aktionen-det">
            <summary>{naechsterSchritt[c.status ?? ''] ?? 'Aktionen'}</summary>

            {moeglicheAktionen(c.status).includes('ernte') && (
              <form class="aktion" method="post" action="/mitglieder/wawi/aktion">
                <input type="hidden" name="charge" value={c.id} />
                <input type="hidden" name="aktion" value="ernte" />
                <strong>Ernte erfassen</strong>
                <label>Frischgewicht (g)<input name="frischgewicht_g" type="number" min="0" step="0.1" required /></label>
                <label>Erntedatum<input name="ernte_datum" type="date" value={heute} /></label>
                <button class="knopf" type="submit">Ernte speichern</button>
              </form>
            )}

            {moeglicheAktionen(c.status).includes('freigabe') && (
              <form class="aktion" method="post" action="/mitglieder/wawi/aktion">
                <input type="hidden" name="charge" value={c.id} />
                <input type="hidden" name="aktion" value="freigabe" />
                <strong>Freigeben (nach Trocknung)</strong>
                <label>Trockengewicht (g)<input name="trockengewicht_g" type="number" min="0" step="0.1" required /></label>
                <label>THC %<input name="thc_prozent" type="number" min="0" step="0.1" value={c.thc_prozent} /></label>
                <label>CBD %<input name="cbd_prozent" type="number" min="0" step="0.1" value={c.cbd_prozent} /></label>
                <button class="knopf" type="submit">Freigeben</button>
              </form>
            )}

            {moeglicheAktionen(c.status).includes('vernichten') && (
              <form class="aktion" method="post" action="/mitglieder/wawi/vernichten">
                <input type="hidden" name="charge" value={c.id} />
                <strong>Vernichtung dokumentieren</strong>
                <label>Menge (g)<input name="menge_gramm" type="number" min="0" step="0.1" required /></label>
                <label>Grund
                  <select name="grund">
                    {VERNICHTUNG_GRUENDE.map((gr) => <option value={gr}>{gr}</option>)}
                  </select>
                </label>
                <label>Zeuge (Name)<input name="zeuge" type="text" /></label>
                <button class="knopf" type="submit">Vernichtung buchen</button>
              </form>
            )}

            <form class="aktion" method="post" action="/mitglieder/wawi/transport">
              <input type="hidden" name="charge" value={c.id} />
              <strong>Transport dokumentieren (§ 22 KCanG)</strong>
              <label>Menge (g)<input name="menge_gramm" type="number" min="0.1" step="0.1" required /></label>
              <label>Von<input name="von" type="text" required placeholder="z. B. Anbaustätte, Anschrift" /></label>
              <label>Nach<input name="nach" type="text" required placeholder="z. B. Ausgabestelle, Anschrift" /></label>
              <label>Zweck (optional)<input name="zweck" type="text" placeholder="z. B. Umlagerung zur Ausgabe" /></label>
              <button class="knopf" type="submit">Bescheinigung erstellen</button>
            </form>

            <form class="aktion" method="post" action="/mitglieder/wawi/labor" enctype="multipart/form-data">
              <input type="hidden" name="charge" value={c.id} />
              <strong>Laborunterlagen hinterlegen</strong>
              <label>Zertifikat (PDF/Bild){c.coa && <span style="color:var(--ink-soft);"> — ersetzt das vorhandene</span>}
                <input name="coa" type="file" accept=".pdf,image/*" />
              </label>
              <label>Link zu eigenen Testergebnissen (z. B. Mess-App)
                <input name="testergebnis_url" type="url" value={c.testergebnis_url ?? ''} placeholder="https://…" />
              </label>
              <button class="knopf" type="submit">Speichern</button>
            </form>

            {moeglicheAktionen(c.status).includes('sperren') && (
              <form class="aktion" method="post" action="/mitglieder/wawi/aktion">
                <input type="hidden" name="charge" value={c.id} />
                <input type="hidden" name="aktion" value="sperren" />
                <button class="knopf-sek" type="submit">Charge sperren</button>
              </form>
            )}
          </details>
        )}
      </div>
      ))}
    </details>
  ))}

  {archiv.length > 0 && (
    <details class="klappe">
      <summary>Archiv ({archiv.length}) — aufgebrauchte und gesperrte Chargen</summary>
      <table class="tabelle">
        <thead><tr><th>Charge</th><th>Sorte</th><th>Status</th><th class="r">Trocken</th><th class="r">THC</th></tr></thead>
        <tbody>
          {archiv.map((c) => (
            <tr>
              <td>{c.charge_nr}</td>
              <td>{c.sorte_name}</td>
              <td>{STATUS_LABEL[c.status as keyof typeof STATUS_LABEL] ?? c.status}</td>
              <td class="r">{g(c.trockengewicht_g)}</td>
              <td class="r">{c.thc_prozent ?? '—'} %</td>
            </tr>
          ))}
        </tbody>
      </table>
    </details>
  )}

  <h2>Weiterverarbeitung (Haschisch / Rosin)</h2>
  <p class="ablauf">
    Aus einer freigegebenen Blüten-Charge wird ein Konzentrat: Einsatzmenge und
    Ertrag wiegen, THC/CBD des Produkts eintragen. Das Produkt entsteht als
    <strong>neue, freigegebene Charge</strong> und steht sofort am Tresen zur
    Abgabe — Limits und die U21-THC-Sperre gelten automatisch. Nur
    lösungsmittelfreie Verfahren (Trockensieb, Presse).
  </p>

  <details class="klappe">
    <summary>＋ Verarbeitung buchen</summary>
    {verarbeitbar.length === 0 ? (
      <p style="color:var(--ink-soft);padding:0.6rem 0;">Keine freigegebene Blüten-Charge mit Bestand vorhanden.</p>
    ) : (
      <form class="kasten" method="post" action="/mitglieder/wawi/verarbeiten">
        <div class="feld">
          <label for="v-quelle">Blüten-Charge (Quelle)</label>
          <select id="v-quelle" name="quelle" required>
            <option value="">— Charge wählen —</option>
            {verarbeitbar.map((c) => (
              <option value={c.id}>{c.charge_nr} · {c.sorte_name} (verfügbar {c.verfuegbar_g} g)</option>
            ))}
          </select>
        </div>
        <div class="feld-reihe">
          <div class="feld">
            <label for="v-typ">Produkt</label>
            <select id="v-typ" name="produkt_typ">
              {VERARBEITUNG_TYPEN.map((t) => <option value={t}>{PRODUKT_LABEL[t]}</option>)}
            </select>
          </div>
          <div class="feld">
            <label for="v-einsatz">Einsatz Blüte (g)</label>
            <input id="v-einsatz" name="einsatz_g" type="number" min="0.1" step="0.1" required />
          </div>
          <div class="feld">
            <label for="v-ertrag">Ertrag Produkt (g)</label>
            <input id="v-ertrag" name="ertrag_g" type="number" min="0.1" step="0.1" required />
          </div>
        </div>
        <div class="feld-reihe">
          <div class="feld">
            <label for="v-thc">THC % (Produkt)</label>
            <input id="v-thc" name="thc_prozent" type="number" min="0" step="0.1" required />
          </div>
          <div class="feld">
            <label for="v-cbd">CBD % (Produkt)</label>
            <input id="v-cbd" name="cbd_prozent" type="number" min="0" step="0.1" />
          </div>
          <div class="feld">
            <label for="v-notiz">Verfahren/Notiz</label>
            <input id="v-notiz" name="notiz" type="text" placeholder="z. B. Trockensieb 160 µm, Rosin-Presse 90 °C" />
          </div>
        </div>
        <p style="color:var(--ink-soft);font-size:0.88rem;margin:0 0 0.8rem;">
          Ohne THC-Wert ist die Abgabe an unter 21-Jährige gesperrt; über 10 %
          THC (bei Konzentraten der Regelfall) ebenfalls — das prüft der Tresen
          automatisch.
        </p>
        <button class="knopf" type="submit">Verarbeitung buchen</button>
      </form>
    )}
  </details>

  {verarbeitungen.length > 0 && (
    <table class="tabelle">
      <thead><tr><th>Datum</th><th>Quelle</th><th>Produkt</th><th class="r">Einsatz</th><th class="r">Ertrag</th><th class="r">Ausbeute</th><th>Neue Charge</th></tr></thead>
      <tbody>
        {verarbeitungen.map((v) => (
          <tr>
            <td>{v.datum}</td>
            <td>{v.quelle_nr} · {v.sorte_name}</td>
            <td>{produktLabel(v.produkt_typ)}</td>
            <td class="r">{v.einsatz_g} g</td>
            <td class="r">{v.ertrag_g} g</td>
            <td class="r">{ausbeuteProzent(v.einsatz_g ?? 0, v.ertrag_g ?? 0) ?? '—'} %</td>
            <td>{v.produkt_nr}</td>
          </tr>
        ))}
      </tbody>
    </table>
  )}

  <h2>Transporte</h2>
  {transporte.length === 0 ? (
    <p style="color:var(--ink-soft);">Keine Transporte dokumentiert.</p>
  ) : (
    <table class="tabelle">
      <thead><tr><th>Datum</th><th>Charge</th><th>Sorte</th><th class="r">Menge</th><th>Strecke</th><th>Bescheinigung</th></tr></thead>
      <tbody>
        {transporte.map((t) => (
          <tr>
            <td>{t.datum}</td><td>{t.charge_nr}</td><td>{t.sorte_name}</td>
            <td class="r">{t.menge_gramm} g</td>
            <td>{t.von} → {t.nach}</td>
            <td><a href={`/mitglieder/wawi/transport/${t.id}`}>{t.belegnr || 'öffnen'}</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  )}

  <h2>Vernichtungen</h2>
  {vernichtungen.length === 0 ? (
    <p style="color:var(--ink-soft);">Keine Vernichtungen dokumentiert.</p>
  ) : (
    <table class="tabelle">
      <thead><tr><th>Datum</th><th>Charge</th><th>Sorte</th><th style="text-align:right;">Menge</th><th>Grund</th><th>Zeuge</th></tr></thead>
      <tbody>
        {vernichtungen.map((v) => (
          <tr>
            <td>{v.datum}</td><td>{v.charge_nr}</td><td>{v.sorte_name}</td>
            <td style="text-align:right;">{v.menge_gramm ? `${v.menge_gramm} g` : `${v.anzahl_pflanzen ?? '?'} Pflanze(n)${v.pflanzen_nrn ? ` (${v.pflanzen_nrn})` : ''}`}</td>
            <td>{v.grund}</td><td>{v.zeuge || '—'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</Basis>

<style>
  .aktion input,
  .aktion select {
    width: 100%;
    padding: 0.5rem 0.6rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-rein);
    color: var(--ink);
    font: inherit;
  }
  .feld-reihe { display: flex; gap: 0.9rem; flex-wrap: wrap; }
  .feld-reihe .feld { flex: 1 1 8rem; }
  .ablauf { max-width: var(--mass); color: var(--ink-soft); font-size: 0.95rem; margin: 0 0 1rem; }
  .charge {
    max-width: var(--mass);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1rem 1.1rem;
    margin: 0 0 0.9rem;
    background: var(--bg-rein);
  }
  .charge-kopf { display: flex; justify-content: space-between; gap: 1rem; align-items: center; margin-bottom: 0.6rem; flex-wrap: wrap; }
  .charge-badges { display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap; }
  .plan-zeile { display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; margin-top: 0.7rem; font-size: 0.92rem; }
  .plan-zeile label { display: flex; gap: 0.5rem; align-items: center; color: var(--ink-soft); flex: 1 1 14rem; min-width: 0; }
  .plan-zeile .eingabe { width: auto; max-width: 18rem; min-width: 0; flex: 1 1 8rem; padding: 0.4rem 0.5rem; font-size: 0.9rem; }
  .plan-zeile .knopf-sek { padding: 0.4rem 0.8rem; font-size: 0.88rem; }
  .charge-daten { display: grid; grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr)); gap: 0.3rem 1rem; font-size: 0.92rem; color: var(--ink-soft); }
  .charge-daten strong { color: var(--ink); }
  .aktionen-det { margin-top: 0.8rem; border-top: 1px solid var(--line); padding-top: 0.6rem; }
  .gebinde-link { margin: 0.7rem 0 0; font-size: 0.92rem; }
  .pflanzen-det { margin-top: 0.7rem; font-size: 0.92rem; }
  .pflanzen-det summary { cursor: pointer; color: var(--ink-soft); font-weight: 600; padding: 0.45rem 0; }
  .pflanzenliste { list-style: none; padding: 0.5rem 0 0; margin: 0; display: flex; flex-direction: column; gap: 0.35rem; }
  .pflanze { display: flex; justify-content: space-between; align-items: center; gap: 0.8rem; flex-wrap: wrap; border-bottom: 1px dashed var(--line); padding-bottom: 0.35rem; }
  .pflanze em { color: var(--ink-soft); font-style: normal; font-size: 0.85rem; }
  .pf-vernichtet span { color: var(--ink-soft); text-decoration: line-through; }
  .pflanze-form { display: flex; gap: 0.4rem; align-items: center; }
  .pflanze-form .eingabe { width: 11rem; padding: 0.35rem 0.5rem; font-size: 0.88rem; }
  .pflanze-form .knopf-sek { padding: 0.35rem 0.7rem; font-size: 0.85rem; }
  .aktionen-det summary { cursor: pointer; font-weight: 600; font-size: 0.95rem; padding: 0.45rem 0; }
  .aktion { display: flex; flex-direction: column; gap: 0.4rem; max-width: 22rem; margin: 0.8rem 0; padding: 0.8rem; border: 1px solid var(--line); border-radius: var(--radius); }
  .aktion label { display: flex; flex-direction: column; gap: 0.2rem; font-size: 0.9rem; color: var(--ink-soft); }
</style>
