---
import Basis from '../../layouts/Basis.astro';
import MitgliedNav from '../../components/MitgliedNav.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../lib/pb';
import { darfAusgeben } from '../../lib/rollen';
import {
  berlinTag,
  berlinMonat,
  istU21,
  alterAmTag,
  summeGramm,
  LIMIT_TAG_G,
  LIMIT_MONAT_G,
  LIMIT_MONAT_U21_G,
  U21_MAX_THC,
  BEITRAG_PRO_GRAMM,
} from '../../lib/ausgabe';

// Tresen: Abgabe an Mitglieder buchen. Nur Personal (Vorstand/Ausgabe).
// Gefuehrter Ablauf in zwei Schritten: 1. Mitglied waehlen -> Restmengen sehen,
// 2. Charge + Menge -> buchen. U21-gesperrte Chargen sind direkt deaktiviert.
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
const { pb, mitglied: personal } = ergebnis;
if (!darfAusgeben(personal.rollen)) {
  return Astro.redirect('/mitglieder/bereich?fehler=keinzugriff', 303);
}

interface UserRow {
  id: string;
  name?: string;
  email: string;
  mitgliedsnummer?: string;
  geburtsdatum?: string;
}
interface ChargeRow {
  id: string;
  charge_nr?: string;
  sorte_name?: string;
  status?: string;
  thc_prozent?: number;
  cbd_prozent?: number;
  verfuegbar_g?: number;
}
interface AusgabeRow {
  id: string;
  mitglied: string;
  mitgliedsnummer?: string;
  sorte_name: string;
  menge_gramm: number;
  thc_prozent?: number;
  beitrag_euro?: number;
  tag: string;
  belegnr?: string;
}

const tag = berlinTag();
const monat = berlinMonat(tag);

async function ladeListe<T>(collection: string, opts: Record<string, unknown>): Promise<T[]> {
  try {
    return (await pb.collection(collection).getFullList(opts)) as T[];
  } catch {
    return [];
  }
}

const mitglieder = await ladeListe<UserRow>('users', { sort: 'mitgliedsnummer,name' });
// Nur freigegebene Chargen mit Restbestand koennen abgegeben werden.
const chargen = (
  await ladeListe<ChargeRow>('chargen', { filter: 'status="freigegeben"', sort: 'sorte_name,charge_nr' })
).filter((c) => (c.verfuegbar_g ?? 0) > 0);
const heuteAlle = await ladeListe<AusgabeRow>('ausgaben', { filter: `tag="${tag}"`, sort: '-created' });

// Fehlermeldung aus dem Buchungs-Endpoint.
const fehler = Astro.url.searchParams.get('fehler');
const msg = Astro.url.searchParams.get('msg');

// Status eines ausgewaehlten Mitglieds (fuer die Restmengen-Anzeige).
const gewaehltId = Astro.url.searchParams.get('mitglied') ?? '';
const gewaehlt = mitglieder.find((m) => m.id === gewaehltId) ?? null;
let status: null | {
  u21: boolean;
  alter: number | null;
  heute: number;
  monatSumme: number;
  monatslimit: number;
  restTag: number;
  restMonat: number;
  restJetzt: number;
} = null;
if (gewaehlt) {
  const saetze = await ladeListe<AusgabeRow>('ausgaben', {
    filter: `mitglied="${gewaehlt.id}" && monat="${monat}"`,
  });
  const monatSumme = summeGramm(saetze);
  const heute = summeGramm(saetze.filter((r) => r.tag === tag));
  const u21 = istU21(gewaehlt.geburtsdatum, tag);
  const monatslimit = u21 ? LIMIT_MONAT_U21_G : LIMIT_MONAT_G;
  const restTag = Math.max(0, LIMIT_TAG_G - heute);
  const restMonat = Math.max(0, monatslimit - monatSumme);
  status = {
    u21,
    alter: alterAmTag(gewaehlt.geburtsdatum, tag),
    heute,
    monatSumme,
    monatslimit,
    restTag,
    restMonat,
    restJetzt: Math.min(restTag, restMonat),
  };
}

// Fuer U21 gesperrte Chargen direkt im Dropdown deaktivieren (>10 % THC oder
// THC unbekannt) - die Fehlermeldung kommt so gar nicht erst zustande.
const chargeGesperrt = (c: ChargeRow) =>
  !!status?.u21 && !(typeof c.thc_prozent === 'number' && c.thc_prozent > 0 && c.thc_prozent <= U21_MAX_THC);

const mnr = (m: UserRow) => (m.mitgliedsnummer ? `${m.mitgliedsnummer} — ` : '') + (m.name || m.email);
const eur = (n?: number) => (n ?? 0).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const heuteSumme = summeGramm(heuteAlle);
const schnellMengen = [1, 2, 3, 5, 10];
---

<Basis titel="Ausgabe (Tresen)" beschreibung="Abgabe an Mitglieder buchen, KCanG-konform.">
  <MitgliedNav rollen={personal.rollen} />
  <p class="eyebrow">Vereinsarbeit</p>
  <h1 style="margin-bottom:0.4rem;">Ausgabe am Tresen</h1>
  <p class="einleitung">
    Erst das Mitglied wählen, dann Sorte und Menge. Alle gesetzlichen Grenzen
    prüft das System automatisch. Beitrag: {eur(BEITRAG_PRO_GRAMM)} € je Gramm,
    kassiert wird an der Kasse.
  </p>

  {fehler && msg && (
    <p class="hinweis" role="alert" style="border-color:#d99;background:#fbecec;"><strong>Nicht gebucht:</strong> {msg}</p>
  )}

  <section class="schritt" aria-label="Schritt 1">
    <h2 class="schritt-titel"><span class="snr">1</span> Mitglied wählen</h2>
    <form class="kasten" method="get" action="/mitglieder/ausgabe">
      <div class="feld">
        <label for="mitglied-sel">Mitglied (Nummer oder Name)</label>
        <select id="mitglied-sel" name="mitglied" onchange="this.form.submit()">
          <option value="">— bitte wählen —</option>
          {mitglieder.map((m) => (
            <option value={m.id} selected={m.id === gewaehltId}>{mnr(m)}</option>
          ))}
        </select>
        <noscript><button class="knopf" type="submit">Mitglied laden</button></noscript>
      </div>

      {gewaehlt && status && (
        <div class:list={['statuskarte', { warn: status.u21 }]}>
          <div class="sk-kopf">
            <strong>{mnr(gewaehlt)}</strong>
            {status.alter != null ? (
              <span class="sk-alter">{status.alter} Jahre{status.u21 ? ' · unter 21' : ''}</span>
            ) : (
              <span class="sk-alter sk-fehlt">Geburtsdatum fehlt → wird streng als U21 behandelt</span>
            )}
          </div>
          <div class="sk-gross">
            <div class="sk-box">
              <span class="sk-box-label">Darf jetzt noch</span>
              <span class="sk-box-wert">{status.restJetzt} g</span>
            </div>
            <div class="sk-box sk-box-soft">
              <span class="sk-box-label">Heute schon</span>
              <span class="sk-box-wert">{status.heute} / {LIMIT_TAG_G} g</span>
            </div>
            <div class="sk-box sk-box-soft">
              <span class="sk-box-label">Diesen Monat</span>
              <span class="sk-box-wert">{status.monatSumme} / {status.monatslimit} g</span>
            </div>
          </div>
          {status.u21 && (
            <p class="sk-warn">Unter 21: nur Sorten bis {U21_MAX_THC} % THC — stärkere sind unten ausgegraut.</p>
          )}
          {status.restJetzt === 0 && (
            <p class="sk-warn sk-stop">Limit erreicht — heute keine Abgabe mehr an dieses Mitglied möglich.</p>
          )}
        </div>
      )}
    </form>
  </section>

  {gewaehlt && status && status.restJetzt > 0 && (
    <section class="schritt" aria-label="Schritt 2">
      <h2 class="schritt-titel"><span class="snr">2</span> Sorten und Mengen</h2>
      {chargen.length === 0 ? (
        <p class="hinweis">Keine freigegebene Charge mit Bestand. Zuerst in der
        <a href="/mitglieder/wawi"> Warenwirtschaft</a> eine Charge freigeben.</p>
      ) : (
        <form class="kasten" method="post" action="/mitglieder/ausgabe/buchen">
          <input type="hidden" name="mitglied" value={gewaehltId} />

          <div class="feld">
            <label for="charge_1">Sorte (Charge)</label>
            <select id="charge_1" name="charge_1" required>
              <option value="">— bitte wählen —</option>
              {chargen.map((c) => (
                <option value={c.id} disabled={chargeGesperrt(c)}>
                  {c.sorte_name} — {c.thc_prozent ?? '?'} % THC · {c.verfuegbar_g} g da · Charge {c.charge_nr}{chargeGesperrt(c) ? ' — für U21 gesperrt' : ''}
                </option>
              ))}
            </select>
          </div>
          <div class="feld">
            <label for="menge_1">Menge in Gramm</label>
            <div class="mengenreihe">
              {schnellMengen.filter((g) => g <= status.restJetzt).map((g) => (
                <button type="button" class="menge-knopf" data-g={g}>{g} g</button>
              ))}
              <input id="menge_1" name="menge_1" type="number" inputmode="decimal"
                min="0.1" step="0.1" max={status.restJetzt} required placeholder="frei" />
            </div>
          </div>

          <details class="mehr-det">
            <summary>＋ weitere Sorte mitgeben (bis zu 3 zusätzlich)</summary>
            {[2, 3, 4].map((i) => (
              <div class="pos-zeile">
                <select name={`charge_${i}`} aria-label={`Sorte Position ${i}`}>
                  <option value="">— Sorte {i} (optional) —</option>
                  {chargen.map((c) => (
                    <option value={c.id} disabled={chargeGesperrt(c)}>
                      {c.sorte_name} — {c.thc_prozent ?? '?'} % THC · {c.verfuegbar_g} g da · {c.charge_nr}{chargeGesperrt(c) ? ' — U21 gesperrt' : ''}
                    </option>
                  ))}
                </select>
                <input name={`menge_${i}`} aria-label={`Menge Position ${i} in Gramm`} type="number"
                  inputmode="decimal" min="0.1" step="0.1" max={status.restJetzt} placeholder="g" />
              </div>
            ))}
          </details>

          <p class="beitrag-zeile">
            Zusammen höchstens <strong>{status.restJetzt} g</strong> ·
            Gesamt: <strong id="summe-vorschau">—</strong> ·
            Beitrag: <strong id="beitrag-vorschau">—</strong>
            <span style="color:var(--ink-soft);">({eur(BEITRAG_PRO_GRAMM)} €/g)</span>
          </p>
          <button class="knopf" type="submit">Alles buchen — ein Beleg</button>
        </form>
      )}
    </section>
  )}

  <h2>Heutige Abgaben</h2>
  {heuteAlle.length === 0 ? (
    <p style="color:var(--ink-soft);">Heute wurde noch nichts ausgegeben.</p>
  ) : (
    <>
      <p style="color:var(--ink-soft);">{heuteAlle.length} Buchungen · zusammen <strong>{heuteSumme} g</strong></p>
      <table class="tabelle">
        <thead>
          <tr><th>Mitglied</th><th>Sorte</th><th class="r">Menge</th><th class="r">THC</th><th class="r">Beitrag</th><th>Beleg</th></tr>
        </thead>
        <tbody>
          {heuteAlle.map((a) => (
            <tr>
              <td>{a.mitgliedsnummer || a.mitglied.slice(0, 6)}</td>
              <td>{a.sorte_name}</td>
              <td class="r">{a.menge_gramm} g</td>
              <td class="r">{a.thc_prozent ?? '—'} %</td>
              <td class="r">{eur(a.beitrag_euro)} €</td>
              <td><a href={`/mitglieder/ausgabe/beleg/${a.id}`}>öffnen</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </>
  )}
</Basis>

<script define:vars={{ preisProGramm: BEITRAG_PRO_GRAMM }}>
  // Schnellwahl-Mengen + Gesamt-/Beitragsvorschau ueber ALLE Positionen.
  // Rein optional - ohne JS bleiben die Felder voll nutzbar, gebucht und
  // geprueft wird immer serverseitig (auf die Summe).
  const felder = () => Array.from(document.querySelectorAll('input[name^="menge_"]'));
  const summeEl = document.getElementById('summe-vorschau');
  const beitragEl = document.getElementById('beitrag-vorschau');
  const zeige = () => {
    if (!summeEl || !beitragEl) return;
    const summe = felder().reduce((s, f) => {
      const g = parseFloat(String(f.value).replace(',', '.'));
      return s + (Number.isFinite(g) && g > 0 ? g : 0);
    }, 0);
    summeEl.textContent = summe > 0 ? summe.toLocaleString('de-DE') + ' g' : '—';
    beitragEl.textContent = summe > 0
      ? (summe * preisProGramm).toLocaleString('de-DE', { style: 'currency', currency: 'EUR' })
      : '—';
  };
  felder().forEach((f) => f.addEventListener('input', zeige));
  const erstes = document.getElementById('menge_1');
  document.querySelectorAll('.menge-knopf').forEach((k) => {
    k.addEventListener('click', () => {
      if (!erstes) return;
      erstes.value = k.dataset.g ?? '';
      zeige();
      document.querySelectorAll('.menge-knopf').forEach((x) => x.classList.toggle('aktiv', x === k));
    });
  });
</script>

<style>
  .schritt {
    margin: 0 0 1.6rem;
    max-width: var(--mass);
  }
  .schritt-titel {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.15rem;
    margin: 0 0 0.7rem;
  }
  .snr {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 50%;
    background: var(--accent);
    color: var(--bg-rein);
    font-size: 0.95rem;
    font-weight: 700;
  }
  .statuskarte {
    border: 1px solid var(--line);
    border-left: 4px solid var(--accent);
    border-radius: var(--radius);
    padding: 1rem 1.2rem;
    margin: 1rem 0 0;
    background: var(--bg-rein);
  }
  .statuskarte.warn {
    border-left-color: #c98a00;
  }
  .sk-kopf {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.7rem;
  }
  .sk-alter {
    color: var(--ink-soft);
    font-size: 0.92rem;
  }
  .sk-fehlt {
    color: #c0392b;
    font-weight: 600;
  }
  .sk-gross {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8.5rem, 1fr));
    gap: 0.6rem;
  }
  .sk-box {
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    padding: 0.55rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .sk-box-soft {
    border-color: var(--line);
  }
  .sk-box-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .sk-box-wert {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--brand-strong);
  }
  .sk-warn {
    margin: 0.7rem 0 0;
    color: #8a5a00;
    font-size: 0.92rem;
  }
  .sk-stop {
    color: #c0392b;
    font-weight: 600;
  }
  .mengenreihe {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: stretch;
  }
  .menge-knopf {
    font: inherit;
    padding: 0.55rem 0.9rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-rein);
    color: var(--ink);
    cursor: pointer;
  }
  .menge-knopf:hover {
    border-color: var(--accent);
  }
  .menge-knopf.aktiv {
    border-color: var(--accent);
    background: var(--line-soft);
    font-weight: 600;
  }
  .mengenreihe input {
    width: 7rem;
    flex: none;
  }
  .mehr-det {
    margin: 0 0 0.9rem;
    border: 1px dashed var(--line);
    border-radius: var(--radius);
    padding: 0.6rem 0.9rem;
  }
  .mehr-det summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .mehr-det[open] {
    border-style: solid;
  }
  .pos-zeile {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.7rem;
  }
  .pos-zeile select {
    flex: 1 1 auto;
    min-width: 0;
  }
  .pos-zeile input {
    width: 5.5rem;
    flex: none;
  }
  .beitrag-zeile {
    margin: 0.6rem 0 0;
    font-size: 0.95rem;
  }
  .tabelle {
    width: 100%;
    max-width: var(--mass);
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .tabelle th,
  .tabelle td {
    text-align: left;
    padding: 0.5rem 0.6rem;
    border-bottom: 1px solid var(--line);
  }
  .tabelle .r {
    text-align: right;
  }
  select,
  .mengenreihe input {
    padding: 0.6rem 0.7rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-rein);
    color: var(--ink);
    font: inherit;
  }
  select {
    width: 100%;
  }
</style>
