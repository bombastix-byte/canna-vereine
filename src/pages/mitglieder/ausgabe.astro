---
import Basis from '../../layouts/Basis.astro';
import MitgliedNav from '../../components/MitgliedNav.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../lib/pb';
import { darfAusgeben } from '../../lib/rollen';
import {
  berlinTag,
  berlinMonat,
  istU21,
  alterAmTag,
  summeGramm,
  LIMIT_TAG_G,
  LIMIT_MONAT_G,
  LIMIT_MONAT_U21_G,
  U21_MAX_THC,
  BEITRAG_PRO_GRAMM,
} from '../../lib/ausgabe';
import { ARTEN, ART_LABEL, limitFuer, summeStueck } from '../../lib/vermehrung';
import { produktTyp, produktLabel } from '../../lib/verarbeitung';

// Tresen: Abgabe (Bluete/Haschisch/Rosin) UND Vermehrungsmaterial (Samen/
// Stecklinge) an Mitglieder buchen - ein Vorgangskontext, ein Mitglied.
// Nur Personal (Vorstand/Ausgabe). Gefuehrter Ablauf: 1. Mitglied waehlen ->
// Restmengen sehen, 2. Charge + Menge buchen, 3. optional Samen/Stecklinge.
// U21-gesperrte Chargen sind direkt deaktiviert.
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
const { pb, mitglied: personal } = ergebnis;
if (!darfAusgeben(personal.rollen)) {
  return Astro.redirect('/mitglieder/bereich?fehler=keinzugriff', 303);
}

interface UserRow {
  id: string;
  name?: string;
  email: string;
  mitgliedsnummer?: string;
  geburtsdatum?: string;
  beitrag_bis?: string;
}
interface ChargeRow {
  id: string;
  charge_nr?: string;
  sorte_name?: string;
  status?: string;
  thc_prozent?: number;
  cbd_prozent?: number;
  verfuegbar_g?: number;
  produkt_typ?: string;
}
interface VermehrungRow {
  id: string;
  mitglied: string;
  mitgliedsnummer?: string;
  art: string;
  anzahl: number;
  tag: string;
}
interface AusgabeRow {
  id: string;
  mitglied: string;
  mitgliedsnummer?: string;
  sorte_name: string;
  menge_gramm: number;
  thc_prozent?: number;
  beitrag_euro?: number;
  tag: string;
  belegnr?: string;
  storniert?: boolean;
}

const tag = berlinTag();
const monat = berlinMonat(tag);

async function ladeListe<T>(collection: string, opts: Record<string, unknown>): Promise<T[]> {
  try {
    return (await pb.collection(collection).getFullList(opts)) as T[];
  } catch {
    return [];
  }
}

const mitglieder = await ladeListe<UserRow>('users', { sort: 'mitgliedsnummer,name' });
// Nur freigegebene Chargen mit Restbestand koennen abgegeben werden.
const chargen = (
  await ladeListe<ChargeRow>('chargen', { filter: 'status="freigegeben"', sort: 'sorte_name,charge_nr' })
).filter((c) => (c.verfuegbar_g ?? 0) > 0);
const heuteAlle = await ladeListe<AusgabeRow>('ausgaben', { filter: `tag="${tag}"`, sort: '-created' });
const heuteVermehrung = await ladeListe<VermehrungRow>('vermehrung_ausgaben', { filter: `tag="${tag}"`, sort: '-created' });

// Fehlermeldung aus den Buchungs-Endpoints (Abgabe UND Vermehrung).
const fehler = Astro.url.searchParams.get('fehler');
const msg = Astro.url.searchParams.get('msg');
const ok = Astro.url.searchParams.get('ok');

// Status eines ausgewaehlten Mitglieds (fuer die Restmengen-Anzeige).
// Auswahl per Dropdown (?mitglied=id) ODER Schnellfeld/Scanner (?nr=M-101).
const nrParam = Astro.url.searchParams.get('nr')?.trim() ?? '';
const perNr = nrParam
  ? mitglieder.find((m) => (m.mitgliedsnummer ?? '').toLowerCase() === nrParam.toLowerCase()) ?? null
  : null;
const gewaehltId = perNr?.id ?? (Astro.url.searchParams.get('mitglied') ?? '');
const gewaehlt = mitglieder.find((m) => m.id === gewaehltId) ?? null;
const nrNichtGefunden = !!nrParam && !perNr;

// Beitragsstatus: nur Hinweis am Tresen, kein Abgabe-Block (Vereinsentscheidung).
const beitragOffen = (m: UserRow) =>
  !m.beitrag_bis || m.beitrag_bis.slice(0, 10) < tag;
let status: null | {
  u21: boolean;
  alter: number | null;
  heute: number;
  monatSumme: number;
  monatslimit: number;
  restTag: number;
  restMonat: number;
  restJetzt: number;
} = null;
if (gewaehlt) {
  const saetze = await ladeListe<AusgabeRow>('ausgaben', {
    filter: `mitglied="${gewaehlt.id}" && monat="${monat}" && storniert!=true`,
  });
  const monatSumme = summeGramm(saetze);
  const heute = summeGramm(saetze.filter((r) => r.tag === tag));
  const u21 = istU21(gewaehlt.geburtsdatum, tag);
  const monatslimit = u21 ? LIMIT_MONAT_U21_G : LIMIT_MONAT_G;
  const restTag = Math.max(0, LIMIT_TAG_G - heute);
  const restMonat = Math.max(0, monatslimit - monatSumme);
  status = {
    u21,
    alter: alterAmTag(gewaehlt.geburtsdatum, tag),
    heute,
    monatSumme,
    monatslimit,
    restTag,
    restMonat,
    restJetzt: Math.min(restTag, restMonat),
  };
}

// Vermehrungs-Stand des gewaehlten Mitglieds (eigene Monatsgrenzen je Art).
let vstand: Record<string, { genutzt: number; limit: number; rest: number }> | null = null;
if (gewaehlt) {
  const vsaetze = await ladeListe<VermehrungRow>('vermehrung_ausgaben', {
    filter: `mitglied="${gewaehlt.id}" && monat="${monat}"`,
  });
  vstand = {};
  for (const art of ARTEN) {
    const genutzt = summeStueck(vsaetze.filter((s) => s.art === art));
    const limit = limitFuer(art);
    vstand[art] = { genutzt, limit, rest: Math.max(0, limit - genutzt) };
  }
}

// Dropdown-Text einer Charge: Produkt (nur wenn kein Bluete), Sorte, THC, Rest.
const chargeText = (c: ChargeRow) =>
  `${produktTyp(c.produkt_typ) === 'bluete' ? '' : `${produktLabel(c.produkt_typ)} · `}${c.sorte_name} — ${c.thc_prozent ?? '?'} % THC · ${c.verfuegbar_g} g da · ${c.charge_nr}`;

// Fuer U21 gesperrte Chargen direkt im Dropdown deaktivieren (>10 % THC oder
// THC unbekannt) - die Fehlermeldung kommt so gar nicht erst zustande.
const chargeGesperrt = (c: ChargeRow) =>
  !!status?.u21 && !(typeof c.thc_prozent === 'number' && c.thc_prozent > 0 && c.thc_prozent <= U21_MAX_THC);

const mnr = (m: UserRow) => (m.mitgliedsnummer ? `${m.mitgliedsnummer} — ` : '') + (m.name || m.email);
const eur = (n?: number) => (n ?? 0).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const heuteSumme = summeGramm(heuteAlle.filter((a) => !a.storniert));
const schnellMengen = [1, 2, 3, 5, 10];
---

<Basis titel="Ausgabe" beschreibung="Abgabe und Vermehrungsmaterial an Mitglieder buchen, KCanG-konform.">
  <MitgliedNav rollen={personal.rollen} />
  <p class="eyebrow">Vereinsarbeit</p>
  <h1 style="margin-bottom:0.4rem;">Ausgabe</h1>
  <p class="einleitung">
    Erst das Mitglied wählen, dann Sorte und Menge — Samen und Stecklinge gleich
    mit dazu. Alle gesetzlichen Grenzen prüft das System automatisch.
    Beitrag: {eur(BEITRAG_PRO_GRAMM)} € je Gramm, kassiert wird an der Kasse.
  </p>

  {fehler && msg && (
    <p class="hinweis hinweis--fehler" role="alert"><strong>Nicht gebucht:</strong> {msg}</p>
  )}
  {ok === 'vermehrung' && (
    <p class="hinweis" role="status">Weitergabe von Vermehrungsmaterial gebucht.</p>
  )}

  <section class="schritt" aria-label="Schritt 1">
    <h2 class="schritt-titel"><span class="snr">1</span> Mitglied wählen</h2>
    <form class="kasten" method="get" action="/mitglieder/ausgabe" style="margin-bottom:0.8rem;" id="nr-form">
      <div class="feld">
        <label for="nr">Schnell: Mitgliedsnummer (tippen oder Ausweis scannen)</label>
        <input class="eingabe" id="nr" name="nr" type="text" inputmode="text"
          placeholder="z. B. M-101" value={nrParam} autocomplete="off" />
      </div>
      <button class="knopf" type="submit">Laden</button>
      <button class="knopf-sek" type="button" id="qr-kamera" hidden>QR mit Kamera scannen</button>
      {nrNichtGefunden && <p style="color:var(--gefahr);font-size:0.92rem;margin:0.6rem 0 0;">Nummer „{nrParam}" nicht gefunden.</p>}
    </form>
    <div class="scan-overlay" id="scan-overlay" hidden>
      <div class="scan-kasten">
        <p class="scan-hinweis">QR-Code des Mitgliedsausweises vor die Kamera halten.</p>
        <video id="scan-video" playsinline autoplay muted></video>
        <p class="scan-fehler" id="scan-fehler" hidden></p>
        <button class="knopf-sek" type="button" id="scan-abbruch">Abbrechen</button>
      </div>
    </div>
    <form class="kasten" method="get" action="/mitglieder/ausgabe">
      <div class="feld">
        <label for="mitglied-sel">…oder aus der Liste wählen</label>
        <select id="mitglied-sel" name="mitglied" onchange="this.form.submit()">
          <option value="">— bitte wählen —</option>
          {mitglieder.map((m) => (
            <option value={m.id} selected={m.id === gewaehltId}>{mnr(m)}</option>
          ))}
        </select>
        <noscript><button class="knopf" type="submit">Mitglied laden</button></noscript>
      </div>

      {gewaehlt && status && (
        <div class:list={['statuskarte', { 'statuskarte--warn': status.u21 }]}>
          <div class="sk-kopf">
            <strong>{mnr(gewaehlt)}</strong>
            {status.alter != null ? (
              <span class="sk-alter">{status.alter} Jahre{status.u21 ? ' · unter 21' : ''}</span>
            ) : (
              <span class="sk-alter sk-fehlt">Geburtsdatum fehlt → wird streng als U21 behandelt</span>
            )}
          </div>
          <div class="sk-gross">
            <div class="sk-box">
              <span class="sk-box-label">Darf jetzt noch</span>
              <span class="sk-box-wert">{status.restJetzt} g</span>
            </div>
            <div class="sk-box sk-box-soft">
              <span class="sk-box-label">Heute schon</span>
              <span class="sk-box-wert">{status.heute} / {LIMIT_TAG_G} g</span>
            </div>
            <div class="sk-box sk-box-soft">
              <span class="sk-box-label">Diesen Monat</span>
              <span class="sk-box-wert">{status.monatSumme} / {status.monatslimit} g</span>
            </div>
          </div>
          {status.u21 && (
            <p class="sk-warn">Unter 21: nur Sorten bis {U21_MAX_THC} % THC — stärkere sind unten ausgegraut.</p>
          )}
          {beitragOffen(gewaehlt) && (
            <p class="sk-warn">Beitragsstatus: {gewaehlt.beitrag_bis ? `bezahlt bis ${gewaehlt.beitrag_bis.slice(0, 10)}` : 'kein Eintrag'} — bitte an der Kasse klären.</p>
          )}
          {status.restJetzt === 0 && (
            <p class="sk-warn sk-stop">Limit erreicht — heute keine Abgabe mehr an dieses Mitglied möglich.</p>
          )}
        </div>
      )}
    </form>
  </section>

  {gewaehlt && status && status.restJetzt > 0 && (
    <section class="schritt" aria-label="Schritt 2">
      <h2 class="schritt-titel"><span class="snr">2</span> Sorten und Mengen</h2>
      {chargen.length === 0 ? (
        <p class="hinweis">Keine freigegebene Charge mit Bestand. Zuerst in der
        <a href="/mitglieder/wawi"> Warenwirtschaft</a> eine Charge freigeben.</p>
      ) : (
        <form class="kasten" method="post" action="/mitglieder/ausgabe/buchen">
          <input type="hidden" name="mitglied" value={gewaehltId} />

          <div class="feld">
            <label for="charge_1">Sorte (Charge)
              <button class="knopf-mini" type="button" id="qr-charge" hidden>Gebinde-QR scannen</button>
            </label>
            <select id="charge_1" name="charge_1" required>
              <option value="">— bitte wählen —</option>
              {chargen.map((c) => (
                <option value={c.id} data-nr={c.charge_nr} disabled={chargeGesperrt(c)}>
                  {chargeText(c)}{chargeGesperrt(c) ? ' — für U21 gesperrt' : ''}
                </option>
              ))}
            </select>
          </div>
          <div class="feld">
            <label for="menge_1">Menge in Gramm</label>
            <div class="mengenreihe">
              {schnellMengen.filter((g) => g <= status.restJetzt).map((g) => (
                <button type="button" class="menge-knopf" data-g={g}>{g} g</button>
              ))}
              <input class="eingabe" id="menge_1" name="menge_1" type="number" inputmode="decimal"
                min="0.1" step="0.1" max={status.restJetzt} required placeholder="frei" />
            </div>
          </div>

          <details class="klappe" style="margin-bottom:0.9rem;">
            <summary>＋ weitere Sorte mitgeben (bis zu 3 zusätzlich)</summary>
            {[2, 3, 4].map((i) => (
              <div class="pos-zeile">
                <select class="eingabe" name={`charge_${i}`} aria-label={`Sorte Position ${i}`}>
                  <option value="">— Sorte {i} (optional) —</option>
                  {chargen.map((c) => (
                    <option value={c.id} data-nr={c.charge_nr} disabled={chargeGesperrt(c)}>
                      {chargeText(c)}{chargeGesperrt(c) ? ' — U21 gesperrt' : ''}
                    </option>
                  ))}
                </select>
                <input class="eingabe" name={`menge_${i}`} aria-label={`Menge Position ${i} in Gramm`} type="number"
                  inputmode="decimal" min="0.1" step="0.1" max={status.restJetzt} placeholder="g" />
              </div>
            ))}
          </details>

          <p class="beitrag-zeile">
            Zusammen höchstens <strong>{status.restJetzt} g</strong> ·
            Gesamt: <strong id="summe-vorschau">—</strong> ·
            Beitrag: <strong id="beitrag-vorschau">—</strong>
            <span style="color:var(--ink-soft);">({eur(BEITRAG_PRO_GRAMM)} €/g)</span>
          </p>
          <button class="knopf" type="submit">Alles buchen — ein Beleg</button>
        </form>
      )}
    </section>
  )}

  {gewaehlt && vstand && (
    <section class="schritt" aria-label="Samen und Stecklinge">
      <h2 class="schritt-titel"><span class="snr">3</span> Samen &amp; Stecklinge (optional)</h2>
      <form class="kasten" method="post" action="/mitglieder/vermehrung/buchen">
        <input type="hidden" name="mitglied" value={gewaehltId} />
        <p style="margin:0 0 0.8rem;color:var(--ink-soft);font-size:0.95rem;">
          Eigene Monatsgrenzen je Mitglied: {limitFuer('samen')} Samen / {limitFuer('stecklinge')} Stecklinge —
          unabhängig von der Abgabemenge oben.
        </p>
        <div class="v-doppel">
          <div class="feld">
            <label for="anzahl_samen">Samen (noch {vstand.samen.rest} von {vstand.samen.limit} diesen Monat)</label>
            <input id="anzahl_samen" name="anzahl_samen" type="number" min="1" step="1"
              max={vstand.samen.rest} disabled={vstand.samen.rest === 0} placeholder={vstand.samen.rest === 0 ? 'Limit erreicht' : 'Stück'} />
          </div>
          <div class="feld">
            <label for="anzahl_stecklinge">Stecklinge (noch {vstand.stecklinge.rest} von {vstand.stecklinge.limit})</label>
            <input id="anzahl_stecklinge" name="anzahl_stecklinge" type="number" min="1" step="1"
              max={vstand.stecklinge.rest} disabled={vstand.stecklinge.rest === 0} placeholder={vstand.stecklinge.rest === 0 ? 'Limit erreicht' : 'Stück'} />
          </div>
        </div>
        <button class="knopf-sek" type="submit" disabled={vstand.samen.rest === 0 && vstand.stecklinge.rest === 0}>Weitergabe buchen</button>
      </form>
    </section>
  )}

  <h2>Heutige Abgaben</h2>
  {heuteAlle.length === 0 ? (
    <p style="color:var(--ink-soft);">Heute wurde noch nichts ausgegeben.</p>
  ) : (
    <>
      <p style="color:var(--ink-soft);">{heuteAlle.length} Buchungen · zusammen <strong>{heuteSumme} g</strong></p>
      <table class="tabelle">
        <thead>
          <tr><th>Mitglied</th><th>Sorte</th><th class="r">Menge</th><th class="r">THC</th><th class="r">Beitrag</th><th>Beleg</th></tr>
        </thead>
        <tbody>
          {heuteAlle.map((a) => (
            <tr class:list={{ storniert: a.storniert }}>
              <td>{a.mitgliedsnummer || a.mitglied.slice(0, 6)}</td>
              <td>{a.sorte_name}{a.storniert && ' · storniert'}</td>
              <td class="r">{a.menge_gramm} g</td>
              <td class="r">{a.thc_prozent ?? '—'} %</td>
              <td class="r">{eur(a.beitrag_euro)} €</td>
              <td><a href={`/mitglieder/ausgabe/beleg/${a.id}`}>öffnen</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </>
  )}

  {heuteVermehrung.length > 0 && (
    <>
      <h2>Heutige Weitergaben (Samen/Stecklinge)</h2>
      <table class="tabelle">
        <thead><tr><th>Mitglied</th><th>Art</th><th class="r">Anzahl</th></tr></thead>
        <tbody>
          {heuteVermehrung.map((v) => (
            <tr>
              <td>{v.mitgliedsnummer || v.mitglied.slice(0, 6)}</td>
              <td>{ART_LABEL[v.art as keyof typeof ART_LABEL] ?? v.art}</td>
              <td class="r">{v.anzahl}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </>
  )}
</Basis>

<script define:vars={{ preisProGramm: BEITRAG_PRO_GRAMM }}>
  // Schnellwahl-Mengen + Gesamt-/Beitragsvorschau ueber ALLE Positionen.
  // Rein optional - ohne JS bleiben die Felder voll nutzbar, gebucht und
  // geprueft wird immer serverseitig (auf die Summe).
  const felder = () => Array.from(document.querySelectorAll('input[name^="menge_"]'));
  const summeEl = document.getElementById('summe-vorschau');
  const beitragEl = document.getElementById('beitrag-vorschau');
  const zeige = () => {
    if (!summeEl || !beitragEl) return;
    const summe = felder().reduce((s, f) => {
      const g = parseFloat(String(f.value).replace(',', '.'));
      return s + (Number.isFinite(g) && g > 0 ? g : 0);
    }, 0);
    summeEl.textContent = summe > 0 ? summe.toLocaleString('de-DE') + ' g' : '—';
    beitragEl.textContent = summe > 0
      ? (summe * preisProGramm).toLocaleString('de-DE', { style: 'currency', currency: 'EUR' })
      : '—';
  };
  felder().forEach((f) => f.addEventListener('input', zeige));
  const erstes = document.getElementById('menge_1');
  document.querySelectorAll('.menge-knopf').forEach((k) => {
    k.addEventListener('click', () => {
      if (!erstes) return;
      erstes.value = k.dataset.g ?? '';
      zeige();
      document.querySelectorAll('.menge-knopf').forEach((x) => x.classList.toggle('aktiv', x === k));
    });
  });
</script>

<script is:inline>
  // Kamera-QR-Scan am Tresen. Zwei Ausloeser, ein Overlay:
  //  - Mitgliedsausweis (QR = Mitgliedsnummer) -> Schnellfeld + Formular ab
  //  - Gebinde-Etikett (QR = Chargennummer, auch Pflanzen-QRs "…-P01")
  //    -> waehlt die Charge in der naechsten freien Position
  // Nutzt die BarcodeDetector-API des Browsers/WebViews (Android/Chrome und
  // die Vereins-App). Wo sie fehlt (z. B. iOS-Safari), bleiben die Knoepfe
  // verborgen - Tippen und USB-Scanner funktionieren immer.
  (() => {
    const overlay = document.getElementById('scan-overlay');
    const video = document.getElementById('scan-video');
    const fehlerEl = document.getElementById('scan-fehler');
    const abbruch = document.getElementById('scan-abbruch');
    if (!overlay || !video) return;
    if (!('BarcodeDetector' in window) || !navigator.mediaDevices?.getUserMedia) return;

    let stream = null;
    let aktiv = false;

    const zu = () => {
      aktiv = false;
      overlay.hidden = true;
      if (stream) stream.getTracks().forEach((t) => t.stop());
      stream = null;
      video.srcObject = null;
    };

    const zeigeFehler = (text) => {
      if (!fehlerEl) return;
      fehlerEl.textContent = text;
      fehlerEl.hidden = false;
    };

    // Oeffnet das Overlay und ruft auswerten(wert) je gelesenem Code auf.
    // Rueckgabe true = fertig (Overlay zu), false/String = weiterscannen
    // (String wird als Hinweis angezeigt, z. B. "Charge nicht gefunden").
    const starteScan = async (auswerten) => {
      if (fehlerEl) fehlerEl.hidden = true;
      overlay.hidden = false;
      try {
        stream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: 'environment' },
          audio: false,
        });
      } catch {
        zeigeFehler('Kamera nicht verfügbar oder Zugriff abgelehnt.');
        return;
      }
      video.srcObject = stream;
      aktiv = true;
      const detector = new BarcodeDetector({ formats: ['qr_code'] });
      let letzterFehlwert = '';
      const pruefe = async () => {
        if (!aktiv) return;
        try {
          const codes = video.readyState >= 2 ? await detector.detect(video) : [];
          const wert = codes[0]?.rawValue?.trim();
          if (wert) {
            const ergebnis = auswerten(wert);
            if (ergebnis === true) {
              zu();
              return;
            }
            // Denselben Fehlwert nicht in jedem Frame neu melden.
            if (typeof ergebnis === 'string' && wert !== letzterFehlwert) {
              letzterFehlwert = wert;
              zeigeFehler(ergebnis);
            }
          }
        } catch {
          // Einzelner Frame nicht lesbar - einfach weiterprobieren.
        }
        setTimeout(pruefe, 150);
      };
      pruefe();
    };

    abbruch?.addEventListener('click', zu);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) zu(); });

    // --- Ausloeser 1: Mitgliedsausweis ---
    const mKnopf = document.getElementById('qr-kamera');
    const nrFeld = document.getElementById('nr');
    const nrForm = document.getElementById('nr-form');
    if (mKnopf && nrFeld && nrForm) {
      mKnopf.hidden = false;
      mKnopf.addEventListener('click', () =>
        starteScan((wert) => {
          nrFeld.value = wert;
          nrForm.submit();
          return true;
        }),
      );
    }

    // --- Ausloeser 2: Gebinde-QR (Chargennummer) ---
    const cKnopf = document.getElementById('qr-charge');
    if (cKnopf && document.querySelector('select[name^="charge_"]')) {
      cKnopf.hidden = false;
      cKnopf.addEventListener('click', () =>
        starteScan((wert) => {
          // Pflanzen-Etiketten ("2026-0001-P01") auf die Charge abbilden.
          const nr = wert.replace(/-P\d+$/i, '');
          const selects = [...document.querySelectorAll('select[name^="charge_"]')];
          const passt = (o) => (o.dataset.nr || '') !== '' && o.dataset.nr.toLowerCase() === nr.toLowerCase();
          const option = [...selects[0].options].find(passt);
          if (!option) return `Charge „${nr}" nicht gefunden oder nicht freigegeben.`;
          if (option.disabled) return `Charge ${nr}: für dieses Mitglied gesperrt (U21/THC).`;
          // Naechste freie Position; ist die Charge schon gewaehlt, dorthin.
          const ziel =
            selects.find((s) => [...s.options].find(passt)?.value === s.value) ??
            selects.find((s) => !s.value);
          if (!ziel) return 'Alle Positionen sind belegt.';
          ziel.value = [...ziel.options].find(passt).value;
          // Positionen 2-4 liegen in der zugeklappten Klappe - aufmachen.
          ziel.closest('details')?.setAttribute('open', '');
          const i = ziel.name.split('_')[1];
          document.querySelector(`input[name="menge_${i}"]`)?.focus();
          return true;
        }),
      );
    }
  })();
</script>

