---
import Basis from '../../../../layouts/Basis.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../../../lib/pb';
import { darfAnbau, darfAusgeben } from '../../../../lib/rollen';
import { produktLabel } from '../../../../lib/verarbeitung';
import QRCode from 'qrcode-svg';
import { site } from '../../../../config';

// Druckbare Gebinde-Etiketten einer freigegebenen Charge (fuer Abgabeglaeser/
// -tueten). QR-Inhalt = Chargennummer - der Tresen-Scanner waehlt darueber
// die Sorte im Abgabeformular. Anzahl ueber ?n= (Standard 12).
// Zugriff: Anbau UND Tresen-Personal (beide bestuecken Gebinde).
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
const { pb, mitglied } = ergebnis;
if (!darfAnbau(mitglied.rollen) && !darfAusgeben(mitglied.rollen)) {
  return Astro.redirect('/mitglieder/bereich?fehler=keinzugriff', 303);
}

const { id } = Astro.params;
let charge;
try {
  charge = await pb.collection('chargen').getOne(id!);
} catch {
  return Astro.redirect('/mitglieder/wawi', 303);
}

const anzahl = Math.min(60, Math.max(1, Number(Astro.url.searchParams.get('n')) || 12));
const produkt = produktLabel(charge.produkt_typ);
const qrSvg = new QRCode({ content: String(charge.charge_nr ?? ''), width: 96, height: 96, padding: 0, ecl: 'M', join: true }).svg();
---

<Basis titel={`Gebinde-Etiketten ${charge.charge_nr ?? ''}`} beschreibung="QR-Etiketten für Abgabegebinde drucken.">
  {Astro.url.searchParams.get('gedruckt') && <p class="hinweis" role="status" style="max-width:var(--mass);">An Etikettendrucker gesendet.</p>}
  {Astro.url.searchParams.get('druckfehler') && <p class="hinweis hinweis--fehler" style="max-width:var(--mass);">Drucker nicht erreichbar. Bitte über den Druckdialog drucken.</p>}

  <div class="aktionen">
    <button class="knopf" type="button" onclick="window.print()">Etiketten drucken</button>
    <form method="post" action={`/mitglieder/wawi/gebinde/${charge.id}/zpl?n=${anzahl}`} style="display:inline;">
      <button class="knopf-sek" type="submit">An Etikettendrucker senden</button>
    </form>
    <form method="get" action={`/mitglieder/wawi/gebinde/${charge.id}`} class="anzahl-form">
      <label for="n">Anzahl</label>
      <input id="n" name="n" type="number" min="1" max="60" value={anzahl} />
      <button class="knopf-sek" type="submit">Neu</button>
    </form>
    <a class="knopf-sek" href="/mitglieder/wawi">Zurück</a>
  </div>

  <p class="kopf-info">
    <strong>{produkt} · {charge.sorte_name}</strong> · Charge {charge.charge_nr} ·
    QR am Tresen scannen = Sorte ist gewählt.
  </p>

  <div class="bogen">
    {Array.from({ length: anzahl }).map(() => (
      <div class="etikett">
        <div class="et-qr" set:html={qrSvg} />
        <div class="et-text">
          <span class="et-sorte">{produkt} · {charge.sorte_name}</span>
          <span class="et-nr">{charge.charge_nr}</span>
          <span class="et-charge">{charge.thc_prozent != null ? `THC ${charge.thc_prozent} % · ` : ''}{site.kurzname}</span>
        </div>
      </div>
    ))}
  </div>
</Basis>

<style>
  .aktionen { display: flex; gap: 0.8rem; align-items: center; flex-wrap: wrap; margin: 1rem 0 1rem; max-width: var(--mass); }
  .anzahl-form { display: flex; gap: 0.4rem; align-items: center; }
  .anzahl-form label { color: var(--ink-soft); font-size: 0.92rem; }
  .anzahl-form input { width: 4.5rem; padding: 0.4rem 0.5rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--bg-rein); color: var(--ink); font: inherit; }
  .kopf-info { color: var(--ink-soft); margin: 0 0 1rem; max-width: var(--mass); }
  .bogen {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(9.5rem, 1fr));
    gap: 0.5rem;
    max-width: var(--mass);
  }
  .etikett {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0.5rem 0.6rem;
    background: #fff;
  }
  .et-qr { flex: none; width: 60px; height: 60px; }
  .et-qr :global(svg) { width: 60px; height: 60px; display: block; }
  .et-text { display: flex; flex-direction: column; min-width: 0; }
  .et-sorte { font-size: 0.72rem; color: #333; }
  .et-nr { font-weight: 700; font-size: 0.92rem; color: #000; }
  .et-charge { font-size: 0.66rem; color: #666; }

  @media print {
    :global(body *) { visibility: hidden; }
    .bogen, .bogen * { visibility: visible; }
    .bogen { position: absolute; top: 0; left: 0; width: 100%; gap: 2mm; }
    .aktionen, .kopf-info { display: none; }
    .etikett { break-inside: avoid; }
  }
</style>
