---
import Basis from '../../layouts/Basis.astro';
import MitgliedNav from '../../components/MitgliedNav.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../lib/pb';
import { darfVerwalten, ROLLEN, ROLLEN_LABEL } from '../../lib/rollen';

// Mitglieder- und Rollenverwaltung. Nur Vorstand.
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
const { pb, mitglied } = ergebnis;
if (!darfVerwalten(mitglied.rollen)) return Astro.redirect('/mitglieder/bereich?fehler=keinzugriff', 303);

interface UserRow {
  id: string;
  name?: string;
  email: string;
  mitgliedsnummer?: string;
  geburtsdatum?: string;
  rollen?: string[];
}
let mitglieder: UserRow[] = [];
try {
  mitglieder = (await pb.collection('users').getFullList({ sort: 'mitgliedsnummer,name' })) as UserRow[];
} catch {
  mitglieder = [];
}

const ok = Astro.url.searchParams.get('ok');
const fehler = Astro.url.searchParams.get('fehler');
const isoTag = (s?: string) => (s ? s.slice(0, 10) : '');
---

<Basis titel="Mitgliederverwaltung" beschreibung="Mitglieder und Rollen verwalten.">
  <MitgliedNav rollen={mitglied.rollen} />
  <p class="eyebrow">Vereinsarbeit · nur Vorstand</p>
  <h1 style="margin-bottom:0.4rem;">Mitglieder &amp; Rollen</h1>
  <p class="einleitung">
    Mitgliedsnummer, Geburtsdatum (für die U21-Regel) und Rollen pflegen.
    Bestehende Mitglieder lassen sich per <code>scripts/import-mitglieder.mjs</code> aus einer CSV importieren.
  </p>

  {ok && <p class="hinweis" role="status">Gespeichert.</p>}
  {fehler && <p class="hinweis" role="alert" style="border-color:#d99;background:#fbecec;">Speichern fehlgeschlagen.</p>}

  <p style="color:var(--ink-soft);">{mitglieder.length} Mitglieder.</p>

  {mitglieder.map((m) => (
    <form class="mrow" id={`m-${m.id}`} method="post" action="/mitglieder/verwaltung/speichern">
      <input type="hidden" name="mitglied" value={m.id} />
      <div class="mrow-kopf">
        <strong>{m.name || m.email}</strong>
        <span class="mrow-mail">{m.email}</span>
      </div>
      <div class="mrow-felder">
        <label>Mitgliedsnr.<input name="mitgliedsnummer" type="text" value={m.mitgliedsnummer ?? ''} /></label>
        <label>Geburtsdatum<input name="geburtsdatum" type="date" value={isoTag(m.geburtsdatum)} /></label>
      </div>
      <fieldset class="mrow-rollen">
        <legend>Rollen</legend>
        {ROLLEN.map((r) => (
          <label class="chk">
            <input type="checkbox" name="rollen" value={r} checked={(m.rollen ?? []).includes(r)} />
            {ROLLEN_LABEL[r]}
          </label>
        ))}
      </fieldset>
      <button class="knopf" type="submit">Speichern</button>
    </form>
  ))}
</Basis>

<style>
  .mrow { max-width: var(--mass); border: 1px solid var(--line); border-radius: var(--radius); padding: 1rem 1.1rem; margin: 0 0 0.8rem; background: var(--bg-rein); }
  .mrow-kopf { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.6rem; }
  .mrow-mail { color: var(--ink-soft); font-size: 0.9rem; }
  .mrow-felder { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.6rem; }
  .mrow-felder label { display: flex; flex-direction: column; gap: 0.2rem; font-size: 0.9rem; color: var(--ink-soft); }
  .mrow-felder input { padding: 0.45rem 0.6rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--bg-rein); color: var(--ink); font: inherit; }
  .mrow-rollen { border: 1px solid var(--line); border-radius: var(--radius); padding: 0.6rem 0.9rem; margin: 0 0 0.7rem; }
  .mrow-rollen legend { font-size: 0.85rem; color: var(--ink-soft); padding: 0 0.4rem; }
  .chk { display: inline-flex; align-items: center; gap: 0.35rem; margin-right: 1rem; font-size: 0.92rem; }
  .chk input { width: auto; }
</style>
