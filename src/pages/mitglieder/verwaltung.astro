---
import Basis from '../../layouts/Basis.astro';
import MitgliedNav from '../../components/MitgliedNav.astro';
import { verwaltungTabs } from '../../lib/mitglied-nav';
import UnterNav from '../../components/UnterNav.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../lib/pb';
import { darfVerwalten, ROLLEN_LABEL, istSystemkonto, type Rolle } from '../../lib/rollen';
import { effektiverStatus, STATUS_LABEL } from '../../lib/status';
import { berlinTag } from '../../lib/ausgabe';
import { site } from '../../config';
import { anzeigeName } from '../../lib/mitglied-anzeige';
// Datensparsamer Modus: Mitglieder werden nur mit der Mitgliedsnummer angelegt
// (keine Personendaten). Das Formular blendet Name/E-Mail/Geburtsdatum aus.
const privacy = site.login_modus === 'mitgliedsnummer';
const __fn = Astro.locals.funktionen;
const hatAufnahmebeitrag = (__fn?.aufnahmebeitragEuro ?? 0) > 0;
const aufnahmebeitragEuro = __fn?.aufnahmebeitragEuro ?? 0;
// Mitgliederverwaltung: Suche + Liste. Bearbeitet wird auf der Detailseite
// (/mitglieder/verwaltung/[id]). Skaliert auf mehrere hundert Mitglieder.
// Nur Vorstand.
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
const { pb, mitglied } = ergebnis;
if (!darfVerwalten(mitglied.rollen)) return Astro.redirect('/mitglieder/bereich?fehler=keinzugriff', 303);

interface UserRow {
  id: string;
  name?: string;
  alias?: string;
  email: string;
  mitgliedsnummer?: string;
  rollen?: string[];
  mitglied_status?: string;
  austritt_zum?: string;
}

// Suchbegriff: freier Text ODER exakte Mitgliedsnummer (vom Ausweis-Scan).
const q = (Astro.url.searchParams.get('q') ?? '').trim();

let alle: UserRow[] = [];
try {
  alle = (await pb.collection('users').getFullList({
    fields: 'id,name,alias,email,mitgliedsnummer,rollen,mitglied_status,austritt_zum',
    sort: 'mitgliedsnummer,name',
  })) as UserRow[];
} catch {
  alle = [];
}
// Technisches System-/Automatik-Konto ist kein Mitglied -> ausblenden.
alle = alle.filter((u) => !istSystemkonto(u));

const norm = (s: string) => s.toLowerCase();
const treffer = q
  ? alle.filter((m) => {
      const nq = norm(q);
      return (
        norm(m.mitgliedsnummer ?? '').includes(nq) ||
        norm(m.name ?? '').includes(nq) ||
        norm(m.email ?? '').includes(nq)
      );
    })
  : alle;

// Ein einziger, exakter Nummern-Treffer (typischer Scan) -> direkt zur Person.
const exakteTreffer = q
  ? alle.filter((m) => norm(m.mitgliedsnummer ?? '') === norm(q))
  : [];
if (exakteTreffer.length === 1) return Astro.redirect(`/mitglieder/verwaltung/${exakteTreffer[0].id}`, 303);

// Altbestände sichtbar machen, statt bei einem Scan willkürlich einen von
// mehreren Datensätzen zu öffnen. Neue Dubletten verhindert die Datenbank.
const nachNummer = new Map<string, UserRow[]>();
for (const m of alle) {
  const nummer = (m.mitgliedsnummer ?? '').trim().toUpperCase();
  if (!nummer) continue;
  nachNummer.set(nummer, [...(nachNummer.get(nummer) ?? []), m]);
}
const doppelteNummern = [...nachNummer.entries()].filter(([, mitglieder]) => mitglieder.length > 1);
const ohneNummer = alle.filter((m) => !(m.mitgliedsnummer ?? '').trim());

const proSeite = 50;
const seitenGesamt = Math.max(1, Math.ceil(treffer.length / proSeite));
const seiteGewuenscht = Number.parseInt(Astro.url.searchParams.get('seite') ?? '1', 10);
const seite = Number.isFinite(seiteGewuenscht)
  ? Math.min(Math.max(seiteGewuenscht, 1), seitenGesamt)
  : 1;
const trefferSeite = treffer.slice((seite - 1) * proSeite, seite * proSeite);
const seitenUrl = (ziel: number) => {
  const params = new URLSearchParams();
  if (q) params.set('q', q);
  params.set('seite', String(ziel));
  return `/mitglieder/verwaltung?${params.toString()}`;
};

const rollenKurz = (r?: string[]) =>
  (r ?? []).filter((x) => x !== 'mitglied').map((x) => ROLLEN_LABEL[x as Rolle] ?? x);

const geloescht = Astro.url.searchParams.get('geloescht');
const fehler = Astro.url.searchParams.get('fehler');
const fehlertext: Record<string, string> = {
  email: 'Bitte eine gültige E-Mail-Adresse angeben.',
  name: 'Bitte mindestens einen Namen angeben.',
  existiert: 'Diese E-Mail-Adresse ist bereits vergeben.',
  nummer: 'Bitte eine gültige Mitgliedsnummer aus Buchstaben, Zahlen und Bindestrichen angeben.',
  nummer_existiert: 'Diese Mitgliedsnummer ist bereits vergeben.',
  fehlgeschlagen: 'Anlegen fehlgeschlagen. Bitte erneut versuchen.',
};
const fmeldung = fehler ? fehlertext[fehler] ?? 'Es ist ein Fehler aufgetreten.' : null;
const ROLLEN_WAEHLBAR = ['ausgabe', 'anbau', 'praevention', 'vorstand'] as const;
---

<Basis titel="Mitgliederverwaltung" beschreibung="Mitglieder suchen und verwalten.">
  <MitgliedNav rollen={mitglied.rollen} />
  <p class="eyebrow">Vereinsarbeit · nur Vorstand</p>
  <UnterNav punkte={verwaltungTabs(Astro.locals.funktionen)} />
  <h1 style="margin-bottom:0.4rem;">Mitglieder</h1>
  <p class="einleitung">
    Nach Name, Mitgliedsnummer oder E-Mail suchen — oder den Mitgliedsausweis
    scannen. Zum Bearbeiten das Mitglied öffnen.
  </p>

  {geloescht && <p class="hinweis" role="status">Mitglied gelöscht.</p>}
  {fmeldung && <p class="hinweis hinweis--fehler" role="alert">{fmeldung}</p>}
  {(doppelteNummern.length > 0 || ohneNummer.length > 0) && (
    <details class="hinweis hinweis--fehler datenwarnung" open={doppelteNummern.length > 0}>
      <summary>Datenbestand prüfen: {doppelteNummern.length} doppelte Nummer(n), {ohneNummer.length} Mitglied(er) ohne Nummer</summary>
      {doppelteNummern.length > 0 && (
        <ul>
          {doppelteNummern.map(([nummer, eintraege]) => (
            <li><strong>{nummer}</strong>: {eintraege.map((m, index) => <>{index > 0 && ' · '}<a href={`/mitglieder/verwaltung/${m.id}`}>{anzeigeName(m)}</a></>)}</li>
          ))}
        </ul>
      )}
      {ohneNummer.length > 0 && <p>Fehlende Nummern bitte in den jeweiligen Mitgliedsdatensätzen ergänzen.</p>}
    </details>
  )}

  <details class="klappe" open={!!fmeldung}>
    <summary>＋ Mitglied anlegen</summary>
    <form class="kasten" method="post" action="/mitglieder/verwaltung/anlegen">
      {privacy ? (
        <div class="feld-reihe">
          <div class="feld"><label for="a-nr">Mitgliedsnummer (optional)</label><input class="eingabe" id="a-nr" name="mitgliedsnummer" type="text" placeholder="leer = automatisch (M-…)" /></div>
        </div>
      ) : (
        <>
          <div class="feld-reihe">
            <div class="feld"><label for="a-vorname">Vorname</label><input class="eingabe" id="a-vorname" name="vorname" type="text" /></div>
            <div class="feld"><label for="a-nachname">Nachname</label><input class="eingabe" id="a-nachname" name="nachname" type="text" /></div>
          </div>
          <div class="feld-reihe">
            <div class="feld"><label for="a-email">E-Mail</label><input class="eingabe" id="a-email" name="email" type="email" required placeholder="fuer die Anmeldung" /></div>
            <div class="feld"><label for="a-nr">Mitgliedsnr. (optional)</label><input class="eingabe" id="a-nr" name="mitgliedsnummer" type="text" placeholder="leer = automatisch" /></div>
            <div class="feld"><label for="a-geb">Geburtsdatum</label><input class="eingabe" id="a-geb" name="geburtsdatum" type="date" /></div>
          </div>
        </>
      )}
      <fieldset class="a-rollen">
        <legend>Zusätzliche Rollen (optional)</legend>
        {ROLLEN_WAEHLBAR.map((r) => (
          <label class="chk"><input type="checkbox" name="rollen" value={r} /> {ROLLEN_LABEL[r]}</label>
        ))}
        <input type="hidden" name="rollen" value="mitglied" />
      </fieldset>
      {hatAufnahmebeitrag && (
        <label class="chk" style="margin:0 0 0.6rem;">
          <input type="checkbox" name="aufnahme_kassiert" checked />
          Aufnahmebeitrag ({aufnahmebeitragEuro.toLocaleString('de-DE', { style: 'currency', currency: 'EUR' })}) bar kassiert → in die Kasse buchen
        </label>
      )}
      <p style="color:var(--ink-soft);font-size:0.88rem;margin:0 0 0.8rem;">
        {privacy
          ? 'Ein Startpasswort wird erzeugt und danach angezeigt — bitte zusammen mit der Mitgliedsnummer offline an das Mitglied weitergeben.'
          : 'Ein Startpasswort wird automatisch erzeugt und danach angezeigt (per Mail, falls SMTP eingerichtet).'}
      </p>
      <button class="knopf" type="submit">Mitglied anlegen</button>
    </form>
  </details>

  <form class="suche" method="get" action="/mitglieder/verwaltung" role="search">
    <div class="suche-feld">
      <input id="q" name="q" type="search" inputmode="search" value={q} autocomplete="off"
        placeholder="Name, Nummer oder E-Mail…" aria-label="Mitglied suchen" />
      <button class="knopf-sek" type="button" id="qr-scan" hidden>Ausweis scannen</button>
      <button class="knopf" type="submit">Suchen</button>
    </div>
    {q && <a class="suche-reset" href="/mitglieder/verwaltung">Zurücksetzen</a>}
  </form>

  <div class="scan-overlay" id="scan-overlay" hidden>
    <div class="scan-kasten">
      <p class="scan-hinweis">QR-Code des Mitgliedsausweises vor die Kamera halten.</p>
      <video id="scan-video" playsinline autoplay muted></video>
      <p class="scan-fehler" id="scan-fehler" hidden></p>
      <button class="knopf-sek" type="button" id="scan-abbruch">Abbrechen</button>
    </div>
  </div>

  <p class="anzahl">
    {treffer.length} von {alle.length} Mitgliedern{q ? ` für „${q}"` : ''}.
    {treffer.length > 0 && (
      <> · <a href={`/mitglieder/verwaltung/karten${q ? `?q=${encodeURIComponent(q)}` : ''}`}>QR-Ausweise drucken</a></>
    )}
  </p>

  {treffer.length === 0 ? (
    <p style="color:var(--ink-soft);">Keine Treffer. Anderen Suchbegriff versuchen.</p>
  ) : (
    <ul class="liste">
      {trefferSeite.map((m) => (
        <li>
          <a class="zeile" href={`/mitglieder/verwaltung/${m.id}`}>
            <span class="zeile-nr">{m.mitgliedsnummer || '—'}</span>
            <span class="zeile-mitte">
              <span class="zeile-name">
                {anzeigeName(m)}
                {effektiverStatus(m, berlinTag()) !== 'aktiv' && (
                  <span class:list={['zeile-status', `st-${effektiverStatus(m, berlinTag())}`]}>{STATUS_LABEL[effektiverStatus(m, berlinTag())]}</span>
                )}
              </span>
              {rollenKurz(m.rollen).length > 0 && (
                <span class="zeile-rollen">{rollenKurz(m.rollen).join(' · ')}</span>
              )}
            </span>
            <span class="zeile-pfeil" aria-hidden="true">›</span>
          </a>
        </li>
      ))}
    </ul>
  )}
  {seitenGesamt > 1 && (
    <nav class="seiten" aria-label="Mitgliederliste Seiten">
      {seite > 1 ? <a class="knopf-sek" href={seitenUrl(seite - 1)}>‹ Zurück</a> : <span />}
      <span>Seite {seite} von {seitenGesamt}</span>
      {seite < seitenGesamt ? <a class="knopf-sek" href={seitenUrl(seite + 1)}>Weiter ›</a> : <span />}
    </nav>
  )}
</Basis>

<script is:inline>
  // Ausweis-Scan: QR-Inhalt (Mitgliedsnummer) ins Suchfeld und abschicken -
  // ein exakter Nummern-Treffer leitet serverseitig direkt zur Person.
  (() => {
    const knopf = document.getElementById('qr-scan');
    const overlay = document.getElementById('scan-overlay');
    const video = document.getElementById('scan-video');
    const fehlerEl = document.getElementById('scan-fehler');
    const abbruch = document.getElementById('scan-abbruch');
    const feld = document.getElementById('q');
    const form = feld?.closest('form');
    if (!knopf || !overlay || !video || !feld || !form) return;
    if (!('BarcodeDetector' in window) || !navigator.mediaDevices?.getUserMedia) return;
    knopf.hidden = false;

    let stream = null, aktiv = false;
    const zu = () => {
      aktiv = false; overlay.hidden = true;
      if (stream) stream.getTracks().forEach((t) => t.stop());
      stream = null; video.srcObject = null;
    };
    knopf.addEventListener('click', async () => {
      if (fehlerEl) fehlerEl.hidden = true;
      overlay.hidden = false;
      try {
        stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' }, audio: false });
      } catch {
        if (fehlerEl) { fehlerEl.textContent = 'Kamera nicht verfügbar oder Zugriff abgelehnt.'; fehlerEl.hidden = false; }
        return;
      }
      video.srcObject = stream; aktiv = true;
      const detector = new BarcodeDetector({ formats: ['qr_code'] });
      const pruefe = async () => {
        if (!aktiv) return;
        try {
          const codes = video.readyState >= 2 ? await detector.detect(video) : [];
          const wert = codes[0]?.rawValue?.trim();
          if (wert) { feld.value = wert; zu(); form.submit(); return; }
        } catch { /* Frame nicht lesbar - weiter */ }
        setTimeout(pruefe, 150);
      };
      pruefe();
    });
    abbruch?.addEventListener('click', zu);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) zu(); });
  })();
</script>

<style>
  .eingabe { width: 100%; padding: 0.55rem 0.65rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--bg-rein); color: var(--ink); font: inherit; }
  .feld { margin: 0 0 0.6rem; }
  .feld label { display: block; font-size: 0.9rem; color: var(--ink-soft); margin-bottom: 0.2rem; }
  .feld-reihe { display: flex; gap: 1rem; flex-wrap: wrap; }
  .feld-reihe .feld { flex: 1 1 9rem; }
  .a-rollen { border: 1px solid var(--line); border-radius: var(--radius); padding: 0.6rem 0.9rem; margin: 0 0 0.8rem; }
  .a-rollen legend { font-size: 0.85rem; color: var(--ink-soft); padding: 0 0.4rem; }
  .chk { display: inline-flex; align-items: center; gap: 0.5rem; margin-right: 1rem; font-size: 0.95rem; min-height: 40px; }
  .chk input { width: 1.2rem; height: 1.2rem; flex: none; }
  @media (max-width: 700px) { .a-rollen { display: flex; flex-direction: column; } .chk { margin-right: 0; min-height: 44px; } }
  .suche { max-width: var(--mass); margin: 0 0 0.8rem; }
  .suche-feld { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .suche-feld input {
    flex: 1 1 12rem; min-width: 0;
    padding: 0.6rem 0.7rem; border: 1px solid var(--line); border-radius: var(--radius);
    background: var(--bg-rein); color: var(--ink); font: inherit;
  }
  .suche-reset { display: inline-block; margin-top: 0.5rem; font-size: 0.9rem; color: var(--ink-soft); }
  .anzahl { color: var(--ink-soft); font-size: 0.92rem; margin: 0 0 0.8rem; }
  .datenwarnung { max-width: var(--mass); }
  .datenwarnung summary { cursor: pointer; font-weight: 700; }
  .datenwarnung ul { margin-bottom: 0; }
  .datenwarnung p { margin-bottom: 0; }
  .datenwarnung a { min-height: 44px; display: inline-flex; align-items: center; }
  .seiten { max-width: var(--mass); display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 0.8rem; margin-top: 1rem; }
  .seiten > :last-child { justify-self: end; }
  .liste { list-style: none; padding: 0; margin: 0; max-width: var(--mass); }
  .zeile {
    display: flex; align-items: center; gap: 0.9rem;
    padding: 0.8rem 0.9rem; border: 1px solid var(--line); border-radius: var(--radius);
    background: var(--bg-rein); text-decoration: none; color: var(--ink); margin: 0 0 0.4rem;
    min-height: 44px;
  }
  .zeile:hover { border-color: var(--accent); }
  .zeile-nr { font-family: var(--font-display); font-weight: 600; color: var(--brand-strong); flex: none; min-width: 3.6rem; }
  .zeile-mitte { display: flex; flex-direction: column; gap: 0.1rem; min-width: 0; flex: 1 1 auto; }
  .zeile-name { font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .zeile-rollen { font-size: 0.8rem; color: var(--accent); }
  .zeile-status { margin-left: 0.5rem; font-size: 0.68rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; padding: 0.1rem 0.45rem; border-radius: 999px; border: 1px solid currentColor; color: var(--ink-soft); vertical-align: middle; }
  .zeile-status.st-ruhend, .zeile-status.st-gekuendigt { color: var(--accent); }
  .zeile-status.st-ausgetreten { color: var(--gefahr); }
  .zeile-pfeil { flex: none; color: var(--ink-soft); font-size: 1.4rem; }

  .scan-overlay { position: fixed; inset: 0; z-index: 60; background: rgba(0,0,0,0.72); display: flex; align-items: center; justify-content: center; padding: 1rem; }
  .scan-overlay[hidden] { display: none; }
  .scan-kasten { background: var(--bg); border-radius: var(--radius); padding: 1rem; max-width: 26rem; width: 100%; display: grid; gap: 0.8rem; justify-items: center; }
  .scan-hinweis { margin: 0; font-size: 0.95rem; text-align: center; }
  #scan-video { width: 100%; max-height: 60vh; border-radius: var(--radius); background: #000; }
  .scan-fehler { margin: 0; color: var(--gefahr); font-size: 0.92rem; text-align: center; }
</style>
