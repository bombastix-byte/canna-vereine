---
import Basis from '../../layouts/Basis.astro';
import MitgliedNav from '../../components/MitgliedNav.astro';
import UnterNav from '../../components/UnterNav.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../lib/pb';
import { darfVerwalten, ROLLEN_LABEL, type Rolle } from '../../lib/rollen';

// Mitgliederverwaltung: Suche + Liste. Bearbeitet wird auf der Detailseite
// (/mitglieder/verwaltung/[id]). Skaliert auf mehrere hundert Mitglieder.
// Nur Vorstand.
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
const { pb, mitglied } = ergebnis;
if (!darfVerwalten(mitglied.rollen)) return Astro.redirect('/mitglieder/bereich?fehler=keinzugriff', 303);

interface UserRow {
  id: string;
  name?: string;
  email: string;
  mitgliedsnummer?: string;
  rollen?: string[];
}

// Suchbegriff: freier Text ODER exakte Mitgliedsnummer (vom Ausweis-Scan).
const q = (Astro.url.searchParams.get('q') ?? '').trim();

let alle: UserRow[] = [];
try {
  alle = (await pb.collection('users').getFullList({
    fields: 'id,name,email,mitgliedsnummer,rollen',
    sort: 'mitgliedsnummer,name',
  })) as UserRow[];
} catch {
  alle = [];
}

const norm = (s: string) => s.toLowerCase();
const treffer = q
  ? alle.filter((m) => {
      const nq = norm(q);
      return (
        norm(m.mitgliedsnummer ?? '').includes(nq) ||
        norm(m.name ?? '').includes(nq) ||
        norm(m.email ?? '').includes(nq)
      );
    })
  : alle;

// Ein einziger, exakter Nummern-Treffer (typischer Scan) -> direkt zur Person.
const exakt = q
  ? alle.find((m) => norm(m.mitgliedsnummer ?? '') === norm(q))
  : null;
if (exakt) return Astro.redirect(`/mitglieder/verwaltung/${exakt.id}`, 303);

const rollenKurz = (r?: string[]) =>
  (r ?? []).filter((x) => x !== 'mitglied').map((x) => ROLLEN_LABEL[x as Rolle] ?? x);

const angelegt = Astro.url.searchParams.get('angelegt');
const geloescht = Astro.url.searchParams.get('geloescht');
---

<Basis titel="Mitgliederverwaltung" beschreibung="Mitglieder suchen und verwalten.">
  <MitgliedNav rollen={mitglied.rollen} />
  <p class="eyebrow">Vereinsarbeit · nur Vorstand</p>
  <UnterNav punkte={[{ label: 'Mitglieder & Rollen', href: '/mitglieder/verwaltung' }, { label: 'Anträge', href: '/mitglieder/antraege' }, { label: 'Beiträge', href: '/mitglieder/beitraege' }, { label: 'Nachricht', href: '/mitglieder/nachricht' }]} />
  <h1 style="margin-bottom:0.4rem;">Mitglieder</h1>
  <p class="einleitung">
    Nach Name, Mitgliedsnummer oder E-Mail suchen — oder den Mitgliedsausweis
    scannen. Zum Bearbeiten das Mitglied öffnen.
  </p>

  {geloescht && <p class="hinweis" role="status">Mitglied gelöscht.</p>}
  {angelegt && <p class="hinweis" role="status">Mitglied angelegt.</p>}

  <form class="suche" method="get" action="/mitglieder/verwaltung" role="search">
    <div class="suche-feld">
      <input id="q" name="q" type="search" inputmode="search" value={q} autocomplete="off"
        placeholder="Name, Nummer oder E-Mail…" aria-label="Mitglied suchen" />
      <button class="knopf-sek" type="button" id="qr-scan" hidden>Ausweis scannen</button>
      <button class="knopf" type="submit">Suchen</button>
    </div>
    {q && <a class="suche-reset" href="/mitglieder/verwaltung">Zurücksetzen</a>}
  </form>

  <div class="scan-overlay" id="scan-overlay" hidden>
    <div class="scan-kasten">
      <p class="scan-hinweis">QR-Code des Mitgliedsausweises vor die Kamera halten.</p>
      <video id="scan-video" playsinline autoplay muted></video>
      <p class="scan-fehler" id="scan-fehler" hidden></p>
      <button class="knopf-sek" type="button" id="scan-abbruch">Abbrechen</button>
    </div>
  </div>

  <p class="anzahl">
    {treffer.length} von {alle.length} Mitgliedern{q ? ` für „${q}"` : ''}.
    {treffer.length > 0 && (
      <> · <a href={`/mitglieder/verwaltung/karten${q ? `?q=${encodeURIComponent(q)}` : ''}`}>QR-Ausweise drucken</a></>
    )}
  </p>

  {treffer.length === 0 ? (
    <p style="color:var(--ink-soft);">Keine Treffer. Anderen Suchbegriff versuchen.</p>
  ) : (
    <ul class="liste">
      {treffer.map((m) => (
        <li>
          <a class="zeile" href={`/mitglieder/verwaltung/${m.id}`}>
            <span class="zeile-nr">{m.mitgliedsnummer || '—'}</span>
            <span class="zeile-mitte">
              <span class="zeile-name">{m.name || m.email}</span>
              {rollenKurz(m.rollen).length > 0 && (
                <span class="zeile-rollen">{rollenKurz(m.rollen).join(' · ')}</span>
              )}
            </span>
            <span class="zeile-pfeil" aria-hidden="true">›</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</Basis>

<script is:inline>
  // Ausweis-Scan: QR-Inhalt (Mitgliedsnummer) ins Suchfeld und abschicken -
  // ein exakter Nummern-Treffer leitet serverseitig direkt zur Person.
  (() => {
    const knopf = document.getElementById('qr-scan');
    const overlay = document.getElementById('scan-overlay');
    const video = document.getElementById('scan-video');
    const fehlerEl = document.getElementById('scan-fehler');
    const abbruch = document.getElementById('scan-abbruch');
    const feld = document.getElementById('q');
    const form = feld?.closest('form');
    if (!knopf || !overlay || !video || !feld || !form) return;
    if (!('BarcodeDetector' in window) || !navigator.mediaDevices?.getUserMedia) return;
    knopf.hidden = false;

    let stream = null, aktiv = false;
    const zu = () => {
      aktiv = false; overlay.hidden = true;
      if (stream) stream.getTracks().forEach((t) => t.stop());
      stream = null; video.srcObject = null;
    };
    knopf.addEventListener('click', async () => {
      if (fehlerEl) fehlerEl.hidden = true;
      overlay.hidden = false;
      try {
        stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' }, audio: false });
      } catch {
        if (fehlerEl) { fehlerEl.textContent = 'Kamera nicht verfügbar oder Zugriff abgelehnt.'; fehlerEl.hidden = false; }
        return;
      }
      video.srcObject = stream; aktiv = true;
      const detector = new BarcodeDetector({ formats: ['qr_code'] });
      const pruefe = async () => {
        if (!aktiv) return;
        try {
          const codes = video.readyState >= 2 ? await detector.detect(video) : [];
          const wert = codes[0]?.rawValue?.trim();
          if (wert) { feld.value = wert; zu(); form.submit(); return; }
        } catch { /* Frame nicht lesbar - weiter */ }
        setTimeout(pruefe, 150);
      };
      pruefe();
    });
    abbruch?.addEventListener('click', zu);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) zu(); });
  })();
</script>

<style>
  .suche { max-width: var(--mass); margin: 0 0 0.8rem; }
  .suche-feld { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .suche-feld input {
    flex: 1 1 12rem; min-width: 0;
    padding: 0.6rem 0.7rem; border: 1px solid var(--line); border-radius: var(--radius);
    background: var(--bg-rein); color: var(--ink); font: inherit;
  }
  .suche-reset { display: inline-block; margin-top: 0.5rem; font-size: 0.9rem; color: var(--ink-soft); }
  .anzahl { color: var(--ink-soft); font-size: 0.92rem; margin: 0 0 0.8rem; }
  .liste { list-style: none; padding: 0; margin: 0; max-width: var(--mass); }
  .zeile {
    display: flex; align-items: center; gap: 0.9rem;
    padding: 0.8rem 0.9rem; border: 1px solid var(--line); border-radius: var(--radius);
    background: var(--bg-rein); text-decoration: none; color: var(--ink); margin: 0 0 0.4rem;
    min-height: 44px;
  }
  .zeile:hover { border-color: var(--accent); }
  .zeile-nr { font-family: var(--font-display); font-weight: 600; color: var(--brand-strong); flex: none; min-width: 3.6rem; }
  .zeile-mitte { display: flex; flex-direction: column; gap: 0.1rem; min-width: 0; flex: 1 1 auto; }
  .zeile-name { font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .zeile-rollen { font-size: 0.8rem; color: var(--accent); }
  .zeile-pfeil { flex: none; color: var(--ink-soft); font-size: 1.4rem; }

  .scan-overlay { position: fixed; inset: 0; z-index: 60; background: rgba(0,0,0,0.72); display: flex; align-items: center; justify-content: center; padding: 1rem; }
  .scan-overlay[hidden] { display: none; }
  .scan-kasten { background: var(--bg); border-radius: var(--radius); padding: 1rem; max-width: 26rem; width: 100%; display: grid; gap: 0.8rem; justify-items: center; }
  .scan-hinweis { margin: 0; font-size: 0.95rem; text-align: center; }
  #scan-video { width: 100%; max-height: 60vh; border-radius: var(--radius); background: #000; }
  .scan-fehler { margin: 0; color: var(--gefahr); font-size: 0.92rem; text-align: center; }
</style>
