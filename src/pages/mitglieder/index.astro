---
import Basis from '../../layouts/Basis.astro';
import { site } from '../../config';
import { mitgliedAusToken, AUTH_COOKIE } from '../../lib/pb';
import { startseiteFuer } from '../../lib/mitglied-nav';
import { uebersetzer } from '../../lib/i18n';
import SprachWahl from '../../components/SprachWahl.astro';

// Serverseitig, damit Status-/Fehlermeldungen und bereits angemeldete
// Mitglieder behandelt werden können.
export const prerender = false;

// Bereits angemeldet? Direkt zur rollengerechten Startseite (Mitglieder auf
// den Ausweis, Personal aufs Dashboard).
const bereits = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (bereits) {
  return Astro.redirect(startseiteFuer(bereits.mitglied.rollen), 303);
}

const fehler = Astro.url.searchParams.get('fehler');
const abgemeldet = Astro.url.searchParams.get('abgemeldet');

const t = uebersetzer(Astro.locals.sprache ?? 'de');
const fehlertext: Record<string, string> = {
  fehlend: t('login.fehler.fehlend'),
  ungueltig: t('login.fehler.ungueltig'),
  anmeldung: t('login.fehler.anmeldung'),
};
const meldung = fehler ? fehlertext[fehler] ?? fehlertext.anmeldung : null;
---

<Basis
  titel="Mitgliederbereich"
  beschreibung="Anmeldung zum internen Mitgliederbereich."
  anonym={site.oeffentlich === false}
>
  <div class="seitenkopf">
    <p class="eyebrow">{t('nav.bereich')}</p>
    <h1 style="margin-bottom:0.6rem;">{t('login.titel')}</h1>
    <p class="einleitung">{t('login.intro')}</p>
    <SprachWahl />
  </div>

  {
    meldung && (
      <p class="hinweis hinweis--fehler" role="alert">
        {meldung}
      </p>
    )
  }
  {
    abgemeldet && (
      <p class="hinweis" role="status">{t('login.abgemeldet')}</p>
    )
  }

  <form class="kasten" method="post" action="/mitglieder/anmelden">
    <div class="feld">
      {site.login_modus === 'mitgliedsnummer' ? (
        <>
          <label for="kennung">{t('login.mitgliedsnummer')}</label>
          <input id="kennung" name="kennung" type="text" autocomplete="username" autocapitalize="characters" required />
        </>
      ) : (
        <>
          <label for="email">{t('login.email')}</label>
          <input id="email" name="email" type="email" autocomplete="username" required />
        </>
      )}
    </div>
    <div class="feld">
      <label for="passwort">{t('login.passwort')}</label>
      <input
        id="passwort"
        name="passwort"
        type="password"
        autocomplete="current-password"
        required
      />
    </div>
    <button class="knopf" type="submit">{t('login.knopf')}</button>
  </form>

  {site.login_modus === 'mitgliedsnummer' && (
    <p style="color:var(--ink-soft);font-size:0.9rem;max-width:var(--mass);">{t('login.reset_hinweis')}</p>
  )}
  {site.oeffentlich !== false && (
    <p style="color:var(--ink-soft);font-size:0.95rem;">
      Zugangsdaten erhalten Mitglieder vom Vorstand. Bei Problemen wenden Sie
      sich an die unter <a href="/kontakt">Kontakt</a> genannte Adresse.
    </p>
  )}
</Basis>
