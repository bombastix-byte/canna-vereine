---
import Basis from '../../layouts/Basis.astro';
import { site } from '../../config';
import { mitgliedAusToken, AUTH_COOKIE } from '../../lib/pb';

// Serverseitig, damit Status-/Fehlermeldungen und bereits angemeldete
// Mitglieder behandelt werden können.
export const prerender = false;

// Bereits angemeldet? Direkt in den Bereich.
const bereits = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (bereits) {
  return Astro.redirect('/mitglieder/bereich', 303);
}

const fehler = Astro.url.searchParams.get('fehler');
const abgemeldet = Astro.url.searchParams.get('abgemeldet');

const fehlertext: Record<string, string> = {
  fehlend: 'Bitte E-Mail-Adresse und Passwort eingeben.',
  ungueltig: 'Anmeldung nicht möglich. Bitte prüfen Sie Ihre Zugangsdaten.',
  anmeldung: 'Bitte melden Sie sich an, um den Mitgliederbereich zu sehen.',
};
const meldung = fehler ? fehlertext[fehler] ?? fehlertext.anmeldung : null;
---

<Basis
  titel="Mitgliederbereich"
  beschreibung="Anmeldung zum internen Mitgliederbereich."
>
  <div class="seitenkopf">
    <p class="eyebrow">Mitgliederbereich</p>
    <h1 style="margin-bottom:0.6rem;">Anmeldung</h1>
    <p class="einleitung">
      Dieser Bereich ist Mitgliedern vorbehalten. Bitte melden Sie sich mit
      Ihren Zugangsdaten an.
    </p>
  </div>

  {
    meldung && (
      <p class="hinweis hinweis--fehler" role="alert">
        {meldung}
      </p>
    )
  }
  {
    abgemeldet && (
      <p class="hinweis" role="status">Sie wurden abgemeldet.</p>
    )
  }

  <form class="kasten" method="post" action="/mitglieder/anmelden">
    <div class="feld">
      <label for="email">E-Mail-Adresse</label>
      <input id="email" name="email" type="email" autocomplete="username" required />
    </div>
    <div class="feld">
      <label for="passwort">Passwort</label>
      <input
        id="passwort"
        name="passwort"
        type="password"
        autocomplete="current-password"
        required
      />
    </div>
    <button class="knopf" type="submit">Anmelden</button>
  </form>

  <p style="color:var(--ink-soft);font-size:0.95rem;">
    Zugangsdaten erhalten Mitglieder vom Vorstand.
    {site.oeffentlich === false ? (
      <>Bei Problemen hilft der Vorstand persönlich im Vereinsraum weiter.</>
    ) : (
      <>Bei Problemen wenden Sie sich an die unter <a href="/kontakt">Kontakt</a> genannte Adresse.</>
    )}
  </p>
</Basis>
