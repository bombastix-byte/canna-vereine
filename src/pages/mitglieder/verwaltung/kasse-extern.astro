---
import Basis from '../../../layouts/Basis.astro';
import MitgliedNav from '../../../components/MitgliedNav.astro';
import UnterNav from '../../../components/UnterNav.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../../lib/pb';
import { darfVerwalten } from '../../../lib/rollen';
import { verwaltungTabs } from '../../../lib/mitglied-nav';
import { konnektorAktiv } from '../../../lib/kassen-konnektor';

// Übertragungs-Protokoll der externen Kassen-Anbindung: zeigt jeden Barvorgang
// samt Zustellstatus, erlaubt erneute Zustellung fehlgeschlagener Vorgänge.
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
const { pb, mitglied } = ergebnis;
if (!darfVerwalten(mitglied.rollen)) return Astro.redirect('/mitglieder/bereich?fehler=keinzugriff', 303);

const cfg = Astro.locals.kasseExtern;
const aktiv = konnektorAktiv(cfg);

interface Vorgang {
  id: string; created: string; art: string; mitgliedsnummer?: string; belegnr?: string;
  betrag_euro?: number; datum?: string; extern_status?: string; extern_antwort?: string;
}
let vorgaenge: Vorgang[] = [];
let offen = 0;
try {
  const res = await pb.collection('kassenvorgaenge').getList(1, 100, { sort: '-created' });
  vorgaenge = res.items as unknown as Vorgang[];
} catch { vorgaenge = []; }
try {
  offen = (await pb.collection('kassenvorgaenge').getList(1, 1, { filter: 'extern_status = "fehler"' })).totalItems;
} catch { offen = 0; }

const ok = Astro.url.searchParams.get('ok');
const eur = (n?: number) => (n ?? 0).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const wann = (s?: string) => (s ? new Date(s).toLocaleString('de-DE', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' }) : '');
const statusLabel: Record<string, string> = { gesendet: 'gesendet', fehler: 'Fehler', offen: 'offen', lokal: 'nur lokal' };
---

<Basis titel="Externe Kasse" beschreibung="Übertragung der Barvorgänge an die externe Kasse.">
  <MitgliedNav rollen={mitglied.rollen} />
  <p class="eyebrow">Vereinsarbeit · nur Vorstand</p>
  <UnterNav punkte={verwaltungTabs(Astro.locals.funktionen)} />
  <h1 style="margin-bottom:0.4rem;">Externe Kasse — Übertragung</h1>
  <p class="einleitung">
    Jeder Barvorgang (Abgabe-Beitrag, Aufnahmebeitrag) wird hier protokolliert und
    — wenn eine externe Kasse angebunden ist — dorthin gemeldet. Fehlgeschlagene
    Zustellungen kannst du erneut senden. Die Anbindung stellst du unter
    <a href="/mitglieder/verwaltung/module">Module</a> ein.
  </p>

  {ok && <p class="hinweis" role="status">Erneut zugestellt.</p>}
  <p class="status-zeile">
    Anbindung: <strong>{aktiv ? `${cfg?.typ} → ${cfg?.url}` : 'keine (nur lokales Protokoll)'}</strong>
    {offen > 0 && <span class="warn"> · {offen} fehlgeschlagen</span>}
  </p>

  {vorgaenge.length === 0 ? (
    <p style="color:var(--ink-soft);">Noch keine Barvorgänge erfasst.</p>
  ) : (
    <table class="tabelle">
      <thead><tr><th>Zeit</th><th>Art</th><th>Mitglied</th><th class="r">Betrag</th><th>Status</th><th></th></tr></thead>
      <tbody>
        {vorgaenge.map((v) => (
          <tr>
            <td>{wann(v.created)}</td>
            <td>{v.art === 'aufnahme' ? 'Aufnahme' : 'Abgabe'}{v.belegnr ? ` · ${v.belegnr}` : ''}</td>
            <td>{v.mitgliedsnummer || '—'}</td>
            <td class="r">{eur(v.betrag_euro)} €</td>
            <td>
              <span class:list={['st', `st-${v.extern_status}`]}>{statusLabel[v.extern_status ?? ''] ?? v.extern_status}</span>
              {v.extern_status === 'fehler' && v.extern_antwort && <span class="antwort" title={v.extern_antwort}> ⓘ</span>}
            </td>
            <td>
              {aktiv && v.extern_status === 'fehler' && (
                <form method="post" action="/mitglieder/verwaltung/kasse-extern-retry" style="margin:0;">
                  <input type="hidden" name="id" value={v.id} />
                  <button class="knopf-sek" type="submit" style="padding:0.25rem 0.6rem;font-size:0.85rem;">Erneut senden</button>
                </form>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</Basis>

<style>
  .status-zeile { max-width: var(--mass); color: var(--ink-soft); margin: 0 0 1rem; }
  .warn { color: var(--gefahr); font-weight: 600; }
  .tabelle { width: 100%; max-width: var(--mass); border-collapse: collapse; font-size: 0.95rem; }
  .tabelle th, .tabelle td { text-align: left; padding: 0.45rem 0.55rem; border-bottom: 1px solid var(--line); }
  .tabelle .r { text-align: right; }
  .st { font-size: 0.8rem; padding: 0.05rem 0.5rem; border-radius: 999px; border: 1px solid var(--line); color: var(--ink-soft); }
  .st-gesendet { border-color: var(--ok); color: var(--ok); }
  .st-fehler { border-color: var(--gefahr); color: var(--gefahr); }
</style>
