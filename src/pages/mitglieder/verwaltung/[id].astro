---
import Basis from '../../../layouts/Basis.astro';
import MitgliedNav from '../../../components/MitgliedNav.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../../lib/pb';
import { darfVerwalten, ROLLEN, ROLLEN_LABEL } from '../../../lib/rollen';
import { MITGLIED_STATUS, STATUS_LABEL, effektiverStatus } from '../../../lib/status';
import { berlinTag } from '../../../lib/ausgabe';
const __fn = Astro.locals.funktionen;
const hatBeitraege = __fn ? __fn.beitraege !== false : true;
// Detail-/Bearbeitungsseite eines Mitglieds (aus der Suche geöffnet).
// Nur Vorstand.
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
const { pb, mitglied } = ergebnis;
if (!darfVerwalten(mitglied.rollen)) return Astro.redirect('/mitglieder/bereich?fehler=keinzugriff', 303);

const { id } = Astro.params;
let m;
try {
  m = await pb.collection('users').getOne(id!);
} catch {
  return Astro.redirect('/mitglieder/verwaltung?fehler=nichtgefunden', 303);
}

const ok = Astro.url.searchParams.get('ok');
const neu = Astro.url.searchParams.get('neu') === '1';
const startpw = Astro.url.searchParams.get('pw') ?? '';
const pwreset = Astro.url.searchParams.get('pwreset') ?? '';
const fehler = Astro.url.searchParams.get('fehler');
const fehlertext: Record<string, string> = {
  selbst: 'Das eigene Konto kann nicht gelöscht werden.',
  loeschen: 'Löschen fehlgeschlagen. Bitte erneut versuchen.',
  status: 'Status konnte nicht gesetzt werden.',
  pwreset: 'Passwort zurücksetzen fehlgeschlagen. Bitte erneut versuchen.',
};
const fmeldung = fehler ? (fehlertext[fehler] ?? 'Speichern fehlgeschlagen.') : null;
const isoTag = (s?: string) => (s ? s.slice(0, 10) : '');
const rollen: string[] = Array.isArray(m.rollen) ? m.rollen : [];
const heute = berlinTag();
const statusJetzt = effektiverStatus(m, heute);
const statusGesetzt = (m.mitglied_status as string) || 'aktiv';
---

<Basis titel={`${m.name || m.email}`} beschreibung="Mitglied bearbeiten.">
  <MitgliedNav rollen={mitglied.rollen} />
  <p class="eyebrow">Vereinsarbeit · nur Vorstand</p>
  <p class="zurueck"><a href="/mitglieder/verwaltung">‹ Zurück zur Suche</a></p>
  <h1 style="margin-bottom:0.2rem;">
    {m.name || m.email}
    <span class:list={['status-marke', `status-${statusJetzt}`]}>{STATUS_LABEL[statusJetzt]}</span>
  </h1>
  <p class="einleitung" style="margin-top:0.2rem;">{m.email}</p>
  <p class="karte-link"><a href={`/mitglieder/verwaltung/${m.id}/karte`}>→ QR-Ausweis (Karte) drucken</a></p>

  {ok && <p class="hinweis" role="status">Gespeichert.</p>}
  {fmeldung && <p class="hinweis hinweis--fehler" role="alert">{fmeldung}</p>}
  {neu && (
    <div class="hinweis pw-box" role="status">
      <strong>Mitglied angelegt.</strong> Startpasswort zum Weitergeben:
      <code class="pw">{startpw}</code>
      <span class="pw-note">Bitte notieren — es wird nur jetzt angezeigt. Das Mitglied ändert es beim ersten Login.</span>
    </div>
  )}
  {pwreset && (
    <div class="hinweis pw-box" role="status">
      <strong>Passwort zurückgesetzt.</strong> Neues Startpasswort:
      <code class="pw">{pwreset}</code>
      <span class="pw-note">Bitte notieren und dem Mitglied weitergeben — es wird nur jetzt angezeigt.</span>
    </div>
  )}

  <form method="post" action="/mitglieder/verwaltung/speichern">
    <input type="hidden" name="mitglied" value={m.id} />

    <section class="kasten">
      <h2 class="abschnitt">Stammdaten</h2>
      <div class="feld-reihe">
        <div class="feld">
          <label for="f-vorname">Vorname</label>
          <input id="f-vorname" name="vorname" type="text" value={m.vorname ?? ''} placeholder="leer = aus Name" />
        </div>
        <div class="feld">
          <label for="f-nachname">Nachname</label>
          <input id="f-nachname" name="nachname" type="text" value={m.nachname ?? ''} placeholder="leer = aus Name" />
        </div>
      </div>
      <p class="feld-hinweis">Bleiben Vorname/Nachname leer, werden sie für den Ausweis automatisch aus dem Namen „{m.name || m.email}" abgeleitet.</p>
      <div class="feld-reihe">
        <div class="feld">
          <label for="f-nr">Mitgliedsnummer</label>
          <input id="f-nr" name="mitgliedsnummer" type="text" value={m.mitgliedsnummer ?? ''} />
        </div>
        <div class="feld">
          <label for="f-geb">Geburtsdatum</label>
          <input id="f-geb" name="geburtsdatum" type="date" value={isoTag(m.geburtsdatum)} />
        </div>
        {hatBeitraege && (
          <div class="feld">
            <label for="f-bis">Beitrag bezahlt bis</label>
            <input id="f-bis" name="beitrag_bis" type="date" value={isoTag(m.beitrag_bis)} />
          </div>
        )}
      </div>
    </section>

    {hatBeitraege && (
    <section class="kasten">
      <h2 class="abschnitt">Beitrag &amp; SEPA-Mandat</h2>
      <div class="feld-reihe">
        <div class="feld">
          <label for="f-monat">Monatsbeitrag €</label>
          <input id="f-monat" name="beitrag_monatlich" type="number" min="0" step="0.01" value={m.beitrag_monatlich ?? ''} />
        </div>
        <div class="feld">
          <label for="f-iban">IBAN</label>
          <input id="f-iban" name="iban" type="text" value={m.iban ?? ''} placeholder="DE…" />
        </div>
        <div class="feld">
          <label for="f-bic">BIC (optional)</label>
          <input id="f-bic" name="bic" type="text" value={m.bic ?? ''} />
        </div>
      </div>
      <div class="feld-reihe">
        <div class="feld">
          <label for="f-ref">Mandatsreferenz</label>
          <input id="f-ref" name="mandatsref" type="text" value={m.mandatsref ?? ''} />
        </div>
        <div class="feld">
          <label for="f-mdat">Mandatsdatum</label>
          <input id="f-mdat" name="mandatsdatum" type="date" value={isoTag(m.mandatsdatum)} />
        </div>
      </div>
    </section>
    )}

    <section class="kasten">
      <h2 class="abschnitt">Rollen</h2>
      <p class="rollen-hinweis">Bestimmen, welche Vereinsarbeit dieses Mitglied sieht.</p>
      <div class="rollen">
        {ROLLEN.map((r) => (
          <label class="chk">
            <input type="checkbox" name="rollen" value={r} checked={rollen.includes(r)} />
            {ROLLEN_LABEL[r]}
          </label>
        ))}
      </div>
    </section>

    <button class="knopf" type="submit">Änderungen speichern</button>
  </form>

  <section class="kasten">
    <h2 class="abschnitt">Mitgliedschaft (Status)</h2>
    <p class="rollen-hinweis">
      Schonender Weg statt Löschen: „Ruhend" und „Ausgetreten" sperren die Abgabe
      am Tresen, alle Daten bleiben erhalten. „Gekündigt" bleibt bis zum
      Austrittsdatum abgabeberechtigt und wird danach automatisch als ausgetreten
      geführt.
    </p>
    <form method="post" action="/mitglieder/verwaltung/status">
      <input type="hidden" name="mitglied" value={m.id} />
      <div class="feld-reihe">
        <div class="feld">
          <label for="f-status">Status</label>
          <select id="f-status" name="mitglied_status">
            {MITGLIED_STATUS.map((s) => (
              <option value={s} selected={s === statusGesetzt}>{STATUS_LABEL[s]}</option>
            ))}
          </select>
        </div>
        <div class="feld">
          <label for="f-austritt">Austritt zum (nur bei „Gekündigt")</label>
          <input id="f-austritt" name="austritt_zum" type="date" value={isoTag(m.austritt_zum)} />
        </div>
      </div>
      <div class="feld">
        <label for="f-snotiz">Notiz (optional)</label>
        <input id="f-snotiz" name="status_notiz" type="text" value={m.status_notiz ?? ''} placeholder="z. B. Kündigung eingegangen am …" />
      </div>
      <button class="knopf" type="submit" style="margin-top:0.8rem;">Status setzen</button>
    </form>
    <p class="feld-hinweis" style="margin-top:0.9rem;">
      Präventionshinweise (§ 23): {m.hinweise_bestaetigt_am
        ? `bestätigt am ${new Date(String(m.hinweise_bestaetigt_am).replace(' ', 'T')).toLocaleDateString('de-DE')} (Version ${m.hinweise_version})`
        : 'noch nicht bestätigt'}.
    </p>
  </section>

  {m.id !== mitglied.id && (
    <section class="kasten">
      <h2 class="abschnitt">Passwort zurücksetzen</h2>
      <p class="rollen-hinweis">
        Erzeugt ein neues Startpasswort und zeigt es dir einmalig an — zum
        Weitergeben an das Mitglied (offline). Das alte Passwort wird ungültig.
      </p>
      <form method="post" action="/mitglieder/verwaltung/passwort-reset"
        onsubmit={`return confirm('Passwort von „${(m.name || m.mitgliedsnummer || m.email).replace(/'/g, '')}" wirklich zurücksetzen?')`}>
        <input type="hidden" name="mitglied" value={m.id} />
        <button class="knopf-sek" type="submit">Neues Passwort erzeugen</button>
      </form>
    </section>
  )}

  {m.id !== mitglied.id && (
    <section class="entfernen">
      <h2 class="abschnitt">Mitglied entfernen</h2>
      <p class="entfernen-hinweis">
        <strong>Nur in Ausnahmefällen</strong> (z. B. Doppelanlage). Für reguläre
        Austritte den Status „Ausgetreten" verwenden — das bewahrt die Historie.
        Löscht das Konto endgültig; Abgaben-/Anbaudaten bleiben pseudonym erhalten.
      </p>
      <form method="post" action="/mitglieder/verwaltung/loeschen"
        onsubmit={`return confirm('Mitglied „${(m.name || m.email).replace(/'/g, '')}" wirklich endgültig entfernen?')`}>
        <input type="hidden" name="mitglied" value={m.id} />
        <button class="knopf-gefahr" type="submit">Mitglied endgültig entfernen</button>
      </form>
    </section>
  )}
</Basis>

<style>
  .zurueck { margin: 0 0 0.4rem; }
  .zurueck a { color: var(--ink-soft); text-decoration: none; }
  .zurueck a:hover { color: var(--ink); }
  .karte-link { margin: 0.2rem 0 0.6rem; font-size: 0.95rem; }
  .abschnitt { font-size: 1.05rem; margin: 0 0 0.8rem; }
  .feld-reihe { display: flex; gap: 1rem; flex-wrap: wrap; }
  .feld-reihe .feld { flex: 1 1 9rem; }
  .feld label { display: block; font-size: 0.9rem; color: var(--ink-soft); margin-bottom: 0.2rem; }
  .feld input, .feld select {
    width: 100%; padding: 0.55rem 0.65rem; border: 1px solid var(--line);
    border-radius: var(--radius); background: var(--bg-rein); color: var(--ink); font: inherit;
  }
  .status-marke {
    display: inline-block; vertical-align: middle; margin-left: 0.5rem;
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
    padding: 0.15rem 0.6rem; border-radius: 999px; border: 1px solid var(--line); color: var(--ink-soft);
  }
  .status-marke.status-aktiv { border-color: var(--ok); color: var(--ok); }
  .status-marke.status-ruhend { border-color: var(--accent); color: var(--accent); }
  .status-marke.status-gekuendigt { border-color: var(--accent); color: var(--accent); }
  .status-marke.status-ausgetreten { border-color: var(--gefahr); color: var(--gefahr); }
  .feld-hinweis { color: var(--ink-soft); font-size: 0.85rem; margin: 0 0 0.8rem; }
  .rollen-hinweis { color: var(--ink-soft); font-size: 0.9rem; margin: 0 0 0.6rem; }
  .rollen { display: flex; flex-direction: column; gap: 0.1rem; }
  .chk { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.98rem; min-height: 44px; }
  .chk input { width: 1.2rem; height: 1.2rem; flex: none; }
  .pw-box { display: flex; flex-direction: column; gap: 0.3rem; }
  .pw { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; letter-spacing: 0.03em; color: var(--brand-strong); }
  .pw-note { font-size: 0.85rem; color: var(--ink-soft); }
  .entfernen { max-width: var(--mass); margin: 2rem 0 0; padding: 1rem 1.1rem; border: 1px solid var(--gefahr); border-radius: var(--radius); background: var(--gefahr-bg); }
  .entfernen .abschnitt { color: var(--gefahr); }
  .entfernen-hinweis { color: var(--ink-soft); font-size: 0.9rem; margin: 0 0 0.8rem; }
  .knopf-gefahr {
    display: inline-block; padding: 0.6rem 1rem; border: 1px solid var(--gefahr);
    border-radius: var(--radius); background: transparent; color: var(--gefahr);
    font: inherit; font-weight: 600; cursor: pointer; min-height: 44px;
  }
  .knopf-gefahr:hover { background: var(--gefahr); color: var(--bg-rein); }
</style>
