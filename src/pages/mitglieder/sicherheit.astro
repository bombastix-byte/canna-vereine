---
import Basis from '../../layouts/Basis.astro';
import MitgliedNav from '../../components/MitgliedNav.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../lib/pb';
import { neuesSecret, otpauthUrl } from '../../lib/totp';
import QRCode from 'qrcode-svg';
import { site } from '../../config';
import { uebersetzer } from '../../lib/i18n';

// Zwei-Faktor-Anmeldung einrichten/verwalten (TOTP, Authenticator-App).
// Besonders empfohlen fuer Personal-Konten (Tresen, Anbau, Vorstand).
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
const { pb, mitglied } = ergebnis;

let zf: { id: string; aktiv?: boolean } | null = null;
try {
  zf = await pb.collection('zweifaktor').getFirstListItem(`user="${mitglied.id}"`);
} catch {
  zf = null;
}
const aktiv = !!zf?.aktiv;

// Fuer die Einrichtung: frisches Geheimnis erzeugen und als QR zeigen.
// Gespeichert wird es erst, wenn der erste Code korrekt eingegeben wurde.
const secret = aktiv ? '' : neuesSecret();
const qrSvg = secret
  ? new QRCode({ content: otpauthUrl(site.kurzname, mitglied.email, secret), width: 200, height: 200, padding: 2, ecl: 'M', join: true }).svg()
  : '';

const fehler = Astro.url.searchParams.get('fehler');
const ok = Astro.url.searchParams.get('ok');
const t = uebersetzer(Astro.locals.sprache ?? 'de');
const fehlertext: Record<string, string> = {
  code: t('sich.fehler.code'),
  fehlgeschlagen: t('sich.fehler.fehlgeschlagen'),
};
// Übersetzte Texte fürs Inline-Push-Script (per JSON-Blob übergeben).
const pushTexte = {
  pruefe: t('push.pruefe'),
  unsupported: t('push.unsupported'),
  aktiv: t('push.aktiv'),
  blockiert: t('push.blockiert'),
  inaktiv: t('push.inaktiv'),
  geprueft_fehler: t('push.geprueft_fehler'),
  nicht_eingerichtet: t('push.nicht_eingerichtet'),
  ohne_erlaubnis: t('push.ohne_erlaubnis'),
  jetzt_aktiv: t('push.jetzt_aktiv'),
  speichern_fehler: t('push.speichern_fehler'),
  deaktiviert: t('push.deaktiviert'),
  fehler: t('push.fehler'),
};
const meldung = fehler ? fehlertext[fehler] ?? fehlertext.fehlgeschlagen : null;
---

<Basis titel={t('nav.sicherheit')} beschreibung={t('sich.intro')}>
  <MitgliedNav rollen={mitglied.rollen} />
  <p class="eyebrow">{t('nav.bereich')}</p>
  <h1 style="margin-bottom:0.4rem;">{t('nav.sicherheit')}</h1>
  <p class="einleitung">{t('sich.intro')}</p>

  {meldung && <p class="hinweis hinweis--fehler" role="alert">{meldung}</p>}
  {ok === 'an' && <p class="hinweis" role="status">{t('sich.ok_an')}</p>}
  {ok === 'aus' && <p class="hinweis" role="status">{t('sich.ok_aus')}</p>}

  {aktiv ? (
    <div class="kasten">
      <p><span class="abzeichen abzeichen--ok">{t('sich.aktiv_badge')}</span> {t('sich.aktiv_text')}</p>
      <form method="post" action="/mitglieder/sicherheit/deaktivieren">
        <div class="feld">
          <label for="code">{t('sich.deaktiv_label')}</label>
          <input id="code" name="code" type="text" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required style="max-width:10rem;" />
        </div>
        <button class="knopf-sek" type="submit">{t('sich.deaktiv_btn')}</button>
      </form>
    </div>
  ) : (
    <div class="kasten">
      <h2 style="margin-top:0;">{t('sich.einrichten_h')}</h2>
      <ol style="margin:0 0 1rem;padding-left:1.3rem;">
        <li>{t('sich.schritt1')}</li>
        <li>{t('sich.schritt2')}</li>
        <li>{t('sich.schritt3')}</li>
      </ol>
      <div class="qr" set:html={qrSvg} />
      <p style="color:var(--ink-soft);font-size:0.85rem;">{t('sich.ohne_kamera')} <code>{secret}</code></p>
      <form method="post" action="/mitglieder/sicherheit/aktivieren">
        <input type="hidden" name="secret" value={secret} />
        <div class="feld">
          <label for="code">{t('sich.code_label')}</label>
          <input id="code" name="code" type="text" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autocomplete="one-time-code" style="max-width:10rem;" />
        </div>
        <button class="knopf" type="submit">{t('sich.aktivieren_btn')}</button>
      </form>
    </div>
  )}

  <p style="color:var(--ink-soft);font-size:0.92rem;max-width:var(--mass);">{t('sich.handy_verloren')}</p>

  <h2>{t('sich.benachr_h')}</h2>
  <div class="kasten" id="push-box">
    <p style="margin-top:0;">{t('sich.benachr_text')}</p>
    <p id="push-status" class="push-status">{t('push.pruefe')}</p>
    <div class="push-knoepfe">
      <button class="knopf" type="button" id="push-an" hidden>{t('sich.push_an')}</button>
      <button class="knopf-sek" type="button" id="push-aus" hidden>{t('sich.push_aus')}</button>
    </div>
  </div>
</Basis>

<script id="push-i18n" type="application/json" set:html={JSON.stringify(pushTexte)}></script>
<script is:inline>
  (function () {
    var statusEl = document.getElementById('push-status');
    var anBtn = document.getElementById('push-an');
    var ausBtn = document.getElementById('push-aus');
    if (!statusEl) return;
    var PT = JSON.parse(document.getElementById('push-i18n').textContent);

    function b64ToU8(base64) {
      var pad = '='.repeat((4 - (base64.length % 4)) % 4);
      var s = (base64 + pad).replace(/-/g, '+').replace(/_/g, '/');
      var raw = atob(s);
      var arr = new Uint8Array(raw.length);
      for (var i = 0; i < raw.length; i++) arr[i] = raw.charCodeAt(i);
      return arr;
    }
    function setze(text, an, aus) {
      statusEl.textContent = text;
      anBtn.hidden = !an;
      ausBtn.hidden = !aus;
    }

    if (!('serviceWorker' in navigator) || !('PushManager' in window) || !('Notification' in window)) {
      setze(PT.unsupported, false, false);
      return;
    }

    async function pruefe() {
      try {
        var reg = await navigator.serviceWorker.ready;
        var sub = await reg.pushManager.getSubscription();
        if (sub) setze(PT.aktiv, false, true);
        else if (Notification.permission === 'denied') setze(PT.blockiert, false, false);
        else setze(PT.inaktiv, true, false);
      } catch (e) {
        setze(PT.geprueft_fehler, true, false);
      }
    }

    anBtn.addEventListener('click', async function () {
      anBtn.disabled = true;
      try {
        var vapid = await (await fetch('/mitglieder/push/vapid')).json();
        if (!vapid.konfiguriert || !vapid.key) {
          setze(PT.nicht_eingerichtet, false, false);
          return;
        }
        var perm = await Notification.requestPermission();
        if (perm !== 'granted') { setze(PT.ohne_erlaubnis, true, false); return; }
        var reg = await navigator.serviceWorker.ready;
        var sub = await reg.pushManager.subscribe({ userVisibleOnly: true, applicationServerKey: b64ToU8(vapid.key) });
        var r = await fetch('/mitglieder/push/anmelden', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(sub) });
        if (r.ok) setze(PT.jetzt_aktiv, false, true);
        else setze(PT.speichern_fehler, true, false);
      } catch (e) {
        setze(PT.fehler + ' ' + (e && e.message ? e.message : e), true, false);
      } finally {
        anBtn.disabled = false;
      }
    });

    ausBtn.addEventListener('click', async function () {
      ausBtn.disabled = true;
      try {
        var reg = await navigator.serviceWorker.ready;
        var sub = await reg.pushManager.getSubscription();
        if (sub) {
          await fetch('/mitglieder/push/abmelden', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ endpoint: sub.endpoint }) });
          await sub.unsubscribe();
        }
        setze(PT.deaktiviert, true, false);
      } catch (e) {
        setze(PT.fehler, false, true);
      } finally {
        ausBtn.disabled = false;
      }
    });

    pruefe();
  })();
</script>

<style>
  .qr {
    display: inline-block;
    margin: 0 0 0.6rem;
  }
  .qr :global(svg) {
    background: #fff;
    border-radius: var(--radius);
  }
  .push-status { color: var(--ink-soft); }
  .push-knoepfe { display: flex; gap: 0.8rem; flex-wrap: wrap; }
</style>
