---
import Basis from '../../layouts/Basis.astro';
import MitgliedNav from '../../components/MitgliedNav.astro';
import UnterNav from '../../components/UnterNav.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../lib/pb';
import { site } from '../../config';
import { uebersetzer } from '../../lib/i18n';

// Praevention & Beratung im Mitgliederbereich (Paragraf 23 KCanG:
// Praeventionsbeauftragte Person + Hinweis auf unabhaengige Beratung).
// Ersetzt die frueher oeffentliche Seite, seit der Verein ohne
// Web-Auftritt arbeitet (site.oeffentlich = false).
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
const { mitglied } = ergebnis;
if (Astro.locals.funktionen?.wissen === false) return Astro.redirect('/mitglieder/bereich', 303);
const p = site.praeventionsbeauftragter;
const t = uebersetzer(Astro.locals.sprache ?? 'de');
---

<Basis titel={t('praev.titel')} beschreibung={t('praev.intro')}>
  <MitgliedNav rollen={mitglied.rollen} />
  <p class="eyebrow">{t('nav.bereich')}</p>
  <UnterNav punkte={[{ label: t('wissen.anleitungen'), href: '/mitglieder/anleitungen' }, { label: t('wissen.sortenberichte'), href: '/mitglieder/sortenberichte' }, { label: t('wissen.praevention'), href: '/mitglieder/praevention' }]} />
  <h1 style="margin-bottom:0.4rem;">{t('praev.titel')}</h1>
  <p class="einleitung">{t('praev.intro')}</p>

  <h2>{t('praev.person_h')}</h2>
  <dl class="fakten">
    <dt>{t('praev.name')}</dt>
    <dd>{p.name}</dd>
    <dt>{t('praev.funktion')}</dt>
    <dd>{p.rolle}</dd>
    {p.email && (<><dt>{t('praev.email')}</dt><dd><a href={`mailto:${p.email}`}>{p.email}</a></dd></>)}
    {p.telefon && (<><dt>{t('praev.telefon')}</dt><dd>{p.telefon}</dd></>)}
  </dl>

  <h2>{t('praev.extern_h')}</h2>
  <p>{t('praev.extern_intro')}</p>
  <ul>
    {
      site.externeBeratung.map((b) => (
        <li>
          <strong>{b.name}</strong>: {b.beschreibung}
          {b.telefon && <> {t('praev.telefon_wort')} {b.telefon}.</>}
          {b.url && (
            <> <a href={b.url} rel="noopener">{b.url.replace('https://', '')}</a></>
          )}
        </li>
      ))
    }
  </ul>

  <h2>{t('praev.jugend_h')}</h2>
  <p>{t('praev.jugend_text')}</p>

  <div class="hinweis">{t('praev.krise')}</div>
</Basis>
