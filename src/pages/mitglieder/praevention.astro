---
import Basis from '../../layouts/Basis.astro';
import MitgliedNav from '../../components/MitgliedNav.astro';
import UnterNav from '../../components/UnterNav.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../lib/pb';
import { site } from '../../config';

// Praevention & Beratung im Mitgliederbereich (Paragraf 23 KCanG:
// Praeventionsbeauftragte Person + Hinweis auf unabhaengige Beratung).
// Ersetzt die frueher oeffentliche Seite, seit der Verein ohne
// Web-Auftritt arbeitet (site.oeffentlich = false).
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
const { mitglied } = ergebnis;
const p = site.praeventionsbeauftragter;
---

<Basis titel="Prävention und Beratung" beschreibung="Präventionsbeauftragte Person und externe Beratungsstellen.">
  <MitgliedNav rollen={mitglied.rollen} />
  <p class="eyebrow">Mitgliederbereich</p>
  <UnterNav punkte={[{ label: 'Anleitungen', href: '/mitglieder/anleitungen' }, { label: 'Sortenberichte', href: '/mitglieder/sortenberichte' }, { label: 'Prävention & Beratung', href: '/mitglieder/praevention' }]} />
  <h1 style="margin-bottom:0.4rem;">Prävention und Beratung</h1>
  <p class="einleitung">
    Der Verein benennt eine präventionsbeauftragte Person und weist auf
    unabhängige Beratungsangebote hin. Diese Informationen dienen dem
    Gesundheitsschutz.
  </p>

  <h2>Präventionsbeauftragte Person</h2>
  <dl class="fakten">
    <dt>Name</dt>
    <dd>{p.name}</dd>
    <dt>Funktion</dt>
    <dd>{p.rolle}</dd>
    {p.email && (<><dt>E-Mail</dt><dd><a href={`mailto:${p.email}`}>{p.email}</a></dd></>)}
    {p.telefon && (<><dt>Telefon</dt><dd>{p.telefon}</dd></>)}
  </dl>

  <h2>Externe Sucht- und Beratungsstellen</h2>
  <p>
    Die folgenden Stellen beraten unabhängig vom Verein, kostenfrei und auf
    Wunsch anonym.
  </p>
  <ul>
    {
      site.externeBeratung.map((b) => (
        <li>
          <strong>{b.name}</strong>: {b.beschreibung}
          {b.telefon && <> Telefon: {b.telefon}.</>}
          {b.url && (
            <> <a href={b.url} rel="noopener">{b.url.replace('https://', '')}</a></>
          )}
        </li>
      ))
    }
  </ul>

  <h2>Jugendschutz und Gesundheit</h2>
  <p>
    Die Abgabe erfolgt ausschließlich an Mitglieder ab 18 Jahren; bis zur
    Vollendung des 21. Lebensjahres gelten zusätzliche Beschränkungen
    (30 g/Monat, höchstens 10 % THC). Der Konsum von Cannabis kann
    insbesondere bei jungen Menschen die Gehirnentwicklung beeinträchtigen
    und gesundheitliche Risiken mit sich bringen.
  </p>

  <div class="hinweis">
    Bei akuten Krisen wenden Sie sich bitte an den ärztlichen Notdienst (116117)
    oder im Notfall an 112.
  </div>
</Basis>
