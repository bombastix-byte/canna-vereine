---
import Basis from '../../layouts/Basis.astro';
import MitgliedNav from '../../components/MitgliedNav.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../lib/pb';
import { uebersetzer } from '../../lib/i18n';
const __fn = Astro.locals.funktionen;
const hatVorbestellung = __fn ? __fn.vorbestellung !== false : true;
// Geschützt. Mitglieder reservieren eine Sorte zur späteren Abholung.
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) {
  return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
}
const { pb, mitglied } = ergebnis;
if (!hatVorbestellung) return Astro.redirect('/mitglieder/bereich', 303);

interface Bestellung {
  id: string;
  sorte: string;
  menge_gramm: number;
  abholdatum?: string;
  hinweis?: string;
  status?: string;
  created: string;
}
interface Bericht {
  sorte?: string;
}

let bestellungen: Bestellung[] = [];
let sorten: string[] = [];
try {
  bestellungen = (await pb.collection('vorbestellungen').getFullList({
    sort: '-created',
  })) as Bestellung[];
} catch {
  bestellungen = [];
}
try {
  const berichte = (await pb.collection('sortenberichte').getFullList({ sort: 'sorte' })) as Bericht[];
  sorten = [...new Set(berichte.map((b) => b.sorte).filter((s): s is string => !!s))];
} catch {
  sorten = [];
}

const fehler = Astro.url.searchParams.get('fehler');
const ok = Astro.url.searchParams.get('ok');
const t = uebersetzer(Astro.locals.sprache ?? 'de');
const fehlertext: Record<string, string> = {
  fehlend: t('vorbe.fehler.fehlend'),
  menge: t('vorbe.fehler.menge'),
  fehlgeschlagen: t('vorbe.fehler.fehlgeschlagen'),
};
const meldung = fehler ? fehlertext[fehler] ?? fehlertext.fehlgeschlagen : null;

const datum = (iso?: string) =>
  iso
    ? new Date(iso).toLocaleDateString('de-DE', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric',
      })
    : '';

const statusLabel: Record<string, string> = {
  offen: t('vorbe.status.offen'),
  bestaetigt: t('vorbe.status.bestaetigt'),
  abgeholt: t('vorbe.status.abgeholt'),
  storniert: t('vorbe.status.storniert'),
};
---

<Basis titel={t('vorbe.titel')} beschreibung={t('vorbe.intro')}>
  <MitgliedNav rollen={mitglied.rollen} />
  <p class="eyebrow">{t('nav.bereich')}</p>
  <h1 style="margin-bottom:0.4rem;">{t('vorbe.titel')}</h1>
  <p class="einleitung">{t('vorbe.intro')}</p>

  {meldung && (
    <p class="hinweis hinweis--fehler" role="alert">{meldung}</p>
  )}
  {ok && (
    <p class="hinweis" role="status">{t('vorbe.ok')}</p>
  )}

  <form class="kasten" method="post" action="/mitglieder/vorbestellung/absenden">
    <div class="feld">
      <label for="sorte">{t('vorbe.sorte')}</label>
      <input id="sorte" name="sorte" type="text" list="sortenliste" required />
      {sorten.length > 0 && (
        <datalist id="sortenliste">
          {sorten.map((s) => <option value={s} />)}
        </datalist>
      )}
    </div>
    <div class="feld">
      <label for="menge_gramm">{t('vorbe.menge')}</label>
      <input id="menge_gramm" name="menge_gramm" type="number" min="1" step="1" required />
    </div>
    <div class="feld">
      <label for="abholdatum">{t('vorbe.abholdatum')}</label>
      <input id="abholdatum" name="abholdatum" type="date" />
    </div>
    <div class="feld">
      <label for="hinweis">{t('vorbe.hinweis')}</label>
      <textarea id="hinweis" name="hinweis" rows="3"></textarea>
    </div>
    <button class="knopf" type="submit">{t('vorbe.absenden')}</button>
  </form>

  <h2>{t('vorbe.deine')}</h2>
  {
    bestellungen.length === 0 ? (
      <p style="color:var(--ink-soft);">{t('vorbe.keine')}</p>
    ) : (
      <ul>
        {bestellungen.map((b) => (
          <li>
            <strong>{b.menge_gramm} g {b.sorte}</strong>
            {b.status && (
              <span style="color:var(--ink-soft);"> — {statusLabel[b.status] ?? b.status}</span>
            )}
            {b.abholdatum && (
              <div style="color:var(--ink-soft);font-size:0.92rem;">
                {t('vorbe.abholung')} {datum(b.abholdatum)}
              </div>
            )}
            {b.hinweis && (
              <div style="color:var(--ink-soft);font-size:0.92rem;">{b.hinweis}</div>
            )}
          </li>
        ))}
      </ul>
    )
  }
</Basis>
