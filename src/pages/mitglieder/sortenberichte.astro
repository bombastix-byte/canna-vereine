---
import Basis from '../../layouts/Basis.astro';
import MitgliedNav from '../../components/MitgliedNav.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../lib/pb';

// Geschützt. Sachliche Sortenbeschreibungen für Mitglieder.
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) {
  return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
}
const { pb } = ergebnis;

interface Bericht {
  id: string;
  titel: string;
  sorte?: string;
  inhalt: string;
  datum: string;
}

let berichte: Bericht[] = [];
try {
  berichte = (await pb.collection('sortenberichte').getFullList({
    sort: '-datum',
  })) as Bericht[];
} catch {
  berichte = [];
}

const datum = (iso: string) =>
  iso
    ? new Date(iso).toLocaleDateString('de-DE', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric',
      })
    : '';
---

<Basis titel="Sortenberichte" beschreibung="Sachliche Sortenbeschreibungen für Mitglieder.">
  <MitgliedNav />
  <p class="eyebrow">Mitgliederbereich</p>
  <h1 style="margin-bottom:0.4rem;">Aktuelle Sortenberichte</h1>
  <p class="einleitung">
    Sachliche Beschreibungen der im laufenden Vereinszyklus angebauten Sorten.
  </p>

  {
    berichte.length === 0 ? (
      <p style="color:var(--ink-soft);">Es liegen noch keine Sortenberichte vor.</p>
    ) : (
      berichte.map((b) => (
        <div class="kasten">
          <h3 style="margin-top:0;">{b.titel}</h3>
          <p style="color:var(--ink-soft);font-size:0.82rem;margin:0 0 0.6rem;">
            {b.sorte && <>{b.sorte} &middot; </>}
            {datum(b.datum)}
          </p>
          <p style="margin:0;white-space:pre-line;">{b.inhalt}</p>
        </div>
      ))
    )
  }
</Basis>
