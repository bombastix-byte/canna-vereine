---
import Basis from '../../layouts/Basis.astro';
import MitgliedNav from '../../components/MitgliedNav.astro';
import UnterNav from '../../components/UnterNav.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../lib/pb';
import { uebersetzer } from '../../lib/i18n';
import { anzeigeName } from '../../lib/mitglied-anzeige';

// Geschützt. Sachliche Sortenbeschreibungen für Mitglieder + Bewertungen
// der Mitglieder (Sterne + Kurzkommentar, eine Bewertung je Mitglied/Sorte).
export const prerender = false;

const __fn = Astro.locals.funktionen;
const hatBewertungen = __fn ? __fn.bewertungen !== false : true;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) {
  return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
}
const { pb, mitglied } = ergebnis;
if (Astro.locals.funktionen?.wissen === false) return Astro.redirect('/mitglieder/bereich', 303);

interface Bericht {
  id: string;
  titel: string;
  sorte?: string;
  inhalt: string;
  datum: string;
}
interface Sorte { id: string; name: string; typ?: string; aktiv?: boolean }
interface Bewertung {
  id: string; sorte: string; mitglied: string; sterne: number; kommentar?: string; updated?: string;
  expand?: { mitglied?: { vorname?: string; name?: string; mitgliedsnummer?: string; alias?: string } };
}

async function ladeListe<T>(collection: string, opts: Record<string, unknown> = {}): Promise<T[]> {
  try {
    return (await pb.collection(collection).getFullList(opts)) as T[];
  } catch {
    return [];
  }
}

const berichte = await ladeListe<Bericht>('sortenberichte', { sort: '-datum' });
const sorten = hatBewertungen ? (await ladeListe<Sorte>('sorten', { sort: 'name' })).filter((s) => s.aktiv !== false) : [];
const bewertungen = hatBewertungen ? await ladeListe<Bewertung>('sorten_bewertungen', { sort: '-updated', expand: 'mitglied' }) : [];

const fuerSorte = (id: string) => bewertungen.filter((b) => b.sorte === id);
const schnitt = (id: string) => {
  const l = fuerSorte(id);
  if (!l.length) return null;
  return Math.round((l.reduce((s, b) => s + (Number(b.sterne) || 0), 0) / l.length) * 10) / 10;
};
const meine = (id: string) => fuerSorte(id).find((b) => b.mitglied === mitglied.id);
const vornameVon = (b: Bewertung) => anzeigeName(b.expand?.mitglied);
const sterneText = (n: number) => '★'.repeat(Math.round(n)) + '☆'.repeat(5 - Math.round(n));

const t = uebersetzer(Astro.locals.sprache ?? 'de');
const ok = Astro.url.searchParams.get('ok');
const fehler = Astro.url.searchParams.get('fehler');

const datum = (iso: string) =>
  iso
    ? new Date(iso).toLocaleDateString('de-DE', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric',
      })
    : '';
---

<Basis titel={t('sorten.titel')} beschreibung={t('sorten.intro_ohne')}>
  <MitgliedNav rollen={mitglied.rollen} />
  <p class="eyebrow">{t('nav.bereich')}</p>
  <UnterNav punkte={[{ label: t('wissen.anleitungen'), href: '/mitglieder/anleitungen' }, { label: t('wissen.sortenberichte'), href: '/mitglieder/sortenberichte' }, { label: t('wissen.praevention'), href: '/mitglieder/praevention' }]} />
  <h1 style="margin-bottom:0.4rem;">{t('sorten.titel')}</h1>
  <p class="einleitung">{hatBewertungen ? t('sorten.intro_mit') : t('sorten.intro_ohne')}</p>

  {ok === 'bewertet' && <p class="hinweis" role="status">{t('sorten.ok_bewertet')}</p>}
  {fehler === 'bewertung' && <p class="hinweis hinweis--fehler" role="alert">{t('sorten.fehler_bewertung')}</p>}

  {hatBewertungen && sorten.length > 0 && (
    <>
      <h2>{t('sorten.bewertungen_h')}</h2>
      {sorten.map((s) => {
        const alle = fuerSorte(s.id);
        const avg = schnitt(s.id);
        const mein = meine(s.id);
        return (
          <details class="sorte" id={`s-${s.id}`}>
            <summary>
              <span class="sorte-name">{s.name}{s.typ ? ` · ${s.typ}` : ''}</span>
              <span class="sorte-wertung">
                {avg != null ? (
                  <><span class="sterne" aria-hidden="true">{sterneText(avg)}</span> {avg.toFixed(1)} ({alle.length})</>
                ) : (
                  <span style="color:var(--ink-soft);">{t('sorten.noch_keine')}</span>
                )}
              </span>
            </summary>

            <form class="bewerten" method="post" action="/mitglieder/sortenberichte/bewerten">
              <input type="hidden" name="sorte" value={s.id} />
              <fieldset class="sterne-wahl">
                <legend>{mein ? t('sorten.deine_aendern') : t('sorten.deine')}</legend>
                <div class="radio-reihe">
                  {[1, 2, 3, 4, 5].map((n) => (
                    <label class="stern-label">
                      <input type="radio" name="sterne" value={n} checked={mein?.sterne === n} required />
                      <span>{n}★</span>
                    </label>
                  ))}
                </div>
              </fieldset>
              <input class="eingabe" name="kommentar" type="text" maxlength="500"
                value={mein?.kommentar ?? ''} placeholder={t('sorten.kommentar_ph')} />
              <button class="knopf-sek" type="submit">{t('sorten.speichern')}</button>
            </form>

            {alle.filter((b) => b.kommentar).length > 0 && (
              <ul class="kommentare">
                {alle.filter((b) => b.kommentar).slice(0, 10).map((b) => (
                  <li>
                    <span class="k-sterne" aria-hidden="true">{sterneText(b.sterne)}</span>
                    <span class="k-text">{b.kommentar}</span>
                    <span class="k-wer">— {vornameVon(b)}</span>
                  </li>
                ))}
              </ul>
            )}
          </details>
        );
      })}
    </>
  )}

  <h2>{t('sorten.berichte_h')}</h2>
  {
    berichte.length === 0 ? (
      <p style="color:var(--ink-soft);">{t('sorten.keine_berichte')}</p>
    ) : (
      berichte.map((b) => (
        <div class="kasten">
          <h3 style="margin-top:0;">{b.titel}</h3>
          <p style="color:var(--ink-soft);font-size:0.82rem;margin:0 0 0.6rem;">
            {b.sorte && <>{b.sorte} &middot; </>}
            {datum(b.datum)}
          </p>
          <p style="margin:0;white-space:pre-line;">{b.inhalt}</p>
        </div>
      ))
    )
  }
</Basis>

<style>
  .sorte { max-width: var(--mass); border: 1px solid var(--line); border-radius: var(--radius); background: var(--bg-rein); margin: 0 0 0.6rem; }
  .sorte summary { cursor: pointer; padding: 0.7rem 0.9rem; display: flex; justify-content: space-between; gap: 0.8rem; flex-wrap: wrap; align-items: baseline; }
  .sorte-name { font-weight: 600; }
  .sorte-wertung { font-size: 0.92rem; }
  .sterne, .k-sterne { color: var(--accent); letter-spacing: 0.1em; }
  .bewerten { padding: 0 0.9rem 0.9rem; border-top: 1px solid var(--line); display: flex; flex-direction: column; gap: 0.6rem; }
  .sterne-wahl { border: 0; padding: 0.6rem 0 0; margin: 0; }
  .sterne-wahl legend { font-size: 0.88rem; color: var(--ink-soft); padding: 0; margin-bottom: 0.3rem; }
  .radio-reihe { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .stern-label { display: inline-flex; align-items: center; }
  .stern-label input { position: absolute; opacity: 0; width: 1px; height: 1px; }
  .stern-label span { padding: 0.35rem 0.7rem; border: 1px solid var(--line); border-radius: 999px; color: var(--ink-soft); cursor: pointer; }
  .stern-label input:checked + span { border-color: var(--accent); color: var(--accent); font-weight: 600; }
  .stern-label input:focus-visible + span { outline: 2px solid var(--accent); }
  .eingabe { width: 100%; padding: 0.5rem 0.65rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--bg-rein); color: var(--ink); font: inherit; }
  .bewerten .knopf-sek { align-self: flex-start; }
  .kommentare { list-style: none; margin: 0; padding: 0 0.9rem 0.9rem; }
  .kommentare li { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: baseline; padding: 0.35rem 0; border-top: 1px solid var(--line); font-size: 0.92rem; }
  .k-text { flex: 1 1 12rem; overflow-wrap: anywhere; }
  .k-wer { color: var(--ink-soft); font-size: 0.85rem; }
</style>
