---
import Basis from '../../layouts/Basis.astro';
import { mitgliedAusToken, AUTH_COOKIE } from '../../lib/pb';
import { HINWEIS_VERSION, mussBestaetigen } from '../../lib/einwilligung';
import { startseiteFuer } from '../../lib/mitglied-nav';
import { uebersetzer } from '../../lib/i18n';
import SprachWahl from '../../components/SprachWahl.astro';
import { site } from '../../config';

// Präventions-/Gesundheitshinweise nach § 23 KCanG mit Kenntnisnahme-Bestätigung.
// Bewusst OHNE Navigation: Interstitial beim ersten Login, bis bestätigt wurde.
// Mehrsprachig (DE/EN/PL), damit alle Mitglieder die Hinweise verstehen.
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
const { mitglied } = ergebnis;

// Schon bestätigt (aktuelle Version)? Dann zurück in den Bereich.
if (!mussBestaetigen(mitglied)) return Astro.redirect(startseiteFuer(mitglied.rollen), 303);

const t = uebersetzer(Astro.locals.sprache ?? 'de');
const fehler = Astro.url.searchParams.get('fehler');
const praev = site.praeventionsbeauftragter;
---

<Basis titel={t('hinweise.titel')} beschreibung="Präventions- und Gesundheitshinweise zur Kenntnis nehmen.">
  <p class="eyebrow">{t('hinweise.eyebrow')}</p>
  <h1 style="margin-bottom:0.4rem;">{t('hinweise.titel')}</h1>
  <p class="einleitung">{t('hinweise.intro')}</p>
  <SprachWahl />

  {fehler && <p class="hinweis hinweis--fehler" role="alert">{t('hinweise.fehler')}</p>}

  <section class="kasten hinweistext">
    <h2>{t('hinweise.h.gesundheit')}</h2>
    <ul>
      <li>{t('hinweise.p1')}</li>
      <li>{t('hinweise.p2')}</li>
      <li>{t('hinweise.p3')}</li>
      <li>{t('hinweise.p4')}</li>
      <li>{t('hinweise.p5')}</li>
    </ul>
    <h2>{t('hinweise.h.umgang')}</h2>
    <ul>
      <li>{t('hinweise.p6')}</li>
      <li>
        {t('hinweise.p7a')}
        <strong> {praev.name}</strong>{praev.email ? <> · <a href={`mailto:${praev.email}`}>{praev.email}</a></> : null}.
      </li>
      <li>{t('hinweise.p8a')} <a href="/praevention-beratung">{t('hinweise.p8link')}</a>.</li>
    </ul>
  </section>

  <form method="post" action="/mitglieder/hinweise/bestaetigen" class="bestaetigung">
    <label class="check">
      <input type="checkbox" name="bestaetigt" required />
      <span>{t('hinweise.check')}</span>
    </label>
    <button class="knopf" type="submit">{t('hinweise.knopf')}</button>
    <p class="fuss">{t('hinweise.version')} {HINWEIS_VERSION}. {t('hinweise.fuss')}</p>
  </form>
</Basis>

<style>
  .hinweistext h2 { font-size: 1.05rem; margin: 1rem 0 0.5rem; }
  .hinweistext h2:first-child { margin-top: 0; }
  .hinweistext ul { margin: 0 0 0.5rem; padding-left: 1.2rem; }
  .hinweistext li { margin: 0.3rem 0; line-height: 1.5; }
  .bestaetigung { max-width: var(--mass); margin-top: 1.4rem; }
  .check { display: flex; gap: 0.6rem; align-items: flex-start; margin-bottom: 1rem; font-size: 1rem; }
  .check input { margin-top: 0.25rem; width: 1.2rem; height: 1.2rem; flex: none; }
  .fuss { color: var(--ink-soft); font-size: 0.85rem; margin: 0.7rem 0 0; }
</style>
