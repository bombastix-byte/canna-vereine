---
import Basis from '../../layouts/Basis.astro';
import MitgliedNav from '../../components/MitgliedNav.astro';
import { mitgliedAusToken, AUTH_COOKIE, dateiUrl } from '../../lib/pb';
import { darfAusgeben, darfAnbau, darfBerichte, darfVerwalten, istPersonal } from '../../lib/rollen';
import { type Dienst, type Eintrag, findetStatt, belegtAm, tagVon } from '../../lib/helfer';
import { vorstandsKennzahlen } from '../../lib/cockpit';
import { berlinTag } from '../../lib/ausgabe';
import { mussBestaetigen } from '../../lib/einwilligung';
import { uebersetzer } from '../../lib/i18n';
import { anzeigeName } from '../../lib/mitglied-anzeige';
const __fn = Astro.locals.funktionen;
const hatBeitraege = __fn ? __fn.beitraege !== false : true;
const hatKasse = __fn ? __fn.kasse !== false : true;
const hatAntraege = __fn ? __fn.antraege !== false : true;
const hatTermine = __fn ? __fn.termine !== false : true;
const hatVorbestellung = __fn ? __fn.vorbestellung !== false : true;
const hatHelferplan = __fn ? __fn.helferplan !== false : true;
// Geschütztes Mitglieder-Dashboard. Serverseitig gerendert.
export const prerender = false;

const ergebnis = await mitgliedAusToken(Astro.cookies.get(AUTH_COOKIE)?.value);
if (!ergebnis) {
  return Astro.redirect('/mitglieder?fehler=anmeldung', 303);
}
const { pb, mitglied } = ergebnis;
// Einwilligungs-Gate: erst die Präventionshinweise bestätigen.
if (mussBestaetigen(mitglied)) return Astro.redirect('/mitglieder/hinweise', 303);

// Inhalte laden. Fehlt eine Collection noch (frische Installation), bleibt der
// Bereich leer statt zu scheitern.
async function ladeListe<T = Record<string, unknown>>(
  collection: string,
  sort: string,
): Promise<T[]> {
  try {
    return (await pb.collection(collection).getFullList({ sort })) as T[];
  } catch {
    return [];
  }
}

interface Mitteilung {
  id: string;
  titel: string;
  inhalt: string;
  datum: string;
}
interface Termin {
  id: string;
  titel: string;
  datum: string;
  ort?: string;
  beschreibung?: string;
}
interface Dokument {
  id: string;
  titel: string;
  kategorie?: string;
  datei: string;
}
interface Angebot {
  id: string;
  titel: string;
  inhalt: string;
  gueltig_von?: string;
  gueltig_bis?: string;
}
interface Bestellung {
  id: string;
  status?: string;
}
const mitteilungen = await ladeListe<Mitteilung>('mitteilungen', '-datum');
const termine = await ladeListe<Termin>('termine', 'datum');
const dokumente = await ladeListe<Dokument>('dokumente', 'titel');
const angebote = await ladeListe<Angebot>('wochenangebot', '-gueltig_von');
const bestellungen = await ladeListe<Bestellung>('vorbestellungen', '-created');
const dienste = await ladeListe<Dienst>('helferdienste', 'titel');
const helferEintraege = await ladeListe<Eintrag>('helfer_eintragungen', 'created');

const jetzt = new Date();
const naechsterTermin = termine.find((t) => new Date(t.datum) >= jetzt) ?? termine[0];
const neuesteMitteilung = mitteilungen[0];
const aktuellesAngebot = angebote[0];
const offeneBestellungen = bestellungen.filter((b) => b.status === 'offen').length;
const heuteTag = tagVon(new Date());
const offeneDienste = dienste.filter(
  (d) => findetStatt(d, heuteTag) && belegtAm(helferEintraege, d.id, heuteTag) < d.bedarf,
).length;

const datum = (iso: string) =>
  iso
    ? new Date(iso).toLocaleDateString('de-DE', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric',
      })
    : '';

const downloadUrl = (d: Dokument) =>
  d.datei ? dateiUrl(d as unknown as { collectionId: string; id: string }, d.datei) : '#';

// Vorstands-Cockpit: Kennzahlen nur für Verwaltende laden.
const kennzahlen = darfVerwalten(mitglied.rollen) ? await vorstandsKennzahlen(pb, berlinTag(), hatBeitraege) : null;
const eur = (n: number) => n.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const gramm = (n: number) => n.toLocaleString('de-DE', { maximumFractionDigits: 1 });
const tr = uebersetzer(Astro.locals.sprache ?? 'de');
---

<Basis titel={tr('nav.bereich')} beschreibung={tr('bereich.sub')}>
  <MitgliedNav rollen={mitglied.rollen} />

  <header class="willkommen">
    <p class="eyebrow">{tr('nav.bereich')}</p>
    <h1>{tr('bereich.willkommen')}, {anzeigeName(mitglied)}</h1>
    <p class="willkommen__sub">{tr('bereich.sub')}</p>
  </header>

  <section class="ueberblick" aria-label="Auf einen Blick">
    <a class="uk" href="/mitglieder/wochenangebot">
      <span class="uk__kopf">
        <svg class="uk__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M3 9h18M3 9l2-4h14l2 4M5 9v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9M9 13h6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="uk__label">{tr('nav.angebot')}</span>
      </span>
      <span class="uk__wert">{aktuellesAngebot ? aktuellesAngebot.titel : tr('bereich.angebot_leer')}</span>
    </a>

    {hatTermine && (
    <a class="uk" href="#termine">
      <span class="uk__kopf">
        <svg class="uk__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <rect x="3" y="4.5" width="18" height="16" rx="2"/>
          <path d="M3 9h18M8 2.5v4M16 2.5v4" stroke-linecap="round"/>
        </svg>
        <span class="uk__label">{tr('bereich.naechster_termin')}</span>
      </span>
      <span class="uk__wert">
        {naechsterTermin ? `${datum(naechsterTermin.datum)} - ${naechsterTermin.titel}` : tr('bereich.keine_termine')}
      </span>
    </a>
    )}

    <a class="uk" href="#mitteilungen">
      <span class="uk__kopf">
        <svg class="uk__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M4 9v6h3l5 4V5L7 9H4zM16 8.5a4 4 0 0 1 0 7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="uk__label">{tr('bereich.neueste_mitteilung')}</span>
      </span>
      <span class="uk__wert">{neuesteMitteilung ? neuesteMitteilung.titel : tr('bereich.keine_mitteilungen')}</span>
    </a>

    {hatVorbestellung && (
    <a class="uk" href="/mitglieder/vorbestellung">
      <span class="uk__kopf">
        <svg class="uk__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M6 7h12l-1 13H7L6 7zM9 7a3 3 0 0 1 6 0M9.5 12.5l1.8 1.8 3.2-3.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="uk__label">{tr('bereich.deine_vorbe')}</span>
      </span>
      <span class="uk__wert">
        {offeneBestellungen > 0 ? `${offeneBestellungen} ${tr('bereich.offen')}` : tr('bereich.keine_offenen')}
      </span>
    </a>
    )}

    {hatHelferplan && (
    <a class="uk" href="/mitglieder/helferplan">
      <span class="uk__kopf">
        <svg class="uk__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M12 21s-7-4.5-9.3-9A5 5 0 0 1 12 7a5 5 0 0 1 9.3 5c-2.3 4.5-9.3 9-9.3 9z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="uk__label">{tr('bereich.mithelfen')}</span>
      </span>
      <span class="uk__wert">
        {offeneDienste > 0 ? `${offeneDienste} ${tr('bereich.heute_offen')}` : tr('bereich.heute_nichts')}
      </span>
    </a>
    )}
  </section>

  {kennzahlen && (
    <>
      <p class="eyebrow" style="margin:1.6rem 0 0.6rem;">Vorstand · auf einen Blick</p>
      <section class="cockpit" aria-label="Kennzahlen">
        <a class="kpi" href="/mitglieder/verwaltung">
          <span class="kpi__wert">{kennzahlen.mitglieder}</span>
          <span class="kpi__label">Mitglieder</span>
        </a>
        {hatBeitraege && (
          <a class:list={['kpi', { 'kpi--warn': kennzahlen.rueckstandZahl > 0 }]} href="/mitglieder/beitraege/status">
            <span class="kpi__wert">{kennzahlen.rueckstandZahl}</span>
            <span class="kpi__label">im Rückstand{kennzahlen.rueckstandZahl > 0 ? ` · ${eur(kennzahlen.rueckstandSumme)} €` : ''}</span>
          </a>
        )}
        <a class="kpi" href="/mitglieder/wawi">
          <span class="kpi__wert">{gramm(kennzahlen.bestandG)} g</span>
          <span class="kpi__label">Bestand freigegeben</span>
        </a>
        <a class="kpi" href="/mitglieder/ausgabe">
          <span class="kpi__wert">{gramm(kennzahlen.abgabe7G)} g</span>
          <span class="kpi__label">abgegeben (7 Tage)</span>
        </a>
        {hatAntraege && (
          <a class:list={['kpi', { 'kpi--warn': kennzahlen.antraegeOffen > 0 }]} href="/mitglieder/antraege">
            <span class="kpi__wert">{kennzahlen.antraegeOffen}</span>
            <span class="kpi__label">offene Anträge</span>
          </a>
        )}
        {hatKasse && (
          <a class:list={['kpi', { 'kpi--warn': kennzahlen.kasseOffen && kennzahlen.kasseErwartet > 0 }]} href="/mitglieder/kasse">
            <span class="kpi__wert">{eur(kennzahlen.kasseErwartet)} €</span>
            <span class="kpi__label">Kasse heute{kennzahlen.kasseOffen ? ' · offen' : ' · abgeschlossen'}</span>
          </a>
        )}
        {kennzahlen.rueckrufeAktiv > 0 && (
          <a class="kpi kpi--gefahr" href="/mitglieder/wawi">
            <span class="kpi__wert">{kennzahlen.rueckrufeAktiv}</span>
            <span class="kpi__label">aktive Rückrufe</span>
          </a>
        )}
      </section>
    </>
  )}

  {istPersonal(mitglied.rollen) && (
    <p class="eyebrow" style="margin:1.6rem 0 0.6rem;">Vereinsarbeit</p>
  )}
  {istPersonal(mitglied.rollen) && (
  <section class="ueberblick" aria-label="Vereinsarbeit">
    {darfAnbau(mitglied.rollen) && (
      <a class="uk" href="/mitglieder/wawi">
        <span class="uk__kopf">
          <svg class="uk__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M12 22V12M12 12c0-3 2-5 5-5 0 3-2 5-5 5zM12 12c0-3-2-5-5-5 0 3 2 5 5 5zM12 12c0-2.5 1.5-4.5 4-4.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="uk__label">Warenwirtschaft</span>
        </span>
        <span class="uk__wert">Chargen &amp; Bestand</span>
      </a>
    )}

    {darfAusgeben(mitglied.rollen) && (
      <a class="uk" href="/mitglieder/ausgabe">
        <span class="uk__kopf">
          <svg class="uk__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M4 7h16M6 7v12a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V7M9 7V5a3 3 0 0 1 6 0v2M10 12h4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="uk__label">Ausgabe</span>
        </span>
        <span class="uk__wert">Abgabe · Samen / Stecklinge</span>
      </a>
    )}

    {darfBerichte(mitglied.rollen) && (
      <a class="uk" href="/mitglieder/jahresmeldung">
        <span class="uk__kopf">
          <svg class="uk__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M7 3h7l5 5v13a0 0 0 0 1 0 0H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1zM14 3v5h5M9 13h6M9 17h6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="uk__label">Jahresmeldung</span>
        </span>
        <span class="uk__wert">Behörden-Aggregat</span>
      </a>
    )}

    {darfVerwalten(mitglied.rollen) && (
      <a class="uk" href="/mitglieder/verwaltung">
        <span class="uk__kopf">
          <svg class="uk__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M9 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM3 20a6 6 0 0 1 12 0M17 8l2 2 3-3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="uk__label">Verwaltung</span>
        </span>
        <span class="uk__wert">Mitglieder · Anträge · Beiträge</span>
      </a>
    )}
  </section>
  )}

  <h2 id="mitteilungen">{tr('bereich.h.mitteilungen')}</h2>
  {
    mitteilungen.length === 0 ? (
      <p style="color:var(--ink-soft);">{tr('bereich.keine_mitteilungen_lang')}</p>
    ) : (
      mitteilungen.map((m) => (
        <div class="kasten">
          <h3 style="margin-top:0;">{m.titel}</h3>
          <p style="color:var(--ink-soft);font-size:0.82rem;margin:0 0 0.6rem;">
            {datum(m.datum)}
          </p>
          <p style="margin:0;white-space:pre-line;">{m.inhalt}</p>
        </div>
      ))
    )
  }

  <h2 id="termine">{tr('bereich.h.termine')}</h2>
  {
    termine.length === 0 ? (
      <p style="color:var(--ink-soft);">{tr('bereich.keine_termine_lang')}</p>
    ) : (
      <ul class="terminliste">
        {termine.map((t) => (
          <li>
            <span class="termin__datum">{datum(t.datum)}</span>
            <span class="termin__inhalt">
              <strong>{t.titel}</strong>
              {t.ort && <span style="color:var(--ink-soft);"> &middot; {t.ort}</span>}
              {t.beschreibung && (
                <span class="termin__text">{t.beschreibung}</span>
              )}
            </span>
          </li>
        ))}
      </ul>
    )
  }

  <h2>{tr('bereich.h.dokumente')}</h2>
  {
    dokumente.length === 0 ? (
      <p style="color:var(--ink-soft);">{tr('bereich.keine_dokumente')}</p>
    ) : (
      <ul>
        {dokumente.map((d) => (
          <li>
            <a href={downloadUrl(d)} rel="noopener">
              {d.titel}
            </a>
            {d.kategorie && (
              <span style="color:var(--ink-soft);"> — {d.kategorie}</span>
            )}
          </li>
        ))}
      </ul>
    )
  }
</Basis>

<style>
  .willkommen {
    margin: 0 0 2rem;
  }
  .willkommen h1 {
    margin: 0 0 0.5rem;
  }
  .willkommen__sub {
    color: var(--ink-soft);
    font-size: 1.05rem;
    max-width: 46ch;
    margin: 0;
  }

  .ueberblick {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12.5rem, 1fr));
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    margin: 0 0 1rem;
    max-width: var(--mass);
  }
  .uk {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.3rem 1.4rem;
    background: var(--bg-rein);
    text-decoration: none;
    color: var(--ink);
    transition: background 0.12s ease;
  }
  .uk:hover {
    background: var(--line-soft);
  }
  .uk__kopf {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
  .uk__icon {
    flex: none;
    width: 22px;
    height: 22px;
    color: var(--accent);
  }
  .uk__label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .uk__wert {
    font-family: var(--font-display);
    font-size: 1.08rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--brand-strong);
  }

  /* Vorstands-Cockpit: kompakte Kennzahlen-Kacheln */
  .cockpit {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: 0.6rem;
    margin: 0 0 1rem;
    max-width: var(--mass);
  }
  .kpi {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.9rem 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-rein);
    text-decoration: none;
    color: var(--ink);
    transition: background 0.12s ease, border-color 0.12s ease;
  }
  .kpi:hover {
    background: var(--line-soft);
  }
  .kpi__wert {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.15;
    color: var(--brand-strong);
  }
  .kpi__label {
    font-size: 0.78rem;
    color: var(--ink-soft);
  }
  .kpi--warn {
    border-color: var(--accent);
  }
  .kpi--warn .kpi__wert {
    color: var(--accent);
  }
  .kpi--gefahr {
    border-color: var(--gefahr);
    background: var(--gefahr-bg);
  }
  .kpi--gefahr .kpi__wert {
    color: var(--gefahr);
  }

  /* Terminliste als saubere Zeitachse */
  .terminliste {
    list-style: none;
    padding: 0;
    margin: 1.4rem 0;
    max-width: var(--mass);
  }
  .terminliste li {
    display: flex;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--line);
  }
  .termin__datum {
    flex: none;
    width: 6.5rem;
    font-weight: 600;
    color: var(--brand-strong);
    font-size: 0.92rem;
  }
  .termin__inhalt {
    display: flex;
    flex-direction: column;
    /* Flex-Item darf schrumpfen, lange Woerter brechen um. */
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .termin__text {
    color: var(--ink-soft);
    font-size: 0.92rem;
  }
</style>
