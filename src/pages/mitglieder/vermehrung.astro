---
// Die Vermehrung ist in die Tresen-Seite integriert (Abgabe + Samen/Stecklinge
// in einem Vorgangskontext). Alte Lesezeichen landen weich dort.
export const prerender = false;
const q = Astro.url.searchParams.toString();
return Astro.redirect(`/mitglieder/ausgabe${q ? `?${q}` : ''}`, 301);
