---
import Basis from '../layouts/Basis.astro';
import { site } from '../config';
import { pfad } from '../lib/url';
// Kein oeffentlicher Auftritt (Vereinskonzept: keine Website): alles zur
// Anmeldung umleiten. Beim statischen Build entsteht eine Redirect-Seite.
if (site.oeffentlich === false) return Astro.redirect('/mitglieder');

const k = site.kontakt;
---

<Basis
  titel="Startseite"
  beschreibung={`Sachinformationen der ${site.vereinsname} nach dem Konsumcannabisgesetz (KCanG).`}
>
  <section class="hero" slot="hero">
    <div class="hero__innen">
      <p class="eyebrow">Anbauvereinigung nach KCanG</p>
      <h1>{site.vereinsname}</h1>
      <p>
        Sachliche Informationen sowie Anschrift und Erreichbarkeit der
        Vereinigung in {site.stadt}.
      </p>
    </div>
  </section>

  <div class="kasten">
    <h2>Was eine Anbauvereinigung ist</h2>
    <p style="margin-bottom:0;">
      Eine Anbauvereinigung ist ein eingetragener Verein, dem nach Paragraf 11
      KCanG der gemeinschaftliche, nicht gewerbliche Eigenanbau von Cannabis und
      die Weitergabe an seine Mitglieder zum Eigenkonsum erlaubt ist. Die Abgabe
      erfolgt ausschließlich an volljährige Mitglieder. Ein Verkauf an Dritte
      sowie jede Form des Handels sind ausgeschlossen.
    </p>
  </div>

  <h2>So finden Sie uns</h2>
  <dl class="fakten">
    <dt>Anschrift</dt>
    <dd>{site.vereinsname}, {k.strasse}, {k.plz} {k.ort}</dd>
    {k.besuchszeiten && (<><dt>Besuchszeiten</dt><dd>{k.besuchszeiten}</dd></>)}
    <dt>E-Mail</dt>
    <dd><a href={`mailto:${k.email}`}>{k.email}</a></dd>
    {k.telefon && (<><dt>Telefon</dt><dd>{k.telefon}</dd></>)}
    {k.erreichbarkeit && (<><dt>Erreichbarkeit</dt><dd>{k.erreichbarkeit}</dd></>)}
  </dl>
  <p>
    Weitere Angaben unter <a href={pfad('/kontakt')}>Kontakt</a>. Mitglieder
    finden aktuelle Informationen im
    <a href={pfad('/mitglieder')}>Mitgliederbereich</a>.
  </p>

  <div class="hinweis">
    <strong>Gesetzlicher Hinweis.</strong> Der Konsum von Cannabis kann
    gesundheitliche Risiken mit sich bringen, insbesondere für Jugendliche und
    junge Erwachsene. Die Abgabe erfolgt ausschließlich an Mitglieder ab 18
    Jahren. Informationen zur Suchtvorbeugung finden Sie unter
    <a href={pfad('/praevention-beratung')}>Prävention und Beratung</a>.
  </div>
</Basis>
