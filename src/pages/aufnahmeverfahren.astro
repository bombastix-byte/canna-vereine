---
import Basis from '../layouts/Basis.astro';
import { site } from '../config';
import { pfad } from '../lib/url';
---

<Basis
  titel="Aufnahmeverfahren"
  beschreibung="Sachliche Darstellung der Voraussetzungen und des Ablaufs einer Mitgliedschaft."
>
  <h1>Aufnahmeverfahren</h1>
  <p class="einleitung">
    Die folgenden Angaben beschreiben sachlich die gesetzlichen und satzungs-
    maessigen Voraussetzungen sowie den Ablauf einer Mitgliedschaft. Sie stellen
    keine Aufforderung zum Beitritt dar.
  </p>

  <h2>Voraussetzungen</h2>
  <ul>
    <li>Vollendung des 18. Lebensjahres.</li>
    <li>Wohnsitz oder gewoehnlicher Aufenthalt in Deutschland seit mindestens sechs Monaten (Paragraf 11 KCanG).</li>
    <li>Keine gleichzeitige Mitgliedschaft in einer weiteren Anbauvereinigung.</li>
    <li>Anerkennung der Satzung und der Beitragsordnung des Vereins.</li>
  </ul>

  <h2>Ablauf</h2>
  <ol>
    <li>Schriftlicher Aufnahmeantrag an den Verein.</li>
    <li>Pruefung der Voraussetzungen durch den Vorstand.</li>
    <li>Nachweis des Alters und des Wohnsitzes.</li>
    <li>Information und Aufklaerungsgespraech zu Gesundheits- und Jugendschutz.</li>
    <li>Beschluss ueber die Aufnahme und Beginn der Mitgliedschaft.</li>
  </ol>

  <div class="kasten">
    <h2>Hinweise zur Bearbeitung</h2>
    <p>
      Antraege koennen schriftlich an die unter <a href={pfad('/kontakt')}>Kontakt</a>
      genannte Anschrift gerichtet werden. Eine Aufnahme begruendet keinen
      Anspruch und steht im Rahmen der gesetzlichen Hoechstmitgliederzahl von
      500 Personen (Paragraf 11 KCanG).
    </p>
    {
      site.dokumente.satzungPdf ? (
        <p>
          Die massgeblichen Regelungen ergeben sich aus der{' '}
          <a href={site.dokumente.satzungPdf}>Satzung</a>.
        </p>
      ) : (
        <p class="platzhalter">
          Platzhalter: Verlinkung der Satzung als PDF, sobald hinterlegt.
        </p>
      )
    }
  </div>
</Basis>
