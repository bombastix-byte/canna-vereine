---
import '../styles/themes.css';
import '../styles/global.css';
import '../styles/sidebar.css';
import Kopf from '../components/Kopf.astro';
import Fuss from '../components/Fuss.astro';
import Sidebar from '../components/Sidebar.astro';
import Mark from '../components/Mark.astro';
import { site, produkt } from '../config';
import { pfad } from '../lib/url';

interface Props {
  titel: string;
  beschreibung?: string;
  /** robots-Meta; 'noindex, nofollow' fuer Seiten, die nicht in Suchmaschinen sollen. */
  robots?: string;
  /**
   * Anonyme Seite: kein Vereinsname im Titel, neutrale Marke in der
   * Seitenleiste. Fuer die oeffentliche Login-Seite, wenn der Verein keinen
   * Web-Auftritt hat (Impressum bleibt erreichbar, nur nicht sichtbar
   * verlinkt).
   */
  anonym?: boolean;
}

const { titel, beschreibung, robots = 'index, follow', anonym = false } = Astro.props;
// Entwicklungs-Schutz: solange die Site nicht ausdruecklich indexierbar ist
// (site.indexierbar), bekommt JEDE Seite noindex - unabhaengig vom Prop.
const robotsWert = site.indexierbar ? robots : 'noindex, nofollow';
// Anonym: neutraler Dokumenttitel. Sonst Produktmarke (CVMS) im Tab, nicht
// der Vereinsname (Diskretion + Produkt-Identitaet).
const seitentitel = anonym ? titel : `${titel} | ${produkt.name}`;
const hatHero = Astro.slots.has('hero');
const layout = site.layout ?? 'standard';
---

<!doctype html>
<html lang="de" data-theme={site.theme} data-layout={layout}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{seitentitel}</title>
    {beschreibung && <meta name="description" content={beschreibung} />}
    <meta name="robots" content={robotsWert} />
    <meta name="theme-color" content="#2c3629" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icon-180.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content={anonym ? 'Mitgliederbereich' : produkt.name} />
    <script is:inline>
      // Service Worker registrieren (PWA: installierbar, Offline-Grundgeruest,
      // Push). Nur in sicheren Kontexten (https/localhost).
      if ('serviceWorker' in navigator && (location.protocol === 'https:' || location.hostname === 'localhost')) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js').catch(function () {});
        });
      }
    </script>
    <script is:inline>
      (function () {
        var erlaubt = ['botanik', 'klar', 'warm', 'nacht'];
        var t = new URLSearchParams(location.search).get('theme');
        if (t && erlaubt.indexOf(t) !== -1) {
          document.documentElement.setAttribute('data-theme', t);
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#inhalt">Zum Inhalt springen</a>
    {
      layout === 'sidebar' ? (
        <>
          <input type="checkbox" id="nav-toggle" class="sb-toggle" tabindex="-1" />
          <div class="sb-shell">
            <header class="sb-topbar">
              <a class="sb-brand sb-brand--top" href={anonym ? '/mitglieder' : pfad('/')}>
                <Mark class="sb-mark" />
                <span class="sb-name">{anonym ? 'Mitgliederbereich' : produkt.name}</span>
              </a>
              <label class="sb-burger" for="nav-toggle" aria-label="Menü öffnen oder schließen">
                <span /> <span /> <span />
              </label>
            </header>
            <label class="sb-overlay" for="nav-toggle" aria-hidden="true" />
            <aside class="sb-sidebar">
              <Sidebar />
            </aside>
            <div class="sb-haupt">
              {hatHero && <slot name="hero" />}
              <main id="inhalt" class="inhalt">
                <slot />
              </main>
              {!anonym && <Fuss />}
            </div>
          </div>
        </>
      ) : (
        <>
          <Kopf variant={layout === 'zentriert' ? 'zentriert' : 'standard'} />
          {hatHero && <slot name="hero" />}
          <main id="inhalt" class="inhalt">
            <slot />
          </main>
          {!anonym && <Fuss />}
        </>
      )
    }
  </body>
</html>
